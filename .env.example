# Copy to .env (gitignored) for local dev, or set as a Render Environment
# Variable in the dashboard for deploys. Read by scripts/prepare-protected-assets.mjs
# at build time — see that file and src/lib/clientGate.ts for how it's used.
# Never committed; this repo is public.
UNLOCK_PASSWORDS={"overrun-bomber":"thread2024"}

# Optional for Render/static deploys. If private/protected-images is not present
# during the build, the prep script can fetch the real hero image from a private
# GitHub repo instead. Store the image as:
# protected-images/<projectId>/hero-real.<png|jpg|jpeg|webp|svg>
# PROTECTED_ASSETS_REPO=Arnav1511/girisha-protected-assets
# PROTECTED_ASSETS_TOKEN=github_pat_read_only_token_here
# PROTECTED_ASSETS_REF=main
# PROTECTED_ASSETS_PATH_PREFIX=protected-images
