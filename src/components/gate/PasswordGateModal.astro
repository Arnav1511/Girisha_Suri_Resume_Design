---
/**
 * Single, globally-mounted gate modal (see BaseLayout). Any element that
 * should open it just needs three data attributes — no per-page wiring:
 *
 *   <button data-gate-trigger data-project-id="..." data-project-title="...">
 *     <img>...</img>
 *     <span data-role="lock-affordance">...</span>
 *     <span data-role="protected-tag">...</span>
 *   </button>
 *
 * On a correct password the modal swaps that trigger's own <img> src to
 * the unlocked URL, drops the lock affordance, and updates the tag — in
 * place, no page reload. The check itself happens in src/lib/clientGate.ts
 * (see that file for why — this site deploys as a static site with no
 * server to check a password against).
 */
---

<dialog id="gate-modal" class="gate-modal" aria-labelledby="gate-title">
  <form method="dialog" class="gate-form" data-gate-form>
    <button type="button" class="close" data-gate-close aria-label="Close">&times;</button>
    <p class="kicker">Protected project</p>
    <h2 id="gate-title" data-gate-title>Project</h2>
    <p class="copy">
      This is an unreleased commercial project, held back until the client release goes live.
      It's viewable on request — enter the project password below, or
      <a href="mailto:hello@girishasuri.example?subject=Project%20access%20request">request access</a>.
    </p>
    <label class="field">
      <span>Password</span>
      <input type="password" name="password" autocomplete="off" required data-gate-input />
    </label>
    <p class="error" role="alert" data-gate-error hidden></p>
    <button type="submit" class="submit" data-gate-submit>Unlock</button>
  </form>
</dialog>

<style>
  .gate-modal {
    border: none;
    border-radius: var(--radius-md);
    padding: 0;
    max-width: 28rem;
    width: calc(100% - 2 * var(--page-gutter));
    background: var(--color-bg-raised);
    color: var(--color-text);
  }

  .gate-modal::backdrop {
    background: color-mix(in srgb, var(--color-ink) 60%, transparent);
  }

  .gate-form {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-xl) var(--space-lg) var(--space-lg);
  }

  .close {
    position: absolute;
    top: var(--space-sm);
    right: var(--space-sm);
    font-size: 1.5rem;
    line-height: 1;
    color: var(--color-text-muted);
  }

  .close:hover {
    color: var(--color-text);
  }

  .kicker {
    font-size: var(--fs-label);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-accent);
  }

  .gate-form h2 {
    font-family: var(--font-display);
    font-variation-settings: var(--fv-h3);
    font-size: var(--fs-h3);
  }

  .copy {
    color: var(--color-text-muted);
    font-size: var(--fs-small);
  }

  .copy a {
    color: var(--color-text);
    text-decoration: underline;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
    font-size: var(--fs-small);
  }

  .field input {
    font: inherit;
    padding: var(--space-2xs) var(--space-xs);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-canvas);
    color: var(--color-text);
  }

  .error {
    color: var(--color-accent);
    font-size: var(--fs-small);
  }

  .submit {
    align-self: flex-start;
    padding: var(--space-2xs) var(--space-md);
    border-radius: var(--radius-sm);
    background: var(--color-ink);
    color: var(--color-chalk);
    transition: opacity var(--duration-fast) var(--ease-thread);
  }

  .submit:hover {
    opacity: 0.85;
  }

  .submit:disabled {
    opacity: 0.5;
    cursor: default;
  }
</style>

<script>
  import { resolveUnlockedImageUrl } from "../../lib/clientGate";

  const modal = document.getElementById("gate-modal") as HTMLDialogElement | null;
  const form = document.querySelector<HTMLFormElement>("[data-gate-form]");
  const titleEl = document.querySelector<HTMLElement>("[data-gate-title]");
  const input = document.querySelector<HTMLInputElement>("[data-gate-input]");
  const errorEl = document.querySelector<HTMLElement>("[data-gate-error]");
  const submitBtn = document.querySelector<HTMLButtonElement>("[data-gate-submit]");
  const closeBtn = document.querySelector<HTMLButtonElement>("[data-gate-close]");

  let activeTrigger: HTMLElement | null = null;
  let activeProjectId: string | null = null;

  function showError(message: string) {
    if (!errorEl) return;
    errorEl.textContent = message;
    errorEl.hidden = false;
  }

  function clearError() {
    if (!errorEl) return;
    errorEl.hidden = true;
    errorEl.textContent = "";
  }

  function openGate(trigger: HTMLElement) {
    activeTrigger = trigger;
    activeProjectId = trigger.dataset.projectId ?? null;
    if (titleEl) titleEl.textContent = trigger.dataset.projectTitle ?? "Protected project";
    clearError();
    if (input) input.value = "";
    modal?.showModal();
    input?.focus();
  }

  document.addEventListener("click", (event) => {
    const trigger = (event.target as Element)?.closest<HTMLElement>("[data-gate-trigger]");
    if (trigger) openGate(trigger);
  });

  closeBtn?.addEventListener("click", () => modal?.close());

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!activeProjectId || !input || !submitBtn) return;

    submitBtn.disabled = true;
    clearError();

    try {
      const unlockedUrl = await resolveUnlockedImageUrl(activeProjectId, input.value);

      if (!unlockedUrl) {
        showError("That password doesn't match. Check it and try again.");
        return;
      }

      if (activeTrigger) {
        const img = activeTrigger.querySelector("img");
        if (img) img.src = unlockedUrl;
        activeTrigger.querySelector('[data-role="lock-affordance"]')?.remove();
        const tag = activeTrigger.querySelector('[data-role="protected-tag"]');
        if (tag) tag.textContent = "Unlocked — full preview";
      }

      modal?.close();
    } catch {
      showError("Something went wrong checking that. Try again.");
    } finally {
      submitBtn.disabled = false;
    }
  });
</script>
