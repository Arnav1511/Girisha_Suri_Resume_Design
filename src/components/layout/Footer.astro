---
import { getOrderedSegments } from "../../data/segments";

const segments = getOrderedSegments();
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="row">
    <p class="name">Girisha Suri</p>
    <ul class="segments">
      {segments.map((segment) => (
        <li><a href={`/work/${segment.slug}`}>{segment.name}</a></li>
      ))}
    </ul>
  </div>
  <div class="row meta">
    <a href="mailto:hello@girishasuri.example">hello@girishasuri.example</a>
    <span>&copy; {year}</span>
  </div>
</footer>

<style>
  .site-footer {
    padding: var(--space-2xl) var(--page-gutter) var(--space-xl);
    background: var(--color-bg-inverted);
    color: var(--color-text-inverted);
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .row {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .name {
    font-family: var(--font-display);
    font-variation-settings: var(--fv-h2);
    font-size: var(--fs-h2);
  }

  .segments {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md) var(--space-lg);
    font-size: var(--fs-small);
  }

  .segments a {
    text-decoration: none;
    color: var(--color-text-inverted);
    opacity: 0.8;
  }

  .segments a:hover {
    opacity: 1;
    color: var(--color-thread-dim);
  }

  .meta {
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    opacity: 0.65;
  }

  .meta a {
    color: var(--color-text-inverted);
    text-decoration: none;
  }
</style>
