---
import { getOrderedSegments } from "../../data/segments";

/**
 * Long-form landing scroll inspired by textile editorials.
 *
 * A denim selvage roll opens like a fabric scroll. Studio objects spill from
 * the cloth, beads fall into the next page, then small indigo study cards drift
 * in before the portfolio worlds arrive as textile sample cards.
 */

const fringeCount = 34;
const beadCount = 88;
const segmentWorlds = getOrderedSegments().map((segment, index) => {
  const details: Record<string, { cue: string; material: string; className: string; x: number; y: number; rot: number }> = {
    "vendor-collaboration": {
      cue: "sample room",
      material: "spec sheets, trims, factory notes",
      className: "world-vendor",
      x: 18,
      y: 16,
      rot: -7,
    },
    streetwear: {
      cue: "streetwear",
      material: "denim, hardware, graphic thread",
      className: "world-streetwear",
      x: 40,
      y: 5,
      rot: 5,
    },
    "evening-wear": {
      cue: "evening",
      material: "beads, drape, quiet shine",
      className: "world-evening",
      x: 64,
      y: 18,
      rot: -3,
    },
    contemporary: {
      cue: "contemporary",
      material: "soft structure, wearable line",
      className: "world-contemporary",
      x: 31,
      y: 49,
      rot: 4,
    },
    "indo-western": {
      cue: "ethnic / indo-western",
      material: "zari memory, modern silhouette",
      className: "world-ethnic",
      x: 70,
      y: 50,
      rot: 8,
    },
  };
  const detail = details[segment.id] ?? {
    cue: segment.name,
    material: segment.blurb,
    className: "world-contemporary",
    x: 20 + index * 14,
    y: 22 + (index % 2) * 26,
    rot: -4 + index * 2,
  };

  return {
    ...segment,
    index,
    ...detail,
  };
});
const colorCards = [
  { no: "01", name: "Raw Indigo", tone: "#172b43" },
  { no: "02", name: "Washed Blue", tone: "#547d93" },
  { no: "03", name: "Thread Red", tone: "#8c2a35" },
  { no: "04", name: "Chalk Cotton", tone: "#e7dbc2" },
  { no: "05", name: "Brass Ochre", tone: "#c49a45" },
  { no: "06", name: "Sage Dye", tone: "#84906f" },
];
const kineticPieces = [
  { type: "street-jacket", x: 82, y: 18, rot: 11, scale: 1, dx: -13, dy: 11 },
  { type: "ethnic-border", x: 15, y: 73, rot: -18, scale: 1.1, dx: 10, dy: -10 },
  { type: "evening-beads", x: 76, y: 72, rot: 24, scale: 0.92, dx: -8, dy: -14 },
  { type: "spec-sheet", x: 21, y: 23, rot: -9, scale: 0.94, dx: 13, dy: 8 },
  { type: "thread-card", x: 63, y: 12, rot: -7, scale: 0.88, dx: -10, dy: 13 },
  { type: "denim-pocket", x: 11, y: 43, rot: 9, scale: 0.9, dx: 12, dy: -5 },
  { type: "drape-cloth", x: 89, y: 47, rot: -13, scale: 1, dx: -14, dy: 4 },
  { type: "zari-motif", x: 43, y: 81, rot: 8, scale: 0.84, dx: 4, dy: -13 },
];
---

<section class="indigo-scroll" data-indigo-scroll aria-label="A long illustrated denim scroll story">
  <svg class="texture-defs" aria-hidden="true">
    <filter id="watercolor-wobble">
      <feTurbulence type="fractalNoise" baseFrequency="0.032" numOctaves="2" seed="8" />
      <feDisplacementMap in="SourceGraphic" scale="1.5" />
    </filter>
  </svg>

  <div class="grain" aria-hidden="true"></div>

  <nav class="story-rail" aria-hidden="true">
    <span data-rail-dot></span>
    <span data-rail-dot></span>
    <span data-rail-dot></span>
    <span data-rail-dot></span>
    <span data-rail-dot></span>
  </nav>

  <div class="chapter-copy">
    <article class="chapter is-active" data-chapter>
      <p>01 / cloth</p>
      <h2>A roll of denim opens.</h2>
      <span>Raw selvage, rough edge, studio table. The portfolio begins before the first project appears.</span>
    </article>
    <article class="chapter" data-chapter>
      <p>02 / tools</p>
      <h2>The studio spills out.</h2>
      <span>Thread, needle, frame, tablet, color, tape. The objects fall like a designer's desk waking up.</span>
    </article>
    <article class="chapter" data-chapter>
      <p>03 / beads</p>
      <h2>Details scatter downward.</h2>
      <span>Beads and thread run past the cloth, carrying the eye into the work below.</span>
    </article>
    <article class="chapter" data-chapter>
      <p>04 / work</p>
      <h2>The work surfaces appear.</h2>
      <span>The cloth becomes a table of worlds: streetwear, ethnic hybridity, evening, contemporary, and vendor rooms.</span>
    </article>
    <article class="chapter" data-chapter>
      <p>05 / worlds</p>
      <h2>Choose the surface.</h2>
      <span>Streetwear, ethnic hybridity, evening work, vendor rooms, contemporary rails. Each one opens from the same cloth.</span>
    </article>
  </div>

  <div class="visual-field">
    <svg class="thread-river" viewBox="0 0 1200 900" preserveAspectRatio="none" aria-hidden="true">
      <path data-thread-river d="M-120 220 C160 120, 330 320, 580 210 S980 40, 1320 235" />
      <path data-thread-river d="M-130 650 C145 485, 385 735, 650 570 S1030 440, 1320 630" />
      <path data-thread-river d="M170 980 C260 720, 520 710, 730 505 S1020 300, 1260 120" />
    </svg>

    <div class="kinetic-layer" aria-hidden="true">
      {kineticPieces.map((piece) => (
        <span
          class:list={["kinetic-piece", `kinetic-${piece.type}`]}
          data-kinetic-piece
          style={`--kx:${piece.x}%; --ky:${piece.y}%; --kr:${piece.rot}deg; --ks:${piece.scale}; --dx:${piece.dx}; --dy:${piece.dy};`}
        >
          <span class="kinetic-shadow"></span>
          <span class="kinetic-face"></span>
          <span class="kinetic-mark"></span>
        </span>
      ))}
    </div>

    <div class="scroll-worktable" data-worktable>
      <div class="fabric-roll" data-roll>
        <span class="roll-shadow"></span>
        <span class="roll-face"></span>
        <span class="roll-core left"></span>
        <span class="roll-core right"></span>
        <span class="roll-line top"></span>
        <span class="roll-line bottom"></span>
      </div>

      <div class="fabric-panel" data-fabric-panel>
        <span class="selvage left"></span>
        <span class="selvage right"></span>
        <span class="weft"></span>
        <span class="stitch-line left"></span>
        <span class="stitch-line right"></span>
        <span class="fabric-depth left"></span>
        <span class="fabric-depth right"></span>
        <span class="fabric-bottom-shadow"></span>
        <span class="fringe" aria-hidden="true">
          {Array.from({ length: fringeCount }).map((_, index) => <span style={`--i:${index}`}></span>)}
        </span>
      </div>

      <div class="studio-tool thread-roll" data-fall-tool style="--tx:-24; --ty:10; --rot:-15;">
        <span class="bobbin-cap left"></span>
        <span class="bobbin-cap right"></span>
        <span class="bobbin"></span>
        <span class="thread red"></span>
        <span class="thread cream"></span>
        <span class="thread sage"></span>
        <span class="loose-thread"></span>
      </div>

      <div class="studio-tool hoop" data-fall-tool style="--tx:23; --ty:8; --rot:13;">
        <span class="hoop-ring"></span>
        <span class="hoop-cloth"></span>
        <span class="hoop-screw"></span>
        <svg viewBox="0 0 150 120" aria-hidden="true">
          <path d="M36 70 C56 36, 93 32, 112 62" />
          <path d="M50 80 C70 94, 96 92, 113 77" />
        </svg>
      </div>

      <div class="studio-tool tablet" data-fall-tool style="--tx:-25; --ty:32; --rot:7;">
        <span class="screen"></span>
        <svg viewBox="0 0 180 120" aria-hidden="true">
          <path d="M34 76 C58 38, 101 36, 136 54" />
          <path d="M48 88 C78 72, 110 73, 140 89" />
          <path d="M55 34 L144 34" />
        </svg>
      </div>

      <div class="studio-tool palette" data-fall-tool style="--tx:25; --ty:31; --rot:-11;">
        <span class="palette-body"></span>
        <span class="paint p1"></span>
        <span class="paint p2"></span>
        <span class="paint p3"></span>
        <span class="paint p4"></span>
        <span class="thumb-hole"></span>
      </div>

      <div class="studio-tool ruler" data-fall-tool style="--tx:-17; --ty:48; --rot:-26;">
        {Array.from({ length: 16 }).map((_, index) => <span style={`--tick:${index}`}></span>)}
      </div>

      <div class="studio-tool tape" data-fall-tool style="--tx:18; --ty:48; --rot:19;">
        <svg viewBox="0 0 260 130" aria-hidden="true">
          <path d="M18 82 C70 18, 130 34, 118 78 C104 128, 37 118, 58 70 C83 12, 188 8, 238 48" />
          {Array.from({ length: 13 }).map((_, index) => (
            <line x1={42 + index * 14} y1={58 - (index % 2) * 9} x2={45 + index * 14} y2={73 - (index % 2) * 9} />
          ))}
        </svg>
      </div>

      <div class="studio-tool needle" data-fall-tool style="--tx:0; --ty:57; --rot:42;">
        <svg viewBox="0 0 260 46" aria-hidden="true">
          <path class="needle-body" d="M18 25 C86 16, 160 16, 244 23" />
          <ellipse cx="221" cy="23" rx="13" ry="5" />
          <path class="needle-thread" d="M223 24 C192 58, 134 54, 104 28" />
        </svg>
      </div>

      <div class="studio-tool pencil" data-fall-tool style="--tx:0; --ty:21; --rot:-42;">
        <span class="pencil-body"></span>
        <span class="pencil-tip"></span>
        <span class="pencil-eraser"></span>
      </div>

      <div class="color-card-field" aria-hidden="true">
        {colorCards.map((card, index) => (
          <article class="color-card" data-color-card style={`--card:${index}; --tone:${card.tone};`}>
            <span>{card.no}</span>
            <strong>{card.name}</strong>
          </article>
        ))}
      </div>

      <div class="world-map" data-world-map aria-label="Portfolio sections">
        {segmentWorlds.map((segment) => (
          <a
            class:list={["world-card", segment.className]}
            data-segment-world
            href={`/work/${segment.slug}`}
            style={`--world:${segment.index}; --wx:${segment.x}%; --wy:${segment.y}%; --wr:${segment.rot}deg;`}
          >
            <span class="world-number">{String(segment.order).padStart(2, "0")}</span>
            <span class="world-swatch" aria-hidden="true"></span>
            <span class="world-cue">{segment.cue}</span>
            <strong>{segment.name}</strong>
            <span class="world-material">{segment.material}</span>
          </a>
        ))}
      </div>

      <div class="bead-field" aria-hidden="true">
        {Array.from({ length: beadCount }).map((_, index) => (
          <span
            class="bead"
            data-bead
            style={`--i:${index}; --x:${(index * 37) % 100}; --fall:${70 + ((index * 23) % 62)}; --drift:${-44 + ((index * 29) % 88)}; --size:${0.38 + ((index * 17) % 46) / 100};`}
          ></span>
        ))}
      </div>
    </div>
  </div>

  <p class="handoff" data-handoff>Choose a world from the cloth.</p>
</section>

<style>
  .indigo-scroll {
    position: relative;
    height: 100vh;
    overflow: hidden;
    display: grid;
    place-items: center;
    background:
      linear-gradient(90deg, rgba(247, 245, 240, 0.025) 0 1px, transparent 1px 100%),
      linear-gradient(0deg, rgba(247, 245, 240, 0.025) 0 1px, transparent 1px 100%),
      #24211d;
    background-size: 76px 76px, 76px 76px, auto;
    isolation: isolate;
  }

  .indigo-scroll::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 52% at 50% 47%, rgba(247, 245, 240, 0.11), transparent 66%),
      radial-gradient(ellipse 34% 42% at 20% 68%, rgba(140, 42, 53, 0.16), transparent 70%),
      linear-gradient(to bottom, rgba(30, 27, 23, 0.04), rgba(30, 27, 23, 0.38));
    pointer-events: none;
  }

  .texture-defs {
    position: absolute;
    width: 0;
    height: 0;
  }

  .grain {
    position: absolute;
    inset: -10%;
    opacity: 0.24;
    background:
      linear-gradient(8deg, transparent 0 48%, rgba(185, 147, 90, 0.14) 49% 50%, transparent 51%),
      repeating-linear-gradient(0deg, transparent 0 34px, rgba(185, 147, 90, 0.08) 35px 36px);
    transform: rotate(-2deg);
  }

  .story-rail {
    position: absolute;
    left: var(--page-gutter);
    top: 50%;
    z-index: 8;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    transform: translateY(-50%);
  }

  .story-rail::before {
    content: "";
    position: absolute;
    top: 0.35rem;
    bottom: 0.35rem;
    left: 0.35rem;
    width: 1px;
    background: rgba(247, 245, 240, 0.25);
  }

  .story-rail span {
    position: relative;
    width: 0.7rem;
    height: 0.7rem;
    border: 1px solid rgba(247, 245, 240, 0.45);
    border-radius: 50%;
    background: #24211d;
  }

  .story-rail span.is-active {
    background: var(--color-thread);
    border-color: var(--color-thread);
  }

  .chapter-copy {
    position: absolute;
    left: max(calc(var(--page-gutter) + 2rem), 6vw);
    top: 14vh;
    z-index: 7;
    width: min(26rem, 32vw);
    min-height: 16rem;
    pointer-events: none;
  }

  .chapter {
    position: absolute;
    inset: 0 auto auto 0;
    opacity: 0;
    transform: translateY(1.4rem);
    color: var(--color-chalk);
  }

  .chapter.is-active {
    opacity: 1;
    transform: translateY(0);
  }

  .chapter p {
    margin-bottom: var(--space-xs);
    color: color-mix(in srgb, var(--color-thread) 65%, var(--color-chalk));
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .chapter h2 {
    margin-bottom: var(--space-sm);
    font-family: var(--font-display);
    font-variation-settings: var(--fv-h2);
    font-size: clamp(2rem, 5vw, 4.8rem);
    line-height: 0.98;
  }

  .chapter span {
    display: block;
    max-width: 24rem;
    color: rgba(247, 245, 240, 0.72);
    font-size: var(--fs-body-lg);
  }

  .visual-field {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  .thread-river {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
    opacity: 0.78;
  }

  .thread-river path {
    fill: none;
    stroke: color-mix(in srgb, var(--color-thread) 72%, var(--color-chalk));
    stroke-width: 2;
    stroke-linecap: round;
    stroke-dasharray: 13 17;
  }

  .kinetic-layer {
    position: absolute;
    inset: 0;
    z-index: 4;
    overflow: hidden;
    pointer-events: none;
    perspective: 1200px;
  }

  .kinetic-piece {
    position: absolute;
    left: var(--kx);
    top: var(--ky);
    width: clamp(5.8rem, 10vw, 11rem);
    aspect-ratio: 1;
    opacity: 0;
    --kx-shift: 0vw;
    --ky-shift: 9vh;
    --spin: -8deg;
    transform:
      translate(-50%, -50%)
      translate3d(var(--kx-shift), var(--ky-shift), 0)
      rotate(calc(var(--kr) + var(--spin)))
      scale(var(--ks));
    transform-style: preserve-3d;
    will-change: transform, opacity;
    filter: drop-shadow(0 1.4rem 1.2rem rgba(0, 0, 0, 0.24));
  }

  .kinetic-shadow {
    position: absolute;
    left: 12%;
    right: 12%;
    bottom: -0.45rem;
    height: 1rem;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.32);
    filter: blur(9px);
    transform: translateZ(-36px) rotateX(64deg);
  }

  .kinetic-face,
  .kinetic-mark {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
  }

  .kinetic-face {
    border: 1px solid rgba(247, 245, 240, 0.12);
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.22), transparent 34%),
      rgba(232, 222, 198, 0.9);
    box-shadow:
      inset -0.5rem -0.5rem 0.85rem rgba(0, 0, 0, 0.16),
      inset 0.35rem 0.35rem 0.55rem rgba(255, 255, 255, 0.35);
  }

  .kinetic-street-jacket {
    width: clamp(6rem, 9vw, 9.5rem);
    aspect-ratio: 0.84;
  }

  .kinetic-street-jacket .kinetic-face {
    clip-path: polygon(20% 10%, 38% 0, 50% 14%, 62% 0, 80% 10%, 94% 100%, 62% 100%, 57% 51%, 43% 51%, 38% 100%, 6% 100%);
    background:
      linear-gradient(90deg, transparent 48%, rgba(247, 245, 240, 0.26) 49% 50%, transparent 51%),
      radial-gradient(circle at 36% 27%, rgba(247, 245, 240, 0.22), transparent 15%),
      repeating-linear-gradient(90deg, rgba(247, 245, 240, 0.07) 0 1px, transparent 1px 8px),
      repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.13) 0 1px, transparent 1px 9px),
      #20344a;
  }

  .kinetic-street-jacket .kinetic-mark {
    inset: 24% 22% 26%;
    border-left: 1px dashed rgba(247, 245, 240, 0.45);
    border-right: 1px dashed rgba(247, 245, 240, 0.45);
  }

  .kinetic-ethnic-border {
    width: clamp(10rem, 17vw, 18rem);
    aspect-ratio: 4.6;
  }

  .kinetic-ethnic-border .kinetic-face {
    border-color: rgba(196, 154, 69, 0.55);
    background:
      repeating-linear-gradient(90deg, rgba(196, 154, 69, 0.85) 0 4px, transparent 4px 12px),
      repeating-linear-gradient(45deg, rgba(140, 42, 53, 0.48) 0 3px, transparent 3px 13px),
      linear-gradient(180deg, #263d58, #17263a);
  }

  .kinetic-ethnic-border .kinetic-mark {
    inset: 28% 5%;
    border-top: 2px solid rgba(238, 211, 129, 0.82);
    border-bottom: 2px solid rgba(238, 211, 129, 0.62);
  }

  .kinetic-evening-beads {
    width: clamp(8rem, 13vw, 14rem);
    aspect-ratio: 2.4;
  }

  .kinetic-evening-beads .kinetic-face {
    border: 0;
    background:
      radial-gradient(circle at 8% 52%, #f7f5f0 0 5%, transparent 6%),
      radial-gradient(circle at 22% 48%, #d5a44d 0 5%, transparent 6%),
      radial-gradient(circle at 36% 56%, #b97e84 0 5%, transparent 6%),
      radial-gradient(circle at 50% 46%, #f7f5f0 0 5%, transparent 6%),
      radial-gradient(circle at 64% 54%, #8c2a35 0 5%, transparent 6%),
      radial-gradient(circle at 78% 48%, #d5a44d 0 5%, transparent 6%),
      radial-gradient(circle at 92% 52%, #f7f5f0 0 5%, transparent 6%);
    box-shadow: none;
  }

  .kinetic-evening-beads .kinetic-mark {
    top: 50%;
    height: 1px;
    background: rgba(247, 245, 240, 0.46);
  }

  .kinetic-spec-sheet {
    width: clamp(6.2rem, 9vw, 9rem);
    aspect-ratio: 0.72;
  }

  .kinetic-spec-sheet .kinetic-face {
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.84), transparent 36%),
      repeating-linear-gradient(0deg, transparent 0 15%, rgba(30, 27, 23, 0.12) 15% 16%),
      #eadfc7;
  }

  .kinetic-spec-sheet .kinetic-mark {
    inset: 16% 14%;
    border: 1px solid rgba(30, 27, 23, 0.23);
    background:
      linear-gradient(90deg, transparent 45%, rgba(30, 27, 23, 0.24) 46% 47%, transparent 48%),
      linear-gradient(0deg, transparent 58%, rgba(140, 42, 53, 0.5) 59% 61%, transparent 62%);
  }

  .kinetic-thread-card {
    width: clamp(6rem, 8.5vw, 8.5rem);
    aspect-ratio: 0.78;
  }

  .kinetic-thread-card .kinetic-face {
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.7), transparent 40%),
      #efe4c9;
  }

  .kinetic-thread-card .kinetic-mark {
    inset: 18% 19%;
    background:
      linear-gradient(90deg, #8c2a35 0 22%, transparent 22% 38%, #557f87 38% 60%, transparent 60% 76%, #84906f 76%),
      repeating-linear-gradient(0deg, rgba(30, 27, 23, 0.12) 0 1px, transparent 1px 7px);
    border-radius: 999px;
    box-shadow: inset -0.25rem -0.25rem 0.45rem rgba(0, 0, 0, 0.18);
  }

  .kinetic-denim-pocket {
    width: clamp(5.6rem, 8vw, 8rem);
    aspect-ratio: 0.86;
  }

  .kinetic-denim-pocket .kinetic-face {
    clip-path: polygon(10% 0, 90% 0, 80% 100%, 20% 100%);
    background:
      repeating-linear-gradient(90deg, rgba(247, 245, 240, 0.06) 0 1px, transparent 1px 8px),
      repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.16) 0 1px, transparent 1px 9px),
      #233e5a;
  }

  .kinetic-denim-pocket .kinetic-mark {
    inset: 14%;
    border: 1px dashed rgba(247, 245, 240, 0.5);
    clip-path: polygon(9% 0, 91% 0, 79% 100%, 21% 100%);
  }

  .kinetic-drape-cloth {
    width: clamp(8rem, 13vw, 13rem);
    aspect-ratio: 1.6;
  }

  .kinetic-drape-cloth .kinetic-face {
    clip-path: polygon(4% 20%, 27% 0, 61% 12%, 96% 5%, 84% 82%, 58% 100%, 26% 84%, 0 96%);
    background:
      linear-gradient(105deg, rgba(255, 255, 255, 0.22), transparent 28%, rgba(0, 0, 0, 0.18) 75%),
      repeating-linear-gradient(90deg, rgba(247, 245, 240, 0.08) 0 1px, transparent 1px 12px),
      #6f897f;
  }

  .kinetic-zari-motif {
    width: clamp(5.2rem, 7vw, 7.4rem);
    aspect-ratio: 1;
  }

  .kinetic-zari-motif .kinetic-face {
    border-radius: 50%;
    border-color: rgba(196, 154, 69, 0.52);
    background:
      radial-gradient(circle, transparent 0 22%, rgba(196, 154, 69, 0.92) 23% 28%, transparent 29% 42%, rgba(140, 42, 53, 0.62) 43% 48%, transparent 49%),
      conic-gradient(from 10deg, #c49a45, #eadfc7, #8c2a35, #253d58, #c49a45);
  }

  .kinetic-zari-motif .kinetic-mark {
    inset: 25%;
    border-radius: 50%;
    border: 2px dotted rgba(247, 245, 240, 0.68);
  }

  @media (prefers-reduced-motion: no-preference) {
    .kinetic-face {
      animation: kinetic-breathe 5.8s ease-in-out infinite alternate;
    }

    .kinetic-piece:nth-child(2n) .kinetic-face {
      animation-duration: 7.2s;
