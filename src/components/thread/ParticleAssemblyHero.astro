---
import { getOrderedSegments } from "../../data/segments";

const fringeCount = 48;
const beadCount = 72;

const segmentWorlds = getOrderedSegments().map((segment) => {
  const details: Record<string, { cue: string; className: string }> = {
    "vendor-collaboration": { cue: "vendor / client", className: "menu-vendor" },
    streetwear: { cue: "streetwear", className: "menu-streetwear" },
    "evening-wear": { cue: "evening", className: "menu-evening" },
    contemporary: { cue: "contemporary", className: "menu-contemporary" },
    "indo-western": { cue: "ethnic / indo-western", className: "menu-ethnic" },
  };

  return {
    ...segment,
    ...(details[segment.id] ?? { cue: segment.name, className: "menu-contemporary" }),
  };
});
---

<section class="indigo-scroll" data-indigo-scroll aria-label="A denim fabric scroll that opens into Girisha Suri's portfolio menu">
  <svg class="texture-defs" aria-hidden="true">
    <filter id="watercolor-wobble">
      <feTurbulence type="fractalNoise" baseFrequency="0.026" numOctaves="3" seed="8" />
      <feDisplacementMap in="SourceGraphic" scale="1.2" />
    </filter>
  </svg>

  <div class="grain" aria-hidden="true"></div>
  <div class="grain grain-soft" aria-hidden="true"></div>
  <div class="light-sweep" data-light-sweep aria-hidden="true"></div>

  <nav class="story-rail" aria-hidden="true">
    <span class="rail-progress" data-rail-progress></span>
    <span data-rail-dot></span>
    <span data-rail-dot></span>
    <span data-rail-dot></span>
    <span data-rail-dot></span>
  </nav>

  <div class="chapter-copy">
    <article class="chapter is-active" data-chapter>
      <p>01 / cloth</p>
      <h2>The denim opens.</h2>
      <span>A raw strip of cloth unrolls vertically, with no label, no print, only texture and edge.</span>
    </article>
    <article class="chapter" data-chapter>
      <p>02 / gravity</p>
      <h2>The studio falls out.</h2>
      <span>Thread, tape, needle, hoop, swatch and beads drop straight down, catching weight as they land.</span>
    </article>
    <article class="chapter" data-chapter>
      <p>03 / settle</p>
      <h2>Objects find the floor.</h2>
      <span>Nothing flies to the sides. The pieces bounce, scatter, and sit like they have actually fallen.</span>
    </article>
    <article class="chapter" data-chapter>
      <p>04 / menu</p>
      <h2>Choose where to go.</h2>
      <span>The cloth becomes a quiet end screen for moving into a portfolio world.</span>
    </article>
  </div>

  <div class="visual-field">
    <div class="fabric-scene" data-fabric-scene>
      <div class="fabric-roll" data-roll>
        <span class="roll-shadow"></span>
        <span class="roll-face"></span>
        <span class="roll-core left"></span>
        <span class="roll-core right"></span>
        <span class="roll-highlight top"></span>
        <span class="roll-highlight bottom"></span>
      </div>

      <div class="fabric-panel" data-fabric-panel>
        <span class="fabric-surface"></span>
        <span class="selvage left"></span>
        <span class="selvage right"></span>
        <span class="fabric-light"></span>
        <span class="fabric-shadow"></span>
        <span class="fabric-fold fold-a"></span>
        <span class="fabric-fold fold-b"></span>
        <span class="fabric-fold fold-c"></span>
        <span class="fabric-curl"></span>
        <span class="raw-fringe" aria-hidden="true">
          {Array.from({ length: fringeCount }).map((_, index) => <span style={`--i:${index}`}></span>)}
        </span>
      </div>
    </div>

    <div class="falling-stage" data-falling-stage aria-hidden="true">
      <div class="fall-object obj-spool" data-fall-object style="--land-x:-18; --land-y:55; --land-r:-24;">
        <span class="object-shadow"></span>
        <span class="spool-cap left"></span>
        <span class="spool-cap right"></span>
        <span class="spool-core"></span>
        <span class="spool-thread red"></span>
        <span class="spool-thread cream"></span>
        <span class="spool-thread sage"></span>
        <span class="loose-loop"></span>
      </div>

      <div class="fall-object obj-tape" data-fall-object style="--land-x:9; --land-y:57; --land-r:18;">
        <span class="object-shadow"></span>
        <span class="tape-coil"></span>
        <span class="tape-tail"></span>
        <span class="tape-mark one"></span>
        <span class="tape-mark two"></span>
        <span class="tape-mark three"></span>
      </div>

      <div class="fall-object obj-needle" data-fall-object style="--land-x:-3; --land-y:52; --land-r:35;">
        <span class="object-shadow"></span>
        <svg viewBox="0 0 280 70" aria-hidden="true">
          <path class="needle-metal" d="M22 36 C92 19 177 21 258 31" />
          <ellipse class="needle-eye" cx="235" cy="31" rx="14" ry="5" />
          <path class="needle-thread" d="M237 31 C196 78 119 67 84 38" />
        </svg>
      </div>

      <div class="fall-object obj-hoop" data-fall-object style="--land-x:23; --land-y:50; --land-r:-17;">
        <span class="object-shadow"></span>
        <span class="hoop-ring"></span>
        <span class="hoop-cloth"></span>
        <span class="hoop-screw"></span>
        <svg viewBox="0 0 150 120" aria-hidden="true">
          <path d="M36 70 C56 36, 93 32, 112 62" />
          <path d="M50 80 C70 94, 96 92, 113 77" />
        </svg>
      </div>

      <div class="fall-object obj-swatch" data-fall-object style="--land-x:-27; --land-y:60; --land-r:13;">
        <span class="object-shadow"></span>
        <span class="swatch one"></span>
        <span class="swatch two"></span>
        <span class="swatch three"></span>
        <span class="swatch-stitch"></span>
      </div>

      <div class="fall-object obj-brush" data-fall-object style="--land-x:28; --land-y:61; --land-r:42;">
        <span class="object-shadow"></span>
        <span class="brush-handle"></span>
        <span class="brush-ferrule"></span>
        <span class="brush-tip"></span>
      </div>

      <div class="fall-object obj-thread-knot" data-fall-object style="--land-x:-7; --land-y:60; --land-r:-8;">
        <span class="object-shadow"></span>
        <svg viewBox="0 0 240 150" aria-hidden="true">
          <path d="M20 98 C56 28, 120 34, 112 82 C102 140, 34 132, 58 74 C88 5, 180 18, 224 63" />
          <path d="M40 116 C78 92, 119 106, 148 132" />
          <path d="M136 47 C159 79, 189 80, 220 56" />
        </svg>
      </div>

      <div class="bead-rain">
        {Array.from({ length: beadCount }).map((_, index) => (
          <span
            class="fall-bead"
            data-fall-bead
            style={`--land-x:${-30 + ((index * 17) % 61)}; --land-y:${47 + ((index * 23) % 18)}; --land-r:${-220 + ((index * 41) % 440)}; --size:${0.42 + ((index * 13) % 56) / 100};`}
          ></span>
        ))}
      </div>
    </div>

    <div class="goto-menu" data-goto-menu>
      <p>Go to</p>
      <nav aria-label="Portfolio sections">
        {segmentWorlds.map((segment) => (
          <a class:list={["menu-link", segment.className]} href={`/work/${segment.slug}`}>
            <span>{String(segment.order).padStart(2, "0")}</span>
            <strong>{segment.name}</strong>
            <em>{segment.cue}</em>
          </a>
        ))}
      </nav>
    </div>
  </div>
</section>

<style>
  .indigo-scroll {
    position: relative;
    height: 100vh;
    overflow: hidden;
    display: grid;
    place-items: center;
    background:
      radial-gradient(ellipse 62% 46% at 52% 43%, rgba(247, 245, 240, 0.075), transparent 68%),
      linear-gradient(115deg, rgba(79, 55, 45, 0.16), transparent 42%),
      #211f1c;
    isolation: isolate;
  }

  .indigo-scroll::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 58% 48% at 51% 38%, rgba(247, 245, 240, 0.12), transparent 68%),
      radial-gradient(ellipse 36% 34% at 22% 78%, rgba(140, 42, 53, 0.12), transparent 74%),
      linear-gradient(to bottom, rgba(30, 27, 23, 0.02), rgba(30, 27, 23, 0.42));
    pointer-events: none;
  }

  .texture-defs {
    position: absolute;
    width: 0;
    height: 0;
  }

  .grain {
    position: absolute;
    inset: -10%;
    opacity: 0.18;
    background:
      radial-gradient(circle at 20% 30%, rgba(247, 245, 240, 0.05) 0 1px, transparent 1.4px),
      radial-gradient(circle at 72% 64%, rgba(185, 147, 90, 0.055) 0 1px, transparent 1.6px),
      linear-gradient(105deg, transparent 0 47%, rgba(185, 147, 90, 0.08) 48% 49%, transparent 50%);
    background-size: 17px 19px, 23px 29px, auto;
    transform: rotate(-1.5deg);
    will-change: transform;
  }

  .grain-soft {
    opacity: 0.1;
    background-size: 26px 31px, 35px 27px, auto;
    transform: rotate(2.2deg) scale(1.12);
    mix-blend-mode: soft-light;
  }

  .light-sweep {
    position: absolute;
    inset: -25%;
    z-index: 11;
    background: radial-gradient(ellipse 36% 28% at 28% 32%, rgba(247, 245, 240, 0.17), transparent 62%);
    mix-blend-mode: screen;
    opacity: 0.5;
    pointer-events: none;
    will-change: transform;
  }

  .story-rail {
    position: absolute;
    left: var(--page-gutter);
    top: 50%;
    z-index: 20;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    transform: translateY(-50%);
  }

  .story-rail::before {
    content: "";
    position: absolute;
    top: 0.35rem;
    bottom: 0.35rem;
    left: 0.35rem;
    width: 1px;
    background: repeating-linear-gradient(to bottom, rgba(247, 245, 240, 0.3) 0 3px, transparent 3px 7px);
  }

  .rail-progress {
    position: absolute;
    top: 0.35rem;
    bottom: 0.35rem;
    left: 0.35rem;
    width: 1px;
    background: var(--color-thread);
    transform-origin: top;
    transform: scaleY(0);
    will-change: transform;
  }

  .story-rail span:not(.rail-progress) {
    position: relative;
    width: 0.7rem;
    height: 0.7rem;
    border: 1px solid rgba(247, 245, 240, 0.45);
    border-radius: 50%;
    background: #211f1c;
  }

  .story-rail span.is-active {
    background: var(--color-thread);
    border-color: var(--color-thread);
  }

  .chapter-copy {
    position: absolute;
    left: max(calc(var(--page-gutter) + 2rem), 6vw);
    top: 13vh;
    z-index: 18;
    width: min(25rem, 31vw);
    min-height: 16rem;
    pointer-events: none;
  }

  .chapter {
    position: absolute;
    inset: 0 auto auto 0;
    opacity: 0;
    transform: translateY(1.6rem);
    filter: blur(5px);
    color: var(--color-chalk);
    transition:
      opacity 0.7s var(--ease-thread),
      transform 0.7s var(--ease-thread),
      filter 0.7s var(--ease-thread);
  }

  .chapter.is-active {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  .chapter p {
    margin-bottom: var(--space-xs);
    color: color-mix(in srgb, var(--color-thread) 65%, var(--color-chalk));
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .chapter h2 {
    margin-bottom: var(--space-sm);
    font-family: var(--font-display);
    font-variation-settings: var(--fv-h2);
    font-size: clamp(2rem, 5vw, 4.9rem);
    line-height: 0.98;
  }

  .chapter span {
    display: block;
    max-width: 23rem;
    color: rgba(247, 245, 240, 0.72);
    font-size: var(--fs-body-lg);
  }

  .visual-field {
    position: absolute;
    inset: 0;
    z-index: 2;
    perspective: 1400px;
  }

  .fabric-scene {
    position: absolute;
    inset: 0;
    width: min(72vw, 58rem);
    height: min(91vh, 58rem);
    margin: auto;
    z-index: 4;
    transform-style: preserve-3d;
  }

  .fabric-roll,
  .fabric-panel,
  .fall-object,
  .fall-bead {
    filter: url("#watercolor-wobble") drop-shadow(0 1.2rem 1.8rem rgba(0, 0, 0, 0.24));
  }

  .fabric-roll {
    position: absolute;
    left: 50%;
    top: 4%;
    z-index: 7;
    width: min(61vw, 45rem);
    height: clamp(4.2rem, 7.5vh, 5.8rem);
    transform: translateX(-50%);
  }

  .roll-shadow {
    position: absolute;
    left: 8%;
    right: 8%;
    bottom: -0.65rem;
    height: 1.3rem;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.36);
    filter: blur(12px);
  }

  .roll-face {
    position: absolute;
    inset: 9% 2% 6%;
    overflow: visible;
    border-radius: 2.4rem 2rem 1.25rem 1.6rem / 72% 68% 42% 46%;
    border: 1px solid rgba(247, 245, 240, 0.13);
    background:
      linear-gradient(180deg, rgba(247, 245, 240, 0.18), transparent 18%, rgba(0, 0, 0, 0.25) 80%),
      radial-gradient(ellipse at 38% 18%, rgba(255, 255, 255, 0.24), transparent 34%),
      repeating-linear-gradient(92deg, rgba(247, 245, 240, 0.055) 0 1px, transparent 1px 6px),
      linear-gradient(105deg, #314a67, #172a42 62%, #263e5a);
    box-shadow:
      inset 0 -1.1rem 1.6rem rgba(0, 0, 0, 0.42),
      inset 0 0.8rem 1.1rem rgba(247, 245, 240, 0.09),
      0 1.1rem 1.7rem rgba(0, 0, 0, 0.34);
  }

  .roll-face::before,
  .roll-face::after {
    content: "";
    position: absolute;
    left: 4%;
    right: 4%;
    height: 46%;
    border-radius: 48% 52% 34% 38% / 60% 60% 42% 42%;
    pointer-events: none;
  }

  .roll-face::before {
    top: -22%;
    background:
      linear-gradient(180deg, rgba(247, 245, 240, 0.18), transparent 58%),
      repeating-linear-gradient(92deg, rgba(247, 245, 240, 0.055) 0 1px, transparent 1px 6px),
      #2a405c;
    box-shadow: 0 0.35rem 0.7rem rgba(0, 0, 0, 0.2);
    transform: rotate(-0.8deg);
  }

  .roll-face::after {
    bottom: -26%;
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.28), rgba(247, 245, 240, 0.05)),
      #17283f;
    box-shadow: inset 0 0.45rem 0.7rem rgba(0, 0, 0, 0.28);
    transform: rotate(0.55deg);
  }

  .roll-core {
    position: absolute;
    top: 4%;
    width: clamp(3.3rem, 5.5vw, 5rem);
    height: 88%;
    border-radius: 42% 58% 46% 54% / 48% 44% 56% 52%;
    border: 1px solid rgba(247, 245, 240, 0.24);
    background:
      radial-gradient(ellipse at 42% 38%, rgba(255, 255, 255, 0.46), transparent 12%),
      repeating-radial-gradient(ellipse at 50% 50%, #e3d4b5 0 3px, #cbbf9f 3px 5px, #253750 5px 8px, #142133 8px 11px);
    box-shadow:
      inset 0.4rem 0.2rem 0.7rem rgba(255, 255, 255, 0.22),
      inset -0.55rem -0.45rem 0.8rem rgba(0, 0, 0, 0.32),
      0 0.55rem 0.8rem rgba(0, 0, 0, 0.26);
  }

  .roll-core.left {
    left: -1.3rem;
  }

  .roll-core.right {
    right: -1.3rem;
  }

  .roll-highlight {
    position: absolute;
    left: 12%;
    right: 12%;
    height: 3px;
    border-radius: 999px;
    background: linear-gradient(90deg, transparent, rgba(247, 245, 240, 0.52), rgba(247, 245, 240, 0.3), transparent);
    filter: blur(0.2px);
  }

  .roll-highlight.top {
    top: 25%;
  }

  .roll-highlight.bottom {
    bottom: 23%;
    opacity: 0.68;
  }

  .fabric-panel {
    position: absolute;
    left: 50%;
    top: calc(4% + clamp(4.2rem, 7.5vh, 5.8rem) * 0.7);
    z-index: 5;
    width: min(47vw, 34rem);
    height: min(78vh, 46rem);
    --open: 0.025;
    --cloth-y: 0vh;
    --cloth-tilt: 0deg;
    transform: translateX(-50%) translateY(var(--cloth-y)) scaleY(var(--open)) rotate(var(--cloth-tilt));
    transform-origin: top center;
    border-left: 0;
    border-right: 0;
    border-radius: 1.4rem 1.8rem 3.1rem 2.2rem / 0.35rem 1.1rem 2.4rem 1.6rem;
    background: transparent;
    overflow: visible;
  }

  .fabric-surface {
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: 1.4rem 1.8rem 3.1rem 2.2rem / 0.35rem 1.1rem 2.4rem 1.6rem;
    clip-path: polygon(4% 0, 96% 1%, 98% 18%, 95% 37%, 99% 58%, 94% 82%, 88% 100%, 58% 98%, 35% 100%, 8% 97%, 3% 75%, 6% 52%, 2% 29%);
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.08), transparent 14%, transparent 82%, rgba(0, 0, 0, 0.26)),
      radial-gradient(ellipse at 38% 8%, rgba(247, 245, 240, 0.17), transparent 35%),
      repeating-linear-gradient(93deg, rgba(247, 245, 240, 0.045) 0 0.8px, transparent 0.8px 5px),
      repeating-linear-gradient(87deg, rgba(0, 0, 0, 0.07) 0 0.8px, transparent 0.8px 7px),
      linear-gradient(115deg, #2a4866, #172b41 52%, #213a58);
    box-shadow:
      inset 1.2rem 0 1.6rem rgba(247, 245, 240, 0.045),
      inset -1.45rem 0 2rem rgba(0, 0, 0, 0.24),
      inset 0 -2.5rem 3.6rem rgba(0, 0, 0, 0.24),
      0 2.4rem 4rem rgba(0, 0, 0, 0.36);
  }

  .fabric-panel::before,
  .fabric-panel::after {
    content: "";
    position: absolute;
    top: 0.2rem;
    bottom: 0.8rem;
    width: 2.35rem;
    background:
      repeating-linear-gradient(0deg, rgba(221, 204, 160, 0.78) 0 1px, transparent 1px 9px),
      linear-gradient(90deg, rgba(221, 204, 160, 0.55), rgba(40, 55, 65, 0.1));
    filter: drop-shadow(0.2rem 0 0.25rem rgba(0, 0, 0, 0.26)) blur(0.1px);
    opacity: 0.86;
  }

  .fabric-panel::before {
    left: -1.6rem;
    border-radius: 52% 24% 38% 62% / 10% 28% 72% 88%;
    transform: rotate(-1.2deg);
  }

  .fabric-panel::after {
    right: -1.75rem;
    border-radius: 24% 52% 62% 38% / 28% 10% 88% 72%;
    transform: scaleX(-1) rotate(1.1deg);
  }

  .selvage {
    position: absolute;
    top: 0;
    bottom: -0.2rem;
    z-index: 2;
    width: 0.9rem;
    background:
      linear-gradient(90deg, rgba(220, 196, 127, 0.88), rgba(220, 196, 127, 0.24), transparent),
      repeating-linear-gradient(0deg, transparent 0 9px, rgba(247, 245, 240, 0.24) 9px 10px);
    opacity: 0.95;
  }

  .selvage.left {
    left: 0;
  }

  .selvage.right {
    right: 0;
    transform: scaleX(-1);
  }

  .fabric-light,
  .fabric-shadow {
    position: absolute;
    inset: 0;
    z-index: 1;
    clip-path: polygon(4% 0, 96% 1%, 98% 18%, 95% 37%, 99% 58%, 94% 82%, 88% 100%, 58% 98%, 35% 100%, 8% 97%, 3% 75%, 6% 52%, 2% 29%);
    pointer-events: none;
  }

  .fabric-light {
    background:
      linear-gradient(95deg, rgba(247, 245, 240, 0.12), transparent 24%, rgba(247, 245, 240, 0.06) 55%, transparent),
      radial-gradient(ellipse at 30% 12%, rgba(247, 245, 240, 0.17), transparent 38%),
      radial-gradient(ellipse at 54% 45%, rgba(247, 245, 240, 0.08), transparent 18%);
    mix-blend-mode: screen;
  }

  .fabric-shadow {
    background:
      radial-gradient(ellipse at 80% 86%, rgba(0, 0, 0, 0.24), transparent 42%),
      linear-gradient(100deg, transparent 0 23%, rgba(0, 0, 0, 0.18) 34%, transparent 45% 62%, rgba(0, 0, 0, 0.14) 74%, transparent 86%);
  }

  .fabric-fold {
    position: absolute;
    top: 2%;
    bottom: 2%;
    z-index: 2;
    width: 16%;
    clip-path: polygon(4% 0, 96% 1%, 98% 18%, 95% 37%, 99% 58%, 94% 82%, 88% 100%, 58% 98%, 35% 100%, 8% 97%, 3% 75%, 6% 52%, 2% 29%);
    border-radius: 50%;
    pointer-events: none;
    mix-blend-mode: multiply;
  }

  .fold-a {
    left: 16%;
    background: linear-gradient(90deg, transparent, rgba(0, 0, 0, 0.2), transparent);
    opacity: 0.45;
    transform: skewX(-7deg);
  }

  .fold-b {
    left: 45%;
    width: 22%;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.08), rgba(0, 0, 0, 0.18), transparent);
    opacity: 0.36;
    transform: skewX(8deg);
  }

  .fold-c {
    right: 11%;
    background: linear-gradient(90deg, transparent, rgba(0, 0, 0, 0.24), rgba(255, 255, 255, 0.05));
    opacity: 0.42;
    transform: skewX(-5deg);
  }

  .fabric-curl {
    position: absolute;
    left: 3%;
    right: 7%;
    bottom: -1.05rem;
    height: 2.4rem;
    border-radius: 46% 52% 55% 45% / 62% 58% 38% 34%;
    background:
      linear-gradient(180deg, rgba(247, 245, 240, 0.16), rgba(0, 0, 0, 0.24)),
      repeating-linear-gradient(92deg, rgba(247, 245, 240, 0.045) 0 0.8px, transparent 0.8px 5px),
      #15273d;
    box-shadow:
      inset 0 0.55rem 0.9rem rgba(247, 245, 240, 0.08),
      inset 0 -0.8rem 0.9rem rgba(0, 0, 0, 0.28),
      0 0.75rem 1.1rem rgba(0, 0, 0, 0.28);
    transform: rotate(-1.2deg);
    pointer-events: none;
  }

  .raw-fringe {
    position: absolute;
    left: -1.2rem;
    right: -1.2rem;
    bottom: -4rem;
    height: 4.2rem;
    display: flex;
    justify-content: space-between;
    pointer-events: none;
  }

  .raw-fringe span {
    width: calc(1px + (var(--i) % 4) * 0.35px);
    height: calc(1.15rem + (var(--i) % 7) * 0.38rem);
    background: linear-gradient(to bottom, rgba(224, 205, 150, 0.92), rgba(224, 205, 150, 0.28));
    opacity: calc(0.52 + (var(--i) % 5) * 0.08);
    transform: translateY(calc((var(--i) % 3) * -0.18rem)) rotate(calc(-20deg + (var(--i) % 11) * 4deg));
  }

  .falling-stage {
    position: absolute;
    inset: 0;
    z-index: 9;
    pointer-events: none;
    perspective: 1200px;
  }

