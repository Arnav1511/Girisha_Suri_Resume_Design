---
/**
 * Landing-page fabric scroll.
 *
 * A denim selvage roll opens downward like a textile scroll. Rough
 * watercolor-style tools spill from the cloth as it unfurls, then beads fall
 * off the bottom toward the work sections below.
 */

const beadCount = 54;
const fringeCount = 28;
---

<section class="fabric-story" data-fabric-story aria-label="A denim fabric scroll opening with fashion tools and beads">
  <svg class="texture-defs" aria-hidden="true">
    <filter id="watercolor-wobble">
      <feTurbulence type="fractalNoise" baseFrequency="0.035" numOctaves="2" seed="8" />
      <feDisplacementMap in="SourceGraphic" scale="1.8" />
    </filter>
    <filter id="paper-wobble">
      <feTurbulence type="fractalNoise" baseFrequency="0.018" numOctaves="2" seed="12" />
      <feDisplacementMap in="SourceGraphic" scale="1.2" />
    </filter>
  </svg>

  <div class="table-grain" aria-hidden="true"></div>

  <div class="fabric-scene">
    <div class="fabric-roll" data-scroll-part>
      <span class="roll-shadow"></span>
      <span class="roll-face"></span>
      <span class="roll-core left"></span>
      <span class="roll-core right"></span>
      <span class="roll-selvage top"></span>
      <span class="roll-selvage bottom"></span>
    </div>

    <div class="fabric-panel" data-fabric-panel>
      <span class="selvage left"></span>
      <span class="selvage right"></span>
      <span class="weft-lines"></span>
      <span class="stitch-line stitch-left"></span>
      <span class="stitch-line stitch-right"></span>
      <span class="fabric-label">raw selvedge</span>
      <span class="bottom-fringe" aria-hidden="true">
        {Array.from({ length: fringeCount }).map((_, index) => <span style={`--i:${index}`}></span>)}
      </span>
    </div>

    <div class="tool tool-thread-roll" data-fall-tool style="--tx:-21vw; --ty:11vh; --rot:-16deg;">
      <span class="bobbin"></span>
      <span class="thread-wrap red"></span>
      <span class="thread-wrap cream"></span>
      <span class="thread-wrap sage"></span>
    </div>

    <div class="tool tool-hoop" data-fall-tool style="--tx:20vw; --ty:10vh; --rot:12deg;">
      <span class="hoop-ring"></span>
      <span class="hoop-cloth"></span>
      <span class="hoop-screw"></span>
      <svg viewBox="0 0 150 120" aria-hidden="true">
        <path d="M36 70 C56 36, 93 32, 112 62" />
        <path d="M50 80 C70 94, 96 92, 113 77" />
      </svg>
    </div>

    <div class="tool tool-tablet" data-fall-tool style="--tx:-24vw; --ty:32vh; --rot:8deg;">
      <span class="tablet-screen"></span>
      <svg viewBox="0 0 180 120" aria-hidden="true">
        <path d="M36 74 C55 44, 89 38, 124 52" />
        <path d="M48 86 C78 72, 108 72, 138 88" />
        <path d="M56 34 L142 34" />
      </svg>
    </div>

    <div class="tool tool-palette" data-fall-tool style="--tx:24vw; --ty:32vh; --rot:-10deg;">
      <span class="palette-body"></span>
      <span class="paint p1"></span>
      <span class="paint p2"></span>
      <span class="paint p3"></span>
      <span class="paint p4"></span>
      <span class="thumb-hole"></span>
    </div>

    <div class="tool tool-ruler" data-fall-tool style="--tx:-16vw; --ty:47vh; --rot:-27deg;">
      {Array.from({ length: 16 }).map((_, index) => <span style={`--tick:${index}`}></span>)}
    </div>

    <div class="tool tool-tape" data-fall-tool style="--tx:17vw; --ty:49vh; --rot:20deg;">
      <svg viewBox="0 0 260 130" aria-hidden="true">
        <path d="M18 82 C70 18, 130 34, 118 78 C104 128, 37 118, 58 70 C83 12, 188 8, 238 48" />
        {Array.from({ length: 13 }).map((_, index) => (
          <line x1={42 + index * 14} y1={58 - (index % 2) * 9} x2={45 + index * 14} y2={73 - (index % 2) * 9} />
        ))}
      </svg>
    </div>

    <div class="tool tool-needle" data-fall-tool style="--tx:1vw; --ty:56vh; --rot:42deg;">
      <svg viewBox="0 0 260 46" aria-hidden="true">
        <path class="needle-body" d="M18 25 C86 16, 160 16, 244 23" />
        <ellipse cx="221" cy="23" rx="13" ry="5" />
        <path class="needle-thread" d="M223 24 C192 58, 134 54, 104 28" />
      </svg>
    </div>

    <div class="tool tool-pencil" data-fall-tool style="--tx:0vw; --ty:21vh; --rot:-42deg;">
      <span class="pencil-body"></span>
      <span class="pencil-tip"></span>
      <span class="pencil-eraser"></span>
    </div>

    <div class="bead-field" aria-hidden="true">
      {Array.from({ length: beadCount }).map((_, index) => (
        <span
          class="bead"
          data-bead
          style={`--i:${index}; --x:${(index * 37) % 100}; --fall:${70 + ((index * 23) % 55)}; --drift:${-38 + ((index * 29) % 76)}; --size:${0.42 + ((index * 17) % 42) / 100}; --hue:${index % 7};`}
        ></span>
      ))}
    </div>
  </div>

  <p class="fabric-caption" data-fabric-caption>Open the cloth. Let the studio spill out.</p>
</section>

<style>
  .fabric-story {
    position: relative;
    height: 100vh;
    overflow: hidden;
    display: grid;
    place-items: center;
    background:
      linear-gradient(90deg, rgba(247, 245, 240, 0.025) 0 1px, transparent 1px 100%),
      linear-gradient(0deg, rgba(247, 245, 240, 0.025) 0 1px, transparent 1px 100%),
      #24211d;
    background-size: 76px 76px, 76px 76px, auto;
    isolation: isolate;
  }

  .fabric-story::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 54% 48% at 50% 48%, rgba(247, 245, 240, 0.1), transparent 66%),
      linear-gradient(to bottom, rgba(30, 27, 23, 0.04), rgba(30, 27, 23, 0.34));
    pointer-events: none;
  }

  .texture-defs {
    position: absolute;
    width: 0;
    height: 0;
  }

  .table-grain {
    position: absolute;
    inset: -10%;
    opacity: 0.25;
    background:
      linear-gradient(8deg, transparent 0 48%, rgba(185, 147, 90, 0.14) 49% 50%, transparent 51%),
      repeating-linear-gradient(0deg, transparent 0 34px, rgba(185, 147, 90, 0.09) 35px 36px);
    transform: rotate(-2deg);
  }

  .fabric-scene {
    position: relative;
    z-index: 1;
    width: min(78vw, 64rem);
    height: min(82vh, 48rem);
  }

  .fabric-roll,
  .fabric-panel,
  .tool,
  .bead {
    filter: url("#watercolor-wobble") drop-shadow(0 1.1rem 2rem rgba(0, 0, 0, 0.28));
  }

  .fabric-roll {
    position: absolute;
    left: 50%;
    top: 6%;
    width: min(62vw, 42rem);
    height: clamp(4.5rem, 9vh, 6.4rem);
    transform: translateX(-50%);
    z-index: 6;
  }

  .roll-shadow {
    position: absolute;
    inset: 26% 3% -10%;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.32);
    filter: blur(16px);
  }

  .roll-face {
    position: absolute;
    inset: 0;
    border-radius: 999px;
    border: 1px solid rgba(247, 245, 240, 0.18);
    background:
      radial-gradient(ellipse at 50% 30%, rgba(247, 245, 240, 0.18), transparent 48%),
      repeating-linear-gradient(0deg, rgba(247, 245, 240, 0.07) 0 2px, transparent 2px 7px),
      repeating-linear-gradient(90deg, rgba(30, 27, 23, 0.18) 0 1px, transparent 1px 10px),
      #20344a;
    box-shadow: inset 0 -1.2rem 2rem rgba(0, 0, 0, 0.32), inset 0 1rem 1.6rem rgba(247, 245, 240, 0.08);
  }

  .roll-core {
    position: absolute;
    top: 13%;
    width: clamp(3.6rem, 6vw, 5.6rem);
    height: 74%;
    border-radius: 50%;
    border: 1px solid rgba(247, 245, 240, 0.24);
    background:
      radial-gradient(circle, #d2c5ad 0 25%, #25364a 26% 55%, #172231 56%);
  }

  .roll-core.left {
    left: -1.2rem;
  }

  .roll-core.right {
    right: -1.2rem;
  }

  .roll-selvage {
    position: absolute;
    left: 8%;
    right: 8%;
    height: 5px;
    border-radius: 999px;
    background: rgba(247, 245, 240, 0.36);
  }

  .roll-selvage.top {
    top: 22%;
  }

  .roll-selvage.bottom {
    bottom: 23%;
  }

  .fabric-panel {
    position: absolute;
    left: 50%;
    top: calc(6% + clamp(4.5rem, 9vh, 6.4rem) * 0.58);
    width: min(54vw, 34rem);
    height: min(66vh, 38rem);
    transform: translateX(-50%) scaleY(var(--open, 0.04));
    transform-origin: top center;
    z-index: 3;
    background:
      linear-gradient(90deg, transparent 0 8%, rgba(247, 245, 240, 0.08) 8.5% 9%, transparent 9.5% 91%, rgba(247, 245, 240, 0.08) 91.5% 92%, transparent 92.5%),
      repeating-linear-gradient(0deg, rgba(247, 245, 240, 0.055) 0 1px, transparent 1px 12px),
      repeating-linear-gradient(90deg, rgba(0, 0, 0, 0.14) 0 1px, transparent 1px 9px),
      linear-gradient(115deg, #253d58, #17283b 58%, #223a55);
    border-left: 3px solid #d9c58f;
    border-right: 3px solid #d9c58f;
    box-shadow: inset 0 0 4rem rgba(0, 0, 0, 0.24), 0 2rem 5rem rgba(0, 0, 0, 0.32);
  }

  .fabric-panel::before,
  .fabric-panel::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    width: 1.2rem;
    background: repeating-linear-gradient(0deg, rgba(247, 245, 240, 0.55) 0 1px, transparent 1px 7px);
    opacity: 0.48;
  }

  .fabric-panel::before {
    left: -1.35rem;
  }

  .fabric-panel::after {
    right: -1.35rem;
  }

  .weft-lines {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(95deg, rgba(247, 245, 240, 0.08), transparent 28%, rgba(247, 245, 240, 0.05) 55%, transparent),
      radial-gradient(ellipse at 30% 12%, rgba(247, 245, 240, 0.14), transparent 38%);
    mix-blend-mode: screen;
    opacity: 0.75;
  }

  .stitch-line {
    position: absolute;
    top: 4%;
    bottom: 7%;
    width: 2px;
    background: repeating-linear-gradient(0deg, rgba(247, 245, 240, 0.8) 0 8px, transparent 8px 16px);
    opacity: 0.46;
  }

  .stitch-left {
    left: 12%;
  }

  .stitch-right {
    right: 12%;
  }

  .fabric-label {
    position: absolute;
    left: 50%;
    top: 48%;
    transform: translate(-50%, -50%) rotate(-7deg);
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4vw, 4rem);
    line-height: 1;
    color: rgba(247, 245, 240, 0.15);
    white-space: nowrap;
  }

  .bottom-fringe {
    position: absolute;
    left: -1.3rem;
    right: -1.3rem;
    bottom: -3.2rem;
    height: 3.4rem;
    display: flex;
    justify-content: space-between;
    pointer-events: none;
  }

  .bottom-fringe span {
    width: 1px;
    height: calc(1rem + (var(--i) % 5) * 0.45rem);
    background: rgba(221, 204, 160, 0.78);
    transform: rotate(calc(-16deg + (var(--i) % 9) * 4deg));
  }

  .tool {
    position: absolute;
    left: 50%;
    top: 19%;
    z-index: 5;
    opacity: 0;
    transform: translate(-50%, -50%);
    transform-origin: center center;
    pointer-events: none;
  }

  .tool-thread-roll {
    width: min(20vw, 15rem);
    height: 7rem;
  }

  .bobbin {
    position: absolute;
    left: 6%;
    right: 6%;
    top: 25%;
    height: 50%;
    border-radius: 999px;
    background: #eee1c6;
    border: 1px solid rgba(30, 27, 23, 0.25);
  }

  .thread-wrap {
    position: absolute;
    top: 18%;
    width: 24%;
    height: 64%;
    border-radius: 24% / 50%;
    box-shadow: inset 0 0 1rem rgba(30, 27, 23, 0.28);
  }

  .thread-wrap.red {
    left: 18%;
    background: repeating-linear-gradient(0deg, rgba(247, 245, 240, 0.18) 0 2px, transparent 2px 7px), #8c2a35;
  }

  .thread-wrap.cream {
    left: 39%;
    background: repeating-linear-gradient(0deg, rgba(30, 27, 23, 0.08) 0 2px, transparent 2px 7px), #efe4c9;
  }

  .thread-wrap.sage {
    left: 60%;
    background: repeating-linear-gradient(0deg, rgba(247, 245, 240, 0.18) 0 2px, transparent 2px 7px), #9ba77b;
  }

  .tool-hoop {
    width: min(20vw, 13rem);
    aspect-ratio: 1;
  }

  .hoop-ring,
  .hoop-cloth {
    position: absolute;
    inset: 8%;
    border-radius: 50%;
  }

  .hoop-ring {
    border: 0.8rem solid #b88448;
  }

  .hoop-cloth {
    inset: 18%;
    background: rgba(239, 231, 212, 0.82);
    border: 1px solid rgba(30, 27, 23, 0.18);
  }

  .hoop-screw {
    position: absolute;
    top: 2%;
    left: 43%;
    width: 14%;
    height: 12%;
    border-radius: 5px;
    background: #b88448;
  }

  .tool-hoop svg {
    position: absolute;
    inset: 18%;
  }

  .tool-hoop path,
  .tool-tablet path,
  .tool-tape path,
  .tool-tape line {
    fill: none;
    stroke: rgba(30, 27, 23, 0.62);
    stroke-width: 2.2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .tool-tablet {
    width: min(22vw, 15rem);
    aspect-ratio: 1.36;
    border-radius: 1rem;
    background: #20262f;
    border: 2px solid rgba(247, 245, 240, 0.24);
    padding: 0.6rem;
  }

  .tablet-screen {
    position: absolute;
    inset: 0.65rem;
    border-radius: 0.7rem;
    background: #eadfc7;
  }

  .tool-tablet svg {
    position: absolute;
    inset: 0.9rem;
  }

  .tool-palette {
    width: min(19vw, 12rem);
    aspect-ratio: 1.25;
  }

  .palette-body {
    position: absolute;
    inset: 0;
    border-radius: 58% 42% 54% 46%;
    background: #e8d8b7;
    border: 1px solid rgba(30, 27, 23, 0.18);
  }

  .paint,
  .thumb-hole {
    position: absolute;
    border-radius: 50%;
  }

  .paint {
    width: 18%;
    aspect-ratio: 1;
  }

  .p1 { left: 22%; top: 24%; background: #8c2a35; }
  .p2 { left: 46%; top: 18%; background: #d4a03f; }
  .p3 { left: 62%; top: 42%; background: #557f87; }
  .p4 { left: 33%; top: 55%; background: #70845d; }

  .thumb-hole {
    right: 18%;
    bottom: 17%;
    width: 18%;
    aspect-ratio: 1;
    background: #24211d;
  }

  .tool-ruler {
    width: min(24vw, 18rem);
    height: 2.4rem;
    background: #d9bf73;
    border: 1px solid rgba(30, 27, 23, 0.28);
  }

  .tool-ruler span {
    position: absolute;
    left: calc(var(--tick) * 6.4%);
    top: 0;
    width: 1px;
    height: 55%;
    background: rgba(30, 27, 23, 0.58);
  }

  .tool-ruler span:nth-child(4n) {
    height: 100%;
  }

  .tool-tape {
    width: min(25vw, 17rem);
  }

  .tool-tape path {
    stroke: #d8bd66;
    stroke-width: 12;
  }

  .tool-tape line {
    stroke: rgba(30, 27, 23, 0.55);
    stroke-width: 2;
  }

  .tool-needle {
    width: min(26vw, 18rem);
  }

  .needle-body {
    fill: none;
    stroke: #e7e1d1;
    stroke-width: 3.5;
    stroke-linecap: round;
  }

  .tool-needle ellipse {
    fill: none;
    stroke: #e7e1d1;
    stroke-width: 2.2;
  }

  .needle-thread {
    fill: none;
    stroke: #b97e84;
    stroke-width: 2.3;
    stroke-linecap: round;
  }

  .tool-pencil {
    width: min(18vw, 13rem);
    height: 2.2rem;
  }

  .pencil-body {
    position: absolute;
    left: 12%;
    right: 14%;
    top: 24%;
    height: 52%;
    background: #c7a25a;
    border: 1px solid rgba(30, 27, 23, 0.24);
  }

  .pencil-tip {
    position: absolute;
    right: 3%;
    top: 12%;
    width: 14%;
    height: 76%;
    clip-path: polygon(0 0, 100% 50%, 0 100%);
    background: #eadfc7;
  }

  .pencil-tip::after {
    content: "";
    position: absolute;
    right: 0;
    top: 37%;
    width: 35%;
    height: 26%;
    background: #2c2721;
  }

  .pencil-eraser {
    position: absolute;
    left: 0;
    top: 18%;
    width: 14%;
    height: 64%;
    background: #b97e84;
    border-radius: 4px;
  }

  .bead-field {
    position: absolute;
    inset: 0;
    z-index: 7;
    pointer-events: none;
  }

  .bead {
    position: absolute;
    left: calc(38% + var(--x) * 0.24%);
    top: 48%;
    width: calc(0.48rem + var(--size) * 0.6rem);
    aspect-ratio: 1;
    border-radius: 50%;
    opacity: 0;
    background: var(--bead-color);
    box-shadow: inset -0.12rem -0.15rem 0 rgba(30, 27, 23, 0.28), inset 0.08rem 0.08rem 0 rgba(247, 245, 240, 0.45);
  }

  .bead:nth-child(7n + 1) { --bead-color: #8c2a35; }
  .bead:nth-child(7n + 2) { --bead-color: #e8dcc2; }
  .bead:nth-child(7n + 3) { --bead-color: #d5a44d; }
  .bead:nth-child(7n + 4) { --bead-color: #6f897f; }
  .bead:nth-child(7n + 5) { --bead-color: #557f87; }
  .bead:nth-child(7n + 6) { --bead-color: #b97e84; }
  .bead:nth-child(7n + 7) { --bead-color: #d2c5ad; }

  .fabric-caption {
    position: absolute;
    left: var(--page-gutter);
    right: var(--page-gutter);
    bottom: var(--space-lg);
    z-index: 8;
    color: var(--color-chalk);
    text-align: center;
    font-size: var(--fs-label);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    opacity: 0;
  }

  @media (max-width: 900px) {
    .fabric-scene {
      width: 92vw;
      height: 78vh;
    }

    .fabric-roll {
      width: 76vw;
    }

    .fabric-panel {
      width: 68vw;
      height: 58vh;
    }

    .tool {
      scale: 0.82;
    }

    .tool-tablet,
    .tool-hoop {
      display: none;
    }
  }

  @media (max-width: 620px) {
    .fabric-scene {
      width: 100vw;
      height: 76vh;
    }

    .tool {
      scale: 0.72;
    }

    .tool-palette,
    .tool-pencil {
      display: none;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function setUp() {
    const root = document.querySelector<HTMLElement>("[data-fabric-story]");
    const panel = document.querySelector<HTMLElement>("[data-fabric-panel]");
    const rollParts = Array.from(document.querySelectorAll<HTMLElement>("[data-scroll-part]"));
    const tools = Array.from(document.querySelectorAll<HTMLElement>("[data-fall-tool]"));
    const beads = Array.from(document.querySelectorAll<HTMLElement>("[data-bead]"));
    const caption = document.querySelector<HTMLElement>("[data-fabric-caption]");

    if (!root || !panel) return;

    if (window.__prefersReducedMotion) {
      panel.style.setProperty("--open", "1");
      tools.forEach((tool) => {
        tool.style.opacity = "1";
        tool.style.transform = `translate(calc(-50% + ${tool.style.getPropertyValue("--tx")}), calc(-50% + ${tool.style.getPropertyValue("--ty")})) rotate(${tool.style.getPropertyValue("--rot")})`;
      });
      beads.forEach((bead) => {
        bead.style.opacity = "0.75";
      });
      if (caption) caption.style.opacity = "0.82";
      return;
    }

    gsap.set(panel, { "--open": 0.04 });
    gsap.set(rollParts, { y: -22, rotate: -1 });
    gsap.set(tools, { autoAlpha: 0, x: 0, y: -70, rotate: 0, scale: 0.76 });
    gsap.set(beads, { autoAlpha: 0, x: 0, y: -20, scale: 0.4 });
    if (caption) gsap.set(caption, { autoAlpha: 0, y: 14 });

    const timeline = gsap.timeline({
      scrollTrigger: {
        trigger: root,
        start: "top top",
        end: "+=190%",
        pin: true,
        scrub: true,
      },
    });

    timeline
      .to(panel, { "--open": 1, ease: "none", duration: 0.48 }, 0)
      .to(rollParts, { y: 0, rotate: 0, ease: "none", duration: 0.35 }, 0)
      .to(tools, {
        autoAlpha: 1,
        x: (_index, element) => element.style.getPropertyValue("--tx"),
        y: (_index, element) => element.style.getPropertyValue("--ty"),
        rotate: (_index, element) => element.style.getPropertyValue("--rot"),
        scale: 1,
        ease: "none",
        stagger: 0.035,
        duration: 0.42,
      }, 0.22)
      .to(tools, {
        y: (_index, element) => `calc(${element.style.getPropertyValue("--ty")} + 1.4rem)`,
        rotate: (_index, element) => `calc(${element.style.getPropertyValue("--rot")} + ${_index % 2 === 0 ? 3 : -3}deg)`,
        ease: "none",
        stagger: 0.02,
        duration: 0.28,
      }, 0.6)
      .to(beads, {
        autoAlpha: 1,
        scale: 1,
        x: (_index, element) => `${element.style.getPropertyValue("--drift")}vw`,
        y: (_index, element) => `${element.style.getPropertyValue("--fall")}vh`,
        rotate: (_index) => (_index % 2 === 0 ? 180 : -180),
        ease: "power1.in",
        stagger: {
          amount: 0.28,
          from: "random",
        },
        duration: 0.48,
      }, 0.54)
      .to(beads, {
        autoAlpha: 0.22,
        y: (_index, element) => `calc(${element.style.getPropertyValue("--fall")}vh + 24vh)`,
        ease: "none",
        stagger: {
          amount: 0.12,
          from: "random",
        },
        duration: 0.22,
      }, 0.84);

    if (caption) {
      timeline.to(caption, { autoAlpha: 0.82, y: 0, ease: "none", duration: 0.18 }, 0.72);
    }
  }

  setUp();
</script>
