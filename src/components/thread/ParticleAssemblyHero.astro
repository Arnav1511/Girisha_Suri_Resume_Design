      }, 0.18)
      .to([roll, panel], { y: "-=3vh", autoAlpha: 0.72, ease: "none", duration: 0.08 }, 0.48)
      .to(menu, { autoAlpha: 1, y: 0, ease: "power1.out", duration: 0.1 }, 0.52);
