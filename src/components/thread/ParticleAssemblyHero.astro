  }

  .thread.cream {
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.34), transparent 20%, rgba(0, 0, 0, 0.12) 86%),
      repeating-linear-gradient(0deg, rgba(30, 27, 23, 0.08) 0 2px, transparent 2px 6px),
      #efe4c9;
  }

  .thread.sage {
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.22), transparent 18%, rgba(0, 0, 0, 0.18) 86%),
      repeating-linear-gradient(0deg, rgba(247, 245, 240, 0.18) 0 2px, transparent 2px 6px),
      #9ba77b;
  }

  .loose-thread {
    position: absolute;
    left: 15%;
    right: -4%;
    bottom: 10%;
    height: 1.8rem;
    border-bottom: 2px solid rgba(239, 228, 201, 0.7);
    border-radius: 50%;
