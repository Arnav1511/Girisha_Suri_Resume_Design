  }

  .bobbin-cap.left {
    left: 0;
  }

  .bobbin-cap.right {
    right: 0;
  }

  .thread {
    top: 15%;
    height: 70%;
    border-radius: 30% / 50%;
    box-shadow:
      inset 0.4rem 0.25rem 0.55rem rgba(255, 255, 255, 0.2),
      inset -0.6rem -0.2rem 0.8rem rgba(0, 0, 0, 0.3),
      0 0.25rem 0.35rem rgba(0, 0, 0, 0.16);
  }

  .thread.red {
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.18), transparent 18%, rgba(0, 0, 0, 0.18) 85%),
      repeating-linear-gradient(0deg, rgba(247, 245, 240, 0.2) 0 2px, transparent 2px 6px),
