        "--fall-y": (_index: number, element: Element) => `${num(element as HTMLElement, "--land-y") - 14}vh`,
        "--fall-r": (_index: number, element: Element) => `${num(element as HTMLElement, "--land-r") * 0.38}deg`,
        ease: "power2.in",
        stagger: { amount: 0.07, from: "random" },
