---
import { getOrderedSegments } from "../../data/segments";

/**
 * Long-form landing scroll inspired by textile editorials.
 *
 * A denim selvage roll opens like a fabric scroll. Studio objects spill from
 * the cloth, beads fall into the next page, then small indigo study cards drift
 * in before the portfolio worlds arrive as textile sample cards.
 */

const fringeCount = 34;
const beadCount = 88;
const segmentWorlds = getOrderedSegments().map((segment, index) => {
  const details: Record<string, { cue: string; material: string; className: string; x: number; y: number; rot: number }> = {
    "vendor-collaboration": {
      cue: "sample room",
      material: "spec sheets, trims, factory notes",
      className: "world-vendor",
      x: 18,
      y: 16,
      rot: -7,
    },
    streetwear: {
      cue: "streetwear",
      material: "denim, hardware, graphic thread",
      className: "world-streetwear",
      x: 40,
      y: 5,
      rot: 5,
    },
    "evening-wear": {
      cue: "evening",
      material: "beads, drape, quiet shine",
      className: "world-evening",
      x: 64,
      y: 18,
      rot: -3,
    },
    contemporary: {
      cue: "contemporary",
      material: "soft structure, wearable line",
      className: "world-contemporary",
      x: 31,
      y: 49,
      rot: 4,
    },
    "indo-western": {
      cue: "ethnic / indo-western",
      material: "zari memory, modern silhouette",
      className: "world-ethnic",
      x: 70,
      y: 50,
      rot: 8,
    },
  };
  const detail = details[segment.id] ?? {
    cue: segment.name,
    material: segment.blurb,
    className: "world-contemporary",
    x: 20 + index * 14,
    y: 22 + (index % 2) * 26,
    rot: -4 + index * 2,
  };

  return {
    ...segment,
    index,
    ...detail,
  };
});
const colorCards = [
  { no: "01", name: "Raw Indigo", tone: "#172b43" },
  { no: "02", name: "Washed Blue", tone: "#547d93" },
  { no: "03", name: "Thread Red", tone: "#8c2a35" },
  { no: "04", name: "Chalk Cotton", tone: "#e7dbc2" },
  { no: "05", name: "Brass Ochre", tone: "#c49a45" },
  { no: "06", name: "Sage Dye", tone: "#84906f" },
];
---

<section class="indigo-scroll" data-indigo-scroll aria-label="A long illustrated denim scroll story">
  <svg class="texture-defs" aria-hidden="true">
    <filter id="watercolor-wobble">
      <feTurbulence type="fractalNoise" baseFrequency="0.032" numOctaves="2" seed="8" />
      <feDisplacementMap in="SourceGraphic" scale="1.5" />
    </filter>
  </svg>

  <div class="grain" aria-hidden="true"></div>

  <nav class="story-rail" aria-hidden="true">
    <span data-rail-dot></span>
    <span data-rail-dot></span>
    <span data-rail-dot></span>
    <span data-rail-dot></span>
    <span data-rail-dot></span>
  </nav>

  <div class="chapter-copy">
    <article class="chapter is-active" data-chapter>
      <p>01 / cloth</p>
      <h2>A roll of denim opens.</h2>
      <span>Raw selvage, rough edge, studio table. The portfolio begins before the first project appears.</span>
    </article>
    <article class="chapter" data-chapter>
      <p>02 / tools</p>
      <h2>The studio spills out.</h2>
      <span>Thread, needle, frame, tablet, color, tape. The objects fall like a designer's desk waking up.</span>
    </article>
    <article class="chapter" data-chapter>
      <p>03 / beads</p>
      <h2>Details scatter downward.</h2>
      <span>Beads and thread run past the cloth, carrying the eye into the work below.</span>
    </article>
    <article class="chapter" data-chapter>
      <p>04 / work</p>
      <h2>Then the pieces begin.</h2>
      <span>A quiet handoff from craft world to portfolio grid.</span>
    </article>
    <article class="chapter" data-chapter>
      <p>05 / worlds</p>
      <h2>Choose the surface.</h2>
      <span>Streetwear, ethnic hybridity, evening work, vendor rooms, contemporary rails. Each one opens from the same cloth.</span>
    </article>
  </div>

  <div class="visual-field">
    <svg class="thread-river" viewBox="0 0 1200 900" preserveAspectRatio="none" aria-hidden="true">
      <path data-thread-river d="M-120 220 C160 120, 330 320, 580 210 S980 40, 1320 235" />
      <path data-thread-river d="M-130 650 C145 485, 385 735, 650 570 S1030 440, 1320 630" />
      <path data-thread-river d="M170 980 C260 720, 520 710, 730 505 S1020 300, 1260 120" />
    </svg>

    <div class="scroll-worktable" data-worktable>
      <div class="fabric-roll" data-roll>
        <span class="roll-shadow"></span>
        <span class="roll-face"></span>
        <span class="roll-core left"></span>
        <span class="roll-core right"></span>
        <span class="roll-line top"></span>
        <span class="roll-line bottom"></span>
      </div>

      <div class="fabric-panel" data-fabric-panel>
        <span class="selvage left"></span>
        <span class="selvage right"></span>
        <span class="weft"></span>
        <span class="stitch-line left"></span>
        <span class="stitch-line right"></span>
        <span class="fabric-title">selvedge study</span>
        <span class="fringe" aria-hidden="true">
          {Array.from({ length: fringeCount }).map((_, index) => <span style={`--i:${index}`}></span>)}
        </span>
      </div>

      <div class="studio-tool thread-roll" data-fall-tool style="--tx:-24; --ty:10; --rot:-15;">
        <span class="bobbin"></span>
        <span class="thread red"></span>
        <span class="thread cream"></span>
        <span class="thread sage"></span>
      </div>

      <div class="studio-tool hoop" data-fall-tool style="--tx:23; --ty:8; --rot:13;">
        <span class="hoop-ring"></span>
        <span class="hoop-cloth"></span>
        <span class="hoop-screw"></span>
        <svg viewBox="0 0 150 120" aria-hidden="true">
          <path d="M36 70 C56 36, 93 32, 112 62" />
          <path d="M50 80 C70 94, 96 92, 113 77" />
        </svg>
      </div>

      <div class="studio-tool tablet" data-fall-tool style="--tx:-25; --ty:32; --rot:7;">
        <span class="screen"></span>
        <svg viewBox="0 0 180 120" aria-hidden="true">
          <path d="M34 76 C58 38, 101 36, 136 54" />
          <path d="M48 88 C78 72, 110 73, 140 89" />
          <path d="M55 34 L144 34" />
        </svg>
      </div>

      <div class="studio-tool palette" data-fall-tool style="--tx:25; --ty:31; --rot:-11;">
        <span class="palette-body"></span>
        <span class="paint p1"></span>
        <span class="paint p2"></span>
        <span class="paint p3"></span>
        <span class="paint p4"></span>
        <span class="thumb-hole"></span>
      </div>

      <div class="studio-tool ruler" data-fall-tool style="--tx:-17; --ty:48; --rot:-26;">
        {Array.from({ length: 16 }).map((_, index) => <span style={`--tick:${index}`}></span>)}
      </div>

      <div class="studio-tool tape" data-fall-tool style="--tx:18; --ty:48; --rot:19;">
        <svg viewBox="0 0 260 130" aria-hidden="true">
          <path d="M18 82 C70 18, 130 34, 118 78 C104 128, 37 118, 58 70 C83 12, 188 8, 238 48" />
          {Array.from({ length: 13 }).map((_, index) => (
            <line x1={42 + index * 14} y1={58 - (index % 2) * 9} x2={45 + index * 14} y2={73 - (index % 2) * 9} />
          ))}
        </svg>
      </div>

      <div class="studio-tool needle" data-fall-tool style="--tx:0; --ty:57; --rot:42;">
        <svg viewBox="0 0 260 46" aria-hidden="true">
          <path class="needle-body" d="M18 25 C86 16, 160 16, 244 23" />
          <ellipse cx="221" cy="23" rx="13" ry="5" />
          <path class="needle-thread" d="M223 24 C192 58, 134 54, 104 28" />
        </svg>
      </div>

      <div class="studio-tool pencil" data-fall-tool style="--tx:0; --ty:21; --rot:-42;">
        <span class="pencil-body"></span>
        <span class="pencil-tip"></span>
        <span class="pencil-eraser"></span>
      </div>

      <div class="color-card-field" aria-hidden="true">
        {colorCards.map((card, index) => (
          <article class="color-card" data-color-card style={`--card:${index}; --tone:${card.tone};`}>
            <span>{card.no}</span>
            <strong>{card.name}</strong>
          </article>
        ))}
      </div>

      <div class="world-map" data-world-map aria-label="Portfolio sections">
        {segmentWorlds.map((segment) => (
          <a
            class:list={["world-card", segment.className]}
            data-segment-world
            href={`/work/${segment.slug}`}
            style={`--world:${segment.index}; --wx:${segment.x}%; --wy:${segment.y}%; --wr:${segment.rot}deg;`}
          >
            <span class="world-number">{String(segment.order).padStart(2, "0")}</span>
            <span class="world-swatch" aria-hidden="true"></span>
            <span class="world-cue">{segment.cue}</span>
            <strong>{segment.name}</strong>
            <span class="world-material">{segment.material}</span>
          </a>
        ))}
      </div>

      <div class="bead-field" aria-hidden="true">
        {Array.from({ length: beadCount }).map((_, index) => (
          <span
            class="bead"
            data-bead
            style={`--i:${index}; --x:${(index * 37) % 100}; --fall:${70 + ((index * 23) % 62)}; --drift:${-44 + ((index * 29) % 88)}; --size:${0.38 + ((index * 17) % 46) / 100};`}
          ></span>
        ))}
      </div>
    </div>
  </div>

  <p class="handoff" data-handoff>Choose a world from the cloth.</p>
</section>

<style>
  .indigo-scroll {
    position: relative;
    height: 100vh;
    overflow: hidden;
    display: grid;
    place-items: center;
    background:
      linear-gradient(90deg, rgba(247, 245, 240, 0.025) 0 1px, transparent 1px 100%),
      linear-gradient(0deg, rgba(247, 245, 240, 0.025) 0 1px, transparent 1px 100%),
      #24211d;
    background-size: 76px 76px, 76px 76px, auto;
    isolation: isolate;
  }

  .indigo-scroll::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 52% at 50% 47%, rgba(247, 245, 240, 0.11), transparent 66%),
      radial-gradient(ellipse 34% 42% at 20% 68%, rgba(140, 42, 53, 0.16), transparent 70%),
      linear-gradient(to bottom, rgba(30, 27, 23, 0.04), rgba(30, 27, 23, 0.38));
    pointer-events: none;
  }

  .texture-defs {
    position: absolute;
    width: 0;
    height: 0;
  }

  .grain {
    position: absolute;
    inset: -10%;
    opacity: 0.24;
    background:
      linear-gradient(8deg, transparent 0 48%, rgba(185, 147, 90, 0.14) 49% 50%, transparent 51%),
      repeating-linear-gradient(0deg, transparent 0 34px, rgba(185, 147, 90, 0.08) 35px 36px);
    transform: rotate(-2deg);
  }

  .story-rail {
    position: absolute;
    left: var(--page-gutter);
    top: 50%;
    z-index: 8;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    transform: translateY(-50%);
  }

  .story-rail::before {
    content: "";
    position: absolute;
    top: 0.35rem;
    bottom: 0.35rem;
    left: 0.35rem;
    width: 1px;
    background: rgba(247, 245, 240, 0.25);
  }

  .story-rail span {
    position: relative;
    width: 0.7rem;
    height: 0.7rem;
    border: 1px solid rgba(247, 245, 240, 0.45);
    border-radius: 50%;
    background: #24211d;
  }

  .story-rail span.is-active {
    background: var(--color-thread);
    border-color: var(--color-thread);
  }

  .chapter-copy {
    position: absolute;
    left: max(calc(var(--page-gutter) + 2rem), 6vw);
    top: 14vh;
    z-index: 7;
    width: min(26rem, 32vw);
    min-height: 16rem;
    pointer-events: none;
  }

  .chapter {
    position: absolute;
    inset: 0 auto auto 0;
    opacity: 0;
    transform: translateY(1.4rem);
    color: var(--color-chalk);
  }

  .chapter.is-active {
    opacity: 1;
    transform: translateY(0);
  }

  .chapter p {
    margin-bottom: var(--space-xs);
    color: color-mix(in srgb, var(--color-thread) 65%, var(--color-chalk));
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .chapter h2 {
    margin-bottom: var(--space-sm);
    font-family: var(--font-display);
    font-variation-settings: var(--fv-h2);
    font-size: clamp(2rem, 5vw, 4.8rem);
    line-height: 0.98;
  }

  .chapter span {
    display: block;
    max-width: 24rem;
    color: rgba(247, 245, 240, 0.72);
    font-size: var(--fs-body-lg);
  }

  .visual-field {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  .thread-river {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
    opacity: 0.78;
  }

  .thread-river path {
    fill: none;
    stroke: color-mix(in srgb, var(--color-thread) 72%, var(--color-chalk));
    stroke-width: 2;
    stroke-linecap: round;
    stroke-dasharray: 13 17;
  }

  .scroll-worktable {
    position: absolute;
    inset: 0;
    width: min(86vw, 74rem);
    height: min(86vh, 54rem);
    margin: auto;
  }

  .fabric-roll,
  .fabric-panel,
  .studio-tool,
  .color-card,
  .bead {
    filter: url("#watercolor-wobble") drop-shadow(0 1.1rem 2rem rgba(0, 0, 0, 0.28));
  }

  .fabric-roll {
    position: absolute;
    left: 50%;
    top: 5%;
    z-index: 6;
    width: min(66vw, 46rem);
    height: clamp(4.5rem, 9vh, 6.4rem);
    transform: translateX(-50%);
  }

  .roll-shadow {
    position: absolute;
    inset: 26% 3% -10%;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.34);
    filter: blur(16px);
  }

  .roll-face {
    position: absolute;
    inset: 0;
    border-radius: 999px;
    border: 1px solid rgba(247, 245, 240, 0.18);
    background:
      radial-gradient(ellipse at 50% 30%, rgba(247, 245, 240, 0.18), transparent 48%),
      repeating-linear-gradient(0deg, rgba(247, 245, 240, 0.07) 0 2px, transparent 2px 7px),
      repeating-linear-gradient(90deg, rgba(30, 27, 23, 0.18) 0 1px, transparent 1px 10px),
      #20344a;
    box-shadow: inset 0 -1.2rem 2rem rgba(0, 0, 0, 0.32), inset 0 1rem 1.6rem rgba(247, 245, 240, 0.08);
  }

  .roll-core {
    position: absolute;
    top: 13%;
    width: clamp(3.6rem, 6vw, 5.6rem);
    height: 74%;
    border-radius: 50%;
    border: 1px solid rgba(247, 245, 240, 0.24);
    background: radial-gradient(circle, #d2c5ad 0 25%, #25364a 26% 55%, #172231 56%);
  }

  .roll-core.left {
    left: -1.2rem;
  }

  .roll-core.right {
    right: -1.2rem;
  }

  .roll-line {
    position: absolute;
    left: 8%;
    right: 8%;
    height: 5px;
    border-radius: 999px;
    background: rgba(247, 245, 240, 0.36);
  }

  .roll-line.top {
    top: 22%;
  }

  .roll-line.bottom {
    bottom: 23%;
  }

  .fabric-panel {
    position: absolute;
    left: 50%;
    top: calc(5% + clamp(4.5rem, 9vh, 6.4rem) * 0.58);
    z-index: 3;
    width: min(56vw, 36rem);
    height: min(69vh, 41rem);
    transform: translateX(-50%) scaleY(var(--open, 0.04));
    transform-origin: top center;
    border-left: 3px solid #d9c58f;
    border-right: 3px solid #d9c58f;
    background:
      linear-gradient(90deg, transparent 0 8%, rgba(247, 245, 240, 0.08) 8.5% 9%, transparent 9.5% 91%, rgba(247, 245, 240, 0.08) 91.5% 92%, transparent 92.5%),
      repeating-linear-gradient(0deg, rgba(247, 245, 240, 0.055) 0 1px, transparent 1px 12px),
      repeating-linear-gradient(90deg, rgba(0, 0, 0, 0.14) 0 1px, transparent 1px 9px),
      linear-gradient(115deg, #253d58, #17283b 58%, #223a55);
    box-shadow: inset 0 0 4rem rgba(0, 0, 0, 0.24), 0 2rem 5rem rgba(0, 0, 0, 0.32);
  }

  .fabric-panel::before,
  .fabric-panel::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    width: 1.25rem;
    background: repeating-linear-gradient(0deg, rgba(247, 245, 240, 0.55) 0 1px, transparent 1px 7px);
    opacity: 0.5;
  }

  .fabric-panel::before {
    left: -1.35rem;
  }

  .fabric-panel::after {
    right: -1.35rem;
  }

  .weft {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(95deg, rgba(247, 245, 240, 0.08), transparent 28%, rgba(247, 245, 240, 0.05) 55%, transparent),
      radial-gradient(ellipse at 30% 12%, rgba(247, 245, 240, 0.14), transparent 38%);
    mix-blend-mode: screen;
    opacity: 0.75;
  }

  .stitch-line {
    position: absolute;
    top: 4%;
    bottom: 7%;
    width: 2px;
    background: repeating-linear-gradient(0deg, rgba(247, 245, 240, 0.8) 0 8px, transparent 8px 16px);
    opacity: 0.46;
  }

  .stitch-line.left {
    left: 12%;
  }

  .stitch-line.right {
    right: 12%;
  }

  .fabric-title {
    position: absolute;
    left: 50%;
    top: 48%;
    transform: translate(-50%, -50%) rotate(-7deg);
    color: rgba(247, 245, 240, 0.16);
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4vw, 4rem);
    line-height: 1;
    white-space: nowrap;
  }

  .fringe {
    position: absolute;
    left: -1.4rem;
    right: -1.4rem;
    bottom: -3.2rem;
    height: 3.4rem;
    display: flex;
    justify-content: space-between;
  }

  .fringe span {
    width: 1px;
    height: calc(1rem + (var(--i) % 5) * 0.45rem);
    background: rgba(221, 204, 160, 0.78);
    transform: rotate(calc(-16deg + (var(--i) % 9) * 4deg));
  }

  .studio-tool {
    position: absolute;
    left: 50%;
    top: 17%;
    z-index: 5;
    opacity: 0;
    transform: translate(-50%, -50%);
    transform-origin: center center;
    pointer-events: none;
  }

  .thread-roll {
    width: min(20vw, 15rem);
    height: 7rem;
  }

  .bobbin {
    position: absolute;
    left: 6%;
    right: 6%;
    top: 25%;
    height: 50%;
    border: 1px solid rgba(30, 27, 23, 0.25);
    border-radius: 999px;
    background: #eee1c6;
  }

  .thread {
    position: absolute;
    top: 18%;
    width: 24%;
    height: 64%;
    border-radius: 24% / 50%;
    box-shadow: inset 0 0 1rem rgba(30, 27, 23, 0.28);
  }

  .thread.red {
    left: 18%;
    background: repeating-linear-gradient(0deg, rgba(247, 245, 240, 0.18) 0 2px, transparent 2px 7px), #8c2a35;
  }

  .thread.cream {
    left: 39%;
    background: repeating-linear-gradient(0deg, rgba(30, 27, 23, 0.08) 0 2px, transparent 2px 7px), #efe4c9;
  }

  .thread.sage {
    left: 60%;
    background: repeating-linear-gradient(0deg, rgba(247, 245, 240, 0.18) 0 2px, transparent 2px 7px), #9ba77b;
  }

  .hoop {
    width: min(20vw, 13rem);
    aspect-ratio: 1;
  }

  .hoop-ring,
  .hoop-cloth {
    position: absolute;
    inset: 8%;
    border-radius: 50%;
  }

  .hoop-ring {
    border: 0.8rem solid #b88448;
  }

  .hoop-cloth {
    inset: 18%;
    border: 1px solid rgba(30, 27, 23, 0.18);
    background: rgba(239, 231, 212, 0.82);
  }

  .hoop-screw {
    position: absolute;
    top: 2%;
    left: 43%;
    width: 14%;
    height: 12%;
    border-radius: 5px;
    background: #b88448;
  }

  .hoop svg {
    position: absolute;
    inset: 18%;
  }

  .hoop path,
  .tablet path,
  .tape path,
  .tape line {
    fill: none;
    stroke: rgba(30, 27, 23, 0.62);
    stroke-width: 2.2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .tablet {
    width: min(22vw, 15rem);
    aspect-ratio: 1.36;
    padding: 0.6rem;
    border: 2px solid rgba(247, 245, 240, 0.24);
    border-radius: 1rem;
    background: #20262f;
  }

  .screen {
    position: absolute;
    inset: 0.65rem;
    border-radius: 0.7rem;
    background: #eadfc7;
  }

  .tablet svg {
    position: absolute;
    inset: 0.9rem;
  }

  .palette {
    width: min(19vw, 12rem);
    aspect-ratio: 1.25;
  }

  .palette-body {
    position: absolute;
    inset: 0;
    border: 1px solid rgba(30, 27, 23, 0.18);
    border-radius: 58% 42% 54% 46%;
    background: #e8d8b7;
  }

  .paint,
  .thumb-hole {
    position: absolute;
    border-radius: 50%;
  }

  .paint {
    width: 18%;
    aspect-ratio: 1;
  }

  .p1 { left: 22%; top: 24%; background: #8c2a35; }
  .p2 { left: 46%; top: 18%; background: #d4a03f; }
  .p3 { left: 62%; top: 42%; background: #557f87; }
  .p4 { left: 33%; top: 55%; background: #70845d; }

  .thumb-hole {
    right: 18%;
    bottom: 17%;
    width: 18%;
    aspect-ratio: 1;
    background: #24211d;
  }

  .ruler {
    width: min(24vw, 18rem);
    height: 2.4rem;
    border: 1px solid rgba(30, 27, 23, 0.28);
    background: #d9bf73;
  }

  .ruler span {
    position: absolute;
    left: calc(var(--tick) * 6.4%);
    top: 0;
    width: 1px;
    height: 55%;
    background: rgba(30, 27, 23, 0.58);
  }

  .ruler span:nth-child(4n) {
    height: 100%;
  }

  .tape {
    width: min(25vw, 17rem);
  }

  .tape path {
    stroke: #d8bd66;
    stroke-width: 12;
  }

  .tape line {
    stroke: rgba(30, 27, 23, 0.55);
    stroke-width: 2;
  }

  .needle {
    width: min(26vw, 18rem);
  }

  .needle-body {
    fill: none;
    stroke: #e7e1d1;
    stroke-width: 3.5;
    stroke-linecap: round;
  }

  .needle ellipse {
    fill: none;
    stroke: #e7e1d1;
    stroke-width: 2.2;
  }

  .needle-thread {
    fill: none;
    stroke: #b97e84;
    stroke-width: 2.3;
    stroke-linecap: round;
  }

  .pencil {
    width: min(18vw, 13rem);
    height: 2.2rem;
  }

  .pencil-body {
    position: absolute;
    left: 12%;
    right: 14%;
    top: 24%;
    height: 52%;
    border: 1px solid rgba(30, 27, 23, 0.24);
    background: #c7a25a;
  }

  .pencil-tip {
    position: absolute;
    right: 3%;
    top: 12%;
    width: 14%;
    height: 76%;
    clip-path: polygon(0 0, 100% 50%, 0 100%);
    background: #eadfc7;
  }

  .pencil-tip::after {
    content: "";
    position: absolute;
    right: 0;
    top: 37%;
    width: 35%;
    height: 26%;
    background: #2c2721;
  }

  .pencil-eraser {
    position: absolute;
    left: 0;
    top: 18%;
    width: 14%;
    height: 64%;
    border-radius: 4px;
    background: #b97e84;
  }

  .color-card-field {
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
  }

  .color-card {
    position: absolute;
    left: calc(15% + var(--card) * 12%);
    bottom: 7%;
    width: min(12vw, 8.5rem);
    min-width: 6rem;
    aspect-ratio: 0.72;
    padding: 0.8rem;
    border: 1px solid rgba(30, 27, 23, 0.2);
    background: #eadfc7;
    color: var(--color-ink);
    opacity: 0;
    transform: translateY(4rem) rotate(calc(-10deg + var(--card) * 4deg));
  }

  .color-card::before {
    content: "";
    display: block;
    height: 58%;
    margin-bottom: 0.7rem;
    background: var(--tone);
  }

  .color-card span {
    display: block;
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
  }

  .color-card strong {
    display: block;
    margin-top: 0.2rem;
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1;
  }

  .world-map {
    position: absolute;
    inset: 0;
    z-index: 9;
    pointer-events: none;
  }

  .world-map.is-live {
    pointer-events: auto;
  }

  .world-card {
    position: absolute;
    left: var(--wx);
    top: var(--wy);
    width: min(18vw, 13.5rem);
    min-width: 10.5rem;
    min-height: clamp(12rem, 25vh, 18rem);
    padding: clamp(0.85rem, 1.5vw, 1.2rem);
    overflow: hidden;
    color: var(--color-ink);
    text-decoration: none;
    background:
      linear-gradient(135deg, rgba(247, 245, 240, 0.9), rgba(226, 214, 188, 0.92)),
      #eadfc7;
    border: 1px solid rgba(30, 27, 23, 0.2);
    box-shadow: 0 1.6rem 3rem rgba(0, 0, 0, 0.24);
    opacity: 0;
    transform: translate(-50%, var(--world-y, 4rem)) rotate(var(--wr));
    pointer-events: none;
    filter: url("#watercolor-wobble") drop-shadow(0 1rem 1.6rem rgba(0, 0, 0, 0.18));
  }

  .world-map.is-live .world-card {
    pointer-events: auto;
  }

  .world-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(90deg, rgba(30, 27, 23, 0.045) 0 1px, transparent 1px 10px),
      repeating-linear-gradient(0deg, rgba(30, 27, 23, 0.035) 0 1px, transparent 1px 12px);
    opacity: 0.8;
    pointer-events: none;
  }

  .world-card::after {
    content: "";
    position: absolute;
    left: 1rem;
    right: 1rem;
    top: 0.75rem;
    border-top: 1px dashed rgba(30, 27, 23, 0.28);
  }

  .world-card:hover,
  .world-card:focus-visible {
    transform: translate(-50%, -0.35rem) rotate(0deg);
  }

  .world-number,
  .world-cue,
  .world-material,
  .world-card strong {
    position: relative;
    z-index: 1;
  }

  .world-number {
    display: block;
    margin-bottom: clamp(0.8rem, 2vh, 1.4rem);
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
    color: rgba(30, 27, 23, 0.52);
  }

  .world-swatch {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: clamp(4.8rem, 11vh, 7rem);
    margin-bottom: var(--space-sm);
    border: 1px solid rgba(30, 27, 23, 0.16);
    background: var(--world-texture);
  }

  .world-cue {
    display: block;
    margin-bottom: var(--space-2xs);
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--world-accent, var(--color-thread));
  }

  .world-card strong {
    display: block;
    font-family: var(--font-display);
    font-variation-settings: var(--fv-h3);
    font-size: clamp(1.1rem, 2vw, 1.55rem);
    line-height: 1.05;
  }

  .world-material {
    display: block;
    margin-top: var(--space-sm);
    color: rgba(30, 27, 23, 0.62);
    font-size: var(--fs-small);
    line-height: 1.35;
  }

  .world-vendor {
    --world-accent: #8c6b3d;
    --world-texture:
      linear-gradient(90deg, rgba(30, 27, 23, 0.12) 0 1px, transparent 1px 18px),
      linear-gradient(0deg, rgba(30, 27, 23, 0.12) 0 1px, transparent 1px 18px),
      #ddd0b6;
  }

  .world-streetwear {
    --world-accent: #253d58;
    --world-texture:
      repeating-linear-gradient(90deg, rgba(247, 245, 240, 0.08) 0 1px, transparent 1px 8px),
      repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.12) 0 1px, transparent 1px 10px),
      #20344a;
  }

  .world-evening {
    --world-accent: #8c2a35;
    --world-texture:
      radial-gradient(circle at 20% 30%, #f7f5f0 0 3px, transparent 4px),
      radial-gradient(circle at 70% 60%, #d5a44d 0 3px, transparent 4px),
      radial-gradient(circle at 45% 80%, #b97e84 0 2px, transparent 3px),
      #32272c;
    background-size: auto, auto, auto, auto;
  }

  .world-contemporary {
    --world-accent: #6f897f;
    --world-texture:
      linear-gradient(120deg, rgba(247, 245, 240, 0.55), transparent 42%),
      linear-gradient(45deg, #ccd1c2, #e4dcc9);
  }

  .world-ethnic {
    --world-accent: #c49a45;
    --world-texture:
      repeating-linear-gradient(45deg, rgba(196, 154, 69, 0.45) 0 3px, transparent 3px 10px),
      repeating-linear-gradient(-45deg, rgba(140, 42, 53, 0.35) 0 2px, transparent 2px 12px),
      #253d58;
  }

  .bead-field {
    position: absolute;
    inset: 0;
    z-index: 7;
    pointer-events: none;
  }

  .bead {
    position: absolute;
    left: calc(36% + var(--x) * 0.28%);
    top: 48%;
    width: calc(0.42rem + var(--size) * 0.64rem);
    aspect-ratio: 1;
    border-radius: 50%;
    opacity: 0;
    background: var(--bead-color);
    box-shadow: inset -0.12rem -0.15rem 0 rgba(30, 27, 23, 0.28), inset 0.08rem 0.08rem 0 rgba(247, 245, 240, 0.45);
  }

  .bead:nth-child(7n + 1) { --bead-color: #8c2a35; }
  .bead:nth-child(7n + 2) { --bead-color: #e8dcc2; }
  .bead:nth-child(7n + 3) { --bead-color: #d5a44d; }
  .bead:nth-child(7n + 4) { --bead-color: #6f897f; }
  .bead:nth-child(7n + 5) { --bead-color: #557f87; }
  .bead:nth-child(7n + 6) { --bead-color: #b97e84; }
  .bead:nth-child(7n + 7) { --bead-color: #d2c5ad; }

  .handoff {
    position: absolute;
    left: var(--page-gutter);
    right: var(--page-gutter);
    bottom: var(--space-lg);
    z-index: 8;
    color: var(--color-chalk);
    text-align: center;
    font-size: var(--fs-label);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    opacity: 0;
  }

  @media (max-width: 980px) {
    .chapter-copy {
      left: var(--page-gutter);
      top: 9vh;
      width: min(25rem, 70vw);
    }

    .chapter h2 {
      font-size: clamp(1.8rem, 8vw, 3.4rem);
    }

    .scroll-worktable {
      width: 95vw;
      height: 76vh;
      top: 8vh;
    }

    .fabric-roll {
      width: 78vw;
    }

    .fabric-panel {
      width: 68vw;
      height: 56vh;
    }

    .studio-tool {
      scale: 0.8;
    }

    .tablet,
    .hoop {
      display: none;
    }

    .world-map {
      inset: 23vh 4vw auto;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
    }

    .world-card {
      position: relative;
      left: auto;
      top: auto;
      width: auto;
      min-width: 0;
      min-height: 9.5rem;
      transform: translateY(var(--world-y, 3rem)) rotate(var(--wr));
    }

    .world-card:hover,
    .world-card:focus-visible {
      transform: translateY(-0.25rem) rotate(0deg);
    }

    .world-swatch {
      height: 3.8rem;
    }
  }

  @media (max-width: 640px) {
    .story-rail {
      display: none;
    }

    .chapter-copy {
      top: 7vh;
    }

    .studio-tool {
      scale: 0.68;
    }

    .palette,
    .pencil {
      display: none;
    }

    .world-map {
      inset: 24vh 5vw auto;
      grid-template-columns: 1fr;
      gap: 0.55rem;
    }

    .world-card {
      min-height: 7.2rem;
      padding: 0.7rem;
    }

    .world-number,
    .world-material {
      display: none;
    }

    .world-swatch {
      float: left;
      width: 4.5rem;
      height: 4.5rem;
      margin: 0 0.7rem 0 0;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function num(el: HTMLElement, name: string): number {
    return Number.parseFloat(el.style.getPropertyValue(name)) || 0;
  }

  function setChapter(index: number, chapters: HTMLElement[], dots: HTMLElement[]) {
    chapters.forEach((chapter, chapterIndex) => {
      chapter.classList.toggle("is-active", chapterIndex === index);
    });

    dots.forEach((dot, dotIndex) => {
      dot.classList.toggle("is-active", dotIndex === index);
    });
  }

  function setUp() {
    const root = document.querySelector<HTMLElement>("[data-indigo-scroll]");
    const panel = document.querySelector<HTMLElement>("[data-fabric-panel]");
    const roll = document.querySelector<HTMLElement>("[data-roll]");
    const tools = Array.from(document.querySelectorAll<HTMLElement>("[data-fall-tool]"));
    const beads = Array.from(document.querySelectorAll<HTMLElement>("[data-bead]"));
    const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-color-card]"));
    const worldMap = document.querySelector<HTMLElement>("[data-world-map]");
    const worlds = Array.from(document.querySelectorAll<HTMLElement>("[data-segment-world]"));
    const chapters = Array.from(document.querySelectorAll<HTMLElement>("[data-chapter]"));
    const dots = Array.from(document.querySelectorAll<HTMLElement>("[data-rail-dot]"));
    const handoff = document.querySelector<HTMLElement>("[data-handoff]");
    const rivers = Array.from(document.querySelectorAll<SVGPathElement>("[data-thread-river]"));

    if (!root || !panel || !roll) return;

    rivers.forEach((path) => {
      const length = path.getTotalLength();
      path.style.strokeDasharray = String(length);
      path.style.strokeDashoffset = String(length);
    });

    if (window.__prefersReducedMotion) {
      panel.style.setProperty("--open", "1");
      tools.forEach((tool) => {
        tool.style.opacity = "1";
        tool.style.transform = `translate(calc(-50% + ${num(tool, "--tx")}vw), calc(-50% + ${num(tool, "--ty")}vh)) rotate(${num(tool, "--rot")}deg)`;
      });
      cards.forEach((card) => {
        card.style.opacity = "1";
      });
      worldMap?.classList.add("is-live");
      worlds.forEach((world) => {
        world.style.opacity = "1";
      });
      beads.forEach((bead) => {
        bead.style.opacity = "0.75";
      });
      if (handoff) handoff.style.opacity = "0.82";
      return;
    }

    gsap.set(panel, { "--open": 0.035 });
    gsap.set(roll, { y: -26, rotate: -1.4 });
    gsap.set(tools, { autoAlpha: 0, x: 0, y: -80, rotate: 0, scale: 0.74 });
    gsap.set(beads, { autoAlpha: 0, x: 0, y: -20, scale: 0.35 });
    gsap.set(cards, { autoAlpha: 0, y: 80, rotate: (index) => -10 + index * 4 });
    gsap.set(worlds, { autoAlpha: 0, "--world-y": "4rem" });
    worldMap?.classList.remove("is-live");
    if (handoff) gsap.set(handoff, { autoAlpha: 0, y: 18 });

    ScrollTrigger.create({
      trigger: root,
      start: "top top",
      end: "+=620%",
      pin: true,
      scrub: true,
      onUpdate: (self) => {
        const p = self.progress;
        const chapterIndex = p < 0.18 ? 0 : p < 0.38 ? 1 : p < 0.6 ? 2 : p < 0.78 ? 3 : 4;
        setChapter(chapterIndex, chapters, dots);
        worldMap?.classList.toggle("is-live", p > 0.82);

        rivers.forEach((path, index) => {
          const length = path.getTotalLength();
          const local = Math.min(1, Math.max(0, (p - index * 0.06) / 0.45));
          path.style.strokeDashoffset = String(length * (1 - local));
        });
      },
    });

    const timeline = gsap.timeline({
      scrollTrigger: {
        trigger: root,
        start: "top top",
        end: "+=620%",
        pin: false,
        scrub: true,
      },
    });

    timeline
      .to(panel, { "--open": 1, ease: "none", duration: 0.24 }, 0)
      .to(roll, { y: 0, rotate: 0, ease: "none", duration: 0.2 }, 0)
      .to(tools, {
        autoAlpha: 1,
        x: (_index, element) => `${num(element as HTMLElement, "--tx")}vw`,
        y: (_index, element) => `${num(element as HTMLElement, "--ty")}vh`,
        rotate: (_index, element) => num(element as HTMLElement, "--rot"),
        scale: 1,
        ease: "none",
        stagger: 0.035,
        duration: 0.34,
      }, 0.2)
      .to(tools, {
        y: (_index, element) => `${num(element as HTMLElement, "--ty") + 3}vh`,
        rotate: (_index, element) => num(element as HTMLElement, "--rot") + (_index % 2 === 0 ? 4 : -4),
        ease: "none",
        stagger: 0.018,
        duration: 0.2,
      }, 0.54)
      .to(beads, {
        autoAlpha: 1,
        scale: 1,
        x: (_index, element) => `${num(element as HTMLElement, "--drift")}vw`,
        y: (_index, element) => `${num(element as HTMLElement, "--fall")}vh`,
        rotate: (_index) => (_index % 2 === 0 ? 240 : -240),
        ease: "power1.in",
        stagger: { amount: 0.34, from: "random" },
        duration: 0.45,
      }, 0.48)
      .to(cards, {
        autoAlpha: 1,
        y: 0,
        rotate: (index) => -10 + index * 4,
        ease: "none",
        stagger: 0.04,
        duration: 0.28,
      }, 0.62)
      .to(worlds, {
        autoAlpha: 1,
        "--world-y": "0rem",
        ease: "none",
        stagger: 0.045,
        duration: 0.26,
      }, 0.76)
      .to(beads, {
        autoAlpha: 0.18,
        y: (_index, element) => `${num(element as HTMLElement, "--fall") + 28}vh`,
        ease: "none",
        stagger: { amount: 0.12, from: "random" },
        duration: 0.2,
      }, 0.82)
      .to([roll, panel, ...tools, ...cards], {
        y: "-=5vh",
        autoAlpha: 0.42,
        ease: "none",
        duration: 0.16,
      }, 0.88);

    if (handoff) {
      timeline.to(handoff, { autoAlpha: 0.85, y: 0, ease: "none", duration: 0.14 }, 0.78);
    }
  }

  setUp();
</script>
