    box-shadow:
      inset 0 0 0 0.28rem rgba(0, 0, 0, 0.35),
      inset 0 0.45rem 0.8rem rgba(255, 255, 255, 0.08),
      0 1.2rem 1.7rem rgba(0, 0, 0, 0.32);
  }

  .tablet::after {
    content: "";
    position: absolute;
    inset: 0.75rem 0.9rem auto 0.9rem;
    height: 32%;
    border-radius: 0.8rem;
    background: linear-gradient(110deg, rgba(255, 255, 255, 0.18), transparent 55%);
    pointer-events: none;
  }

  .screen {
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.42), transparent 33%),
      linear-gradient(180deg, #f1e7d0, #d8c8a9);
    box-shadow: inset 0 0 0.6rem rgba(0, 0, 0, 0.13);
  }

  .palette-body {
    border-color: rgba(30, 27, 23, 0.24);
    background:
      radial-gradient(circle at 28% 24%, rgba(255, 255, 255, 0.64), transparent 20%),
      linear-gradient(145deg, #f0dfbd, #c6a56f);
    box-shadow:
      inset -0.7rem -0.8rem 1rem rgba(0, 0, 0, 0.16),
      inset 0.45rem 0.4rem 0.75rem rgba(255, 255, 255, 0.38),
      0 1rem 1.3rem rgba(0, 0, 0, 0.26);
  }

  .paint {
    box-shadow:
      inset -0.2rem -0.24rem 0.25rem rgba(0, 0, 0, 0.26),
      inset 0.12rem 0.12rem 0.16rem rgba(255, 255, 255, 0.44),
      0 0.25rem 0.22rem rgba(0, 0, 0, 0.16);
  }

  .thumb-hole {
    background: radial-gradient(circle at 35% 35%, #3a332b, #16130f 68%);
    box-shadow: inset 0.18rem 0.18rem 0.28rem rgba(0, 0, 0, 0.58), 0 0.12rem 0.16rem rgba(255, 255, 255, 0.22);
  }

  .ruler {
    height: 2.65rem;
    border-color: rgba(30, 27, 23, 0.32);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.26), transparent 28%, rgba(0, 0, 0, 0.18)),
      #d9bf73;
    box-shadow:
      inset 0 -0.55rem 0.45rem rgba(0, 0, 0, 0.16),
      inset 0 0.25rem 0.3rem rgba(255, 255, 255, 0.36),
      0 0.8rem 1rem rgba(0, 0, 0, 0.25);
  }

  .ruler::after {
    content: "";
    position: absolute;
    left: 0.1rem;
    right: 0.1rem;
    bottom: -0.45rem;
    height: 0.45rem;
    background: #9b7732;
    transform: skewX(-36deg);
    opacity: 0.72;
  }

  .tape svg {
    filter: drop-shadow(0 0.55rem 0.45rem rgba(0, 0, 0, 0.32));
  }

  .tape path {
    stroke: #e4c768;
    stroke-linecap: round;
    stroke-width: 14;
  }

  .needle svg {
    filter: drop-shadow(0 0.5rem 0.35rem rgba(0, 0, 0, 0.3));
  }

  .needle-body {
    stroke: #f7f3e8;
    stroke-width: 4.4;
  }

  .needle ellipse {
    stroke: #f7f3e8;
    stroke-width: 2.8;
    filter: drop-shadow(0 0.08rem 0 rgba(0, 0, 0, 0.24));
  }

  .needle-thread {
    stroke: #c78a91;
    stroke-width: 2.8;
  }

  .pencil-body {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.34), transparent 37%, rgba(0, 0, 0, 0.16)),
      #c7a25a;
    box-shadow: inset 0 -0.3rem 0.25rem rgba(0, 0, 0, 0.18), 0 0.55rem 0.45rem rgba(0, 0, 0, 0.24);
  }

  .pencil-tip {
    background: linear-gradient(90deg, #eadfc7, #ad8d54);
    filter: drop-shadow(0 0.42rem 0.32rem rgba(0, 0, 0, 0.22));
  }

  .color-card {
    border-color: rgba(30, 27, 23, 0.24);
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.82), transparent 36%),
      #eadfc7;
    box-shadow:
      inset -0.25rem -0.25rem 0.55rem rgba(0, 0, 0, 0.08),
      0 1.4rem 2.2rem rgba(0, 0, 0, 0.28);
  }

  .color-card::after {
    content: "";
    position: absolute;
    left: 0.8rem;
    right: 0.8rem;
    bottom: -0.45rem;
    height: 0.45rem;
    background: rgba(120, 101, 71, 0.36);
    transform: skewX(-28deg);
  }

  .world-card {
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.86), transparent 32%),
      linear-gradient(135deg, rgba(247, 245, 240, 0.96), rgba(216, 203, 174, 0.96)),
      #eadfc7;
    box-shadow:
      inset -0.4rem -0.4rem 0.7rem rgba(30, 27, 23, 0.09),
      inset 0.35rem 0.3rem 0.5rem rgba(255, 255, 255, 0.42),
      0 1.8rem 3rem rgba(0, 0, 0, 0.3),
      0 0.2rem 0.35rem rgba(0, 0, 0, 0.22);
  }

  .world-card::after {
    border-top-style: solid;
    box-shadow: 0 0.16rem 0 rgba(255, 255, 255, 0.35);
  }

  .world-swatch {
    box-shadow:
      inset -0.35rem -0.45rem 0.6rem rgba(0, 0, 0, 0.18),
      inset 0.25rem 0.25rem 0.4rem rgba(255, 255, 255, 0.28),
      0 0.4rem 0.55rem rgba(0, 0, 0, 0.16);
  }

  .world-swatch::after {
    content: "";
    position: absolute;
    inset: 0.45rem;
    border: 1px dashed rgba(247, 245, 240, 0.38);
    pointer-events: none;
  }

  .bead-field {
    position: absolute;
    inset: 0;
    z-index: 7;
    pointer-events: none;
  }

  .bead {
    position: absolute;
    left: calc(36% + var(--x) * 0.28%);
    top: 48%;
    width: calc(0.42rem + var(--size) * 0.64rem);
    aspect-ratio: 1;
    border-radius: 50%;
    opacity: 0;
    background: var(--bead-color);
    box-shadow: inset -0.12rem -0.15rem 0 rgba(30, 27, 23, 0.28), inset 0.08rem 0.08rem 0 rgba(247, 245, 240, 0.45);
  }

  .bead:nth-child(7n + 1) { --bead-color: #8c2a35; }
  .bead:nth-child(7n + 2) { --bead-color: #e8dcc2; }
  .bead:nth-child(7n + 3) { --bead-color: #d5a44d; }
  .bead:nth-child(7n + 4) { --bead-color: #6f897f; }
  .bead:nth-child(7n + 5) { --bead-color: #557f87; }
  .bead:nth-child(7n + 6) { --bead-color: #b97e84; }
  .bead:nth-child(7n + 7) { --bead-color: #d2c5ad; }

  .handoff {
    position: absolute;
    left: var(--page-gutter);
    right: var(--page-gutter);
    bottom: var(--space-lg);
    z-index: 8;
    color: var(--color-chalk);
    text-align: center;
    font-size: var(--fs-label);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    opacity: 0;
  }

  @media (max-width: 980px) {
    .chapter-copy {
      left: var(--page-gutter);
      top: 9vh;
      width: min(25rem, 70vw);
    }

    .chapter h2 {
      font-size: clamp(1.8rem, 8vw, 3.4rem);
    }

    .scroll-worktable {
      width: 95vw;
      height: 76vh;
      top: 8vh;
    }

    .fabric-roll {
      width: 78vw;
    }

    .fabric-panel {
      width: 68vw;
      height: 56vh;
    }

    .studio-tool {
      scale: 0.8;
    }

    .tablet,
    .hoop {
      display: none;
    }

    .world-map {
      inset: 23vh 4vw auto;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
    }

    .world-card {
      position: relative;
      left: auto;
      top: auto;
      width: auto;
      min-width: 0;
      min-height: 9.5rem;
      transform: translateY(var(--world-y, 3rem)) rotate(var(--wr));
    }

    .world-card:hover,
    .world-card:focus-visible {
      transform: translateY(-0.25rem) rotate(0deg);
    }

    .world-swatch {
      height: 3.8rem;
    }
  }

  @media (max-width: 640px) {
    .story-rail {
      display: none;
    }

    .chapter-copy {
      top: 7vh;
    }

    .studio-tool {
      scale: 0.68;
    }

    .palette,
    .pencil {
      display: none;
    }

    .world-map {
      inset: 24vh 5vw auto;
      grid-template-columns: 1fr;
      gap: 0.55rem;
    }

    .world-card {
      min-height: 7.2rem;
      padding: 0.7rem;
    }

    .world-number,
    .world-material {
      display: none;
    }

    .world-swatch {
      float: left;
      width: 4.5rem;
      height: 4.5rem;
      margin: 0 0.7rem 0 0;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function num(el: HTMLElement, name: string): number {
    return Number.parseFloat(el.style.getPropertyValue(name)) || 0;
  }

  function setChapter(index: number, chapters: HTMLElement[], dots: HTMLElement[]) {
    chapters.forEach((chapter, chapterIndex) => {
      chapter.classList.toggle("is-active", chapterIndex === index);
    });

    dots.forEach((dot, dotIndex) => {
      dot.classList.toggle("is-active", dotIndex === index);
    });
  }

  function setUp() {
    const root = document.querySelector<HTMLElement>("[data-indigo-scroll]");
    const panel = document.querySelector<HTMLElement>("[data-fabric-panel]");
    const roll = document.querySelector<HTMLElement>("[data-roll]");
    const tools = Array.from(document.querySelectorAll<HTMLElement>("[data-fall-tool]"));
    const kinetics = Array.from(document.querySelectorAll<HTMLElement>("[data-kinetic-piece]"));
    const beads = Array.from(document.querySelectorAll<HTMLElement>("[data-bead]"));
    const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-color-card]"));
    const worldMap = document.querySelector<HTMLElement>("[data-world-map]");
    const worlds = Array.from(document.querySelectorAll<HTMLElement>("[data-segment-world]"));
    const chapters = Array.from(document.querySelectorAll<HTMLElement>("[data-chapter]"));
    const dots = Array.from(document.querySelectorAll<HTMLElement>("[data-rail-dot]"));
    const handoff = document.querySelector<HTMLElement>("[data-handoff]");
    const rivers = Array.from(document.querySelectorAll<SVGPathElement>("[data-thread-river]"));

    if (!root || !panel || !roll) return;

    rivers.forEach((path) => {
      const length = path.getTotalLength();
      path.style.strokeDasharray = String(length);
      path.style.strokeDashoffset = String(length);
    });

    if (window.__prefersReducedMotion) {
      panel.style.setProperty("--open", "1");
      tools.forEach((tool) => {
        tool.style.opacity = "1";
        tool.style.transform = `translate(calc(-50% + ${num(tool, "--tx")}vw), calc(-50% + ${num(tool, "--ty")}vh)) rotate(${num(tool, "--rot")}deg)`;
      });
      kinetics.forEach((piece) => {
        piece.style.opacity = "0.78";
        piece.style.setProperty("--kx-shift", "0vw");
        piece.style.setProperty("--ky-shift", "0vh");
        piece.style.setProperty("--spin", "0deg");
      });
      cards.forEach((card) => {
        card.style.opacity = "1";
      });
      worldMap?.classList.add("is-live");
      worlds.forEach((world) => {
        world.style.opacity = "1";
      });
      beads.forEach((bead) => {
        bead.style.opacity = "0.75";
      });
      if (handoff) handoff.style.opacity = "0.82";
      return;
    }

    gsap.set(panel, { "--open": 0.035 });
    gsap.set(roll, { y: -26, rotate: -1.4 });
    gsap.set(tools, { autoAlpha: 0, x: 0, y: -80, rotate: 0, scale: 0.74 });
    gsap.set(kinetics, { autoAlpha: 0, "--kx-shift": "0vw", "--ky-shift": "10vh", "--spin": "-10deg" });
    gsap.set(beads, { autoAlpha: 0, x: 0, y: -20, scale: 0.35 });
    gsap.set(cards, { autoAlpha: 0, y: 80, rotate: (index) => -10 + index * 4 });
    gsap.set(worlds, { autoAlpha: 0, "--world-y": "4rem" });
    worldMap?.classList.remove("is-live");
    if (handoff) gsap.set(handoff, { autoAlpha: 0, y: 18 });

    ScrollTrigger.create({
      trigger: root,
      start: "top top",
      end: "+=620%",
      pin: true,
      scrub: true,
      onUpdate: (self) => {
        const p = self.progress;
        const chapterIndex = p < 0.18 ? 0 : p < 0.38 ? 1 : p < 0.6 ? 2 : p < 0.78 ? 3 : 4;
        setChapter(chapterIndex, chapters, dots);
        worldMap?.classList.toggle("is-live", p > 0.82);

        rivers.forEach((path, index) => {
          const length = path.getTotalLength();
          const local = Math.min(1, Math.max(0, (p - index * 0.06) / 0.45));
          path.style.strokeDashoffset = String(length * (1 - local));
        });
      },
    });

    const timeline = gsap.timeline({
      scrollTrigger: {
        trigger: root,
        start: "top top",
        end: "+=620%",
        pin: false,
        scrub: true,
      },
    });

    timeline
      .to(panel, { "--open": 1, ease: "none", duration: 0.24 }, 0)
      .to(roll, { y: 0, rotate: 0, ease: "none", duration: 0.2 }, 0)
      .to(kinetics, {
        autoAlpha: 0.88,
        "--ky-shift": "0vh",
        "--spin": "0deg",
        ease: "none",
        stagger: { amount: 0.28, from: "random" },
        duration: 0.28,
      }, 0.06)
      .to(tools, {
        autoAlpha: 1,
        x: (_index, element) => `${num(element as HTMLElement, "--tx")}vw`,
        y: (_index, element) => `${num(element as HTMLElement, "--ty")}vh`,
        rotate: (_index, element) => num(element as HTMLElement, "--rot"),
        scale: 1,
        ease: "none",
        stagger: 0.035,
        duration: 0.34,
      }, 0.2)
      .to(kinetics, {
        "--kx-shift": (_index: number, element: Element) => `${num(element as HTMLElement, "--dx")}vw`,
        "--ky-shift": (_index: number, element: Element) => `${num(element as HTMLElement, "--dy")}vh`,
        "--spin": (_index: number) => (_index % 2 === 0 ? "12deg" : "-12deg"),
        autoAlpha: 0.62,
        ease: "none",
        stagger: { amount: 0.18, from: "edges" },
        duration: 0.42,
      }, 0.38)
      .to(tools, {
        y: (_index, element) => `${num(element as HTMLElement, "--ty") + 3}vh`,
        rotate: (_index, element) => num(element as HTMLElement, "--rot") + (_index % 2 === 0 ? 4 : -4),
        ease: "none",
        stagger: 0.018,
        duration: 0.2,
      }, 0.54)
      .to(beads, {
        autoAlpha: 1,
        scale: 1,
        x: (_index, element) => `${num(element as HTMLElement, "--drift")}vw`,
        y: (_index, element) => `${num(element as HTMLElement, "--fall")}vh`,
        rotate: (_index) => (_index % 2 === 0 ? 240 : -240),
        ease: "power1.in",
        stagger: { amount: 0.34, from: "random" },
        duration: 0.45,
      }, 0.48)
      .to(cards, {
        autoAlpha: 1,
        y: 0,
        rotate: (index) => -10 + index * 4,
        ease: "none",
        stagger: 0.04,
        duration: 0.28,
      }, 0.62)
      .to(kinetics, {
        autoAlpha: 0.16,
        "--ky-shift": (_index: number, element: Element) => `${num(element as HTMLElement, "--dy") - 12}vh`,
        ease: "none",
        stagger: { amount: 0.12, from: "random" },
        duration: 0.2,
      }, 0.76)
      .to(worlds, {
        autoAlpha: 1,
        "--world-y": "0rem",
        ease: "none",
        stagger: 0.045,
        duration: 0.26,
      }, 0.76)
      .to(beads, {
        autoAlpha: 0.18,
        y: (_index, element) => `${num(element as HTMLElement, "--fall") + 28}vh`,
        ease: "none",
        stagger: { amount: 0.12, from: "random" },
        duration: 0.2,
      }, 0.82)
      .to([roll, panel, ...tools, ...cards], {
        y: "-=5vh",
        autoAlpha: 0.42,
        ease: "none",
        duration: 0.16,
      }, 0.88);

    if (handoff) {
      timeline.to(handoff, { autoAlpha: 0.85, y: 0, ease: "none", duration: 0.14 }, 0.78);
    }
  }

  setUp();
</script>
