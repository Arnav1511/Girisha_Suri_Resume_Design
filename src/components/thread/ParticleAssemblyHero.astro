    background:
      linear-gradient(95deg, rgba(247, 245, 240, 0.11), transparent 24%, rgba(247, 245, 240, 0.06) 55%, transparent),
      radial-gradient(ellipse at 30% 12%, rgba(247, 245, 240, 0.16), transparent 38%),
      radial-gradient(ellipse at 80% 86%, rgba(0, 0, 0, 0.18), transparent 42%);
  }

  .stitch-line {
    width: 1px;
    background: repeating-linear-gradient(0deg, rgba(247, 245, 240, 0.72) 0 8px, transparent 8px 18px);
    filter: drop-shadow(0.08rem 0.08rem 0 rgba(0, 0, 0, 0.24));
  }

  .fringe {
    left: -1.15rem;
    right: -1.15rem;
    bottom: -3.75rem;
    height: 4rem;
  }

  .fringe span {
    width: calc(1px + (var(--i) % 4) * 0.35px);
    height: calc(1.15rem + (var(--i) % 7) * 0.38rem);
    background: linear-gradient(to bottom, rgba(224, 205, 150, 0.92), rgba(224, 205, 150, 0.28));
    opacity: calc(0.52 + (var(--i) % 5) * 0.08);
    transform: translateY(calc((var(--i) % 3) * -0.18rem)) rotate(calc(-20deg + (var(--i) % 11) * 4deg));
  }

  .studio-tool::before {
    content: "";
