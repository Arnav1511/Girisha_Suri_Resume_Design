</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function num(el: HTMLElement, name: string): number {
    return Number.parseFloat(el.style.getPropertyValue(name)) || 0;
  }

  function setChapter(index: number, chapters: HTMLElement[], dots: HTMLElement[]) {
    chapters.forEach((chapter, chapterIndex) => {
      chapter.classList.toggle("is-active", chapterIndex === index);
    });

    dots.forEach((dot, dotIndex) => {
      dot.classList.toggle("is-active", dotIndex === index);
    });
  }

  function setLanded(el: HTMLElement, yAdjust = 0) {
    el.style.setProperty("--fall-x", `${num(el, "--land-x")}vw`);
    el.style.setProperty("--fall-y", `${num(el, "--land-y") + yAdjust}vh`);
    el.style.setProperty("--fall-r", `${num(el, "--land-r")}deg`);
    el.style.setProperty("--fall-s", "1");
  }

  function setUp() {
    const root = document.querySelector<HTMLElement>("[data-indigo-scroll]");
    const panel = document.querySelector<HTMLElement>("[data-fabric-panel]");
    const roll = document.querySelector<HTMLElement>("[data-roll]");
    const objects = Array.from(document.querySelectorAll<HTMLElement>("[data-fall-object]"));
    const beads = Array.from(document.querySelectorAll<HTMLElement>("[data-fall-bead]"));
    const chapters = Array.from(document.querySelectorAll<HTMLElement>("[data-chapter]"));
    const dots = Array.from(document.querySelectorAll<HTMLElement>("[data-rail-dot]"));
    const menu = document.querySelector<HTMLElement>("[data-goto-menu]");
    const railProgress = document.querySelector<HTMLElement>("[data-rail-progress]");
    const lightSweep = document.querySelector<HTMLElement>("[data-light-sweep]");

    if (!root || !panel || !roll) return;

    if (window.__prefersReducedMotion) {
      panel.style.setProperty("--open", "1");
      objects.forEach((object) => {
        object.style.opacity = "1";
        setLanded(object);
      });
      beads.forEach((bead) => {
        bead.style.opacity = "0.75";
        setLanded(bead);
      });
      if (menu) {
        menu.style.opacity = "1";
        menu.style.transform = "translateY(0)";
        menu.classList.add("is-live");
      }
      if (railProgress) railProgress.style.transform = "scaleY(1)";
      return;
    }

    // Slow, continuous drift independent of scroll position — the backdrop
    // should already feel alive before the visitor moves the wheel.
    if (lightSweep) {
      gsap.to(lightSweep, {
        xPercent: 16,
        yPercent: -10,
        duration: 17,
        ease: "sine.inOut",
        repeat: -1,
        yoyo: true,
      });
    }

    gsap.set(panel, { "--open": 0.025, "--cloth-y": "0vh", "--cloth-tilt": "0deg" });
    gsap.set(roll, { y: -20, rotate: -1.2 });
    gsap.set(objects, { autoAlpha: 0, "--fall-x": "0vw", "--fall-y": "-6vh", "--fall-r": "0deg", "--fall-s": 0.82 });
    gsap.set(beads, { autoAlpha: 0, "--fall-x": "0vw", "--fall-y": "-6vh", "--fall-r": "0deg" });
    if (menu) gsap.set(menu, { autoAlpha: 0, y: 34 });

    ScrollTrigger.create({
      trigger: root,
      start: "top top",
      end: "+=85%",
      pin: true,
      scrub: true,
      onUpdate: (self) => {
        const p = self.progress;
        const chapterIndex = p < 0.16 ? 0 : p < 0.38 ? 1 : p < 0.6 ? 2 : 3;
        setChapter(chapterIndex, chapters, dots);
        menu?.classList.toggle("is-live", p > 0.66);
        if (railProgress) railProgress.style.transform = `scaleY(${p})`;
      },
    });

    const timeline = gsap.timeline({
      scrollTrigger: {
        trigger: root,
        start: "top top",
        end: "+=85%",
        scrub: true,
      },
    });

    if (lightSweep) {
      timeline.to(lightSweep, { x: "8vw", y: "-5vh", ease: "none", duration: 1 }, 0);
    }

    timeline
      .to(panel, { "--open": 1, ease: "power2.out", duration: 0.075 }, 0)
      .to(panel, { "--cloth-tilt": "1.7deg", ease: "power1.out", duration: 0.03 }, 0.006)
      .to(panel, { "--cloth-tilt": "-1.15deg", ease: "power1.inOut", duration: 0.035 }, 0.04)
      .to(panel, { "--cloth-tilt": "0deg", ease: "power1.out", duration: 0.035 }, 0.08)
      .to(roll, { y: 6, rotate: 0, ease: "power2.out", duration: 0.075 }, 0)
      .to(objects, { autoAlpha: 1, ease: "none", stagger: 0.01, duration: 0.02 }, 0.055)
      .to(objects, {
        "--fall-x": (_index: number, element: Element) => `${num(element as HTMLElement, "--land-x") * 0.18}vw`,
        "--fall-y": (_index: number, element: Element) => `${num(element as HTMLElement, "--land-y") - 18}vh`,
        "--fall-r": (_index: number, element: Element) => `${num(element as HTMLElement, "--land-r") * 0.28}deg`,
        "--fall-s": 0.98,
        ease: "power2.in",
        stagger: 0.012,
        duration: 0.07,
      }, 0.075)
      .to(objects, {
        "--fall-x": (_index: number, element: Element) => `${num(element as HTMLElement, "--land-x")}vw`,
        "--fall-y": (_index: number, element: Element) => `${num(element as HTMLElement, "--land-y")}vh`,
        "--fall-r": (_index: number, element: Element) => `${num(element as HTMLElement, "--land-r")}deg`,
        "--fall-s": 1,
        ease: "power3.out",
        stagger: 0.014,
        duration: 0.13,
      }, 0.145)
      .to(objects, {
        "--fall-y": (_index: number, element: Element) => `${num(element as HTMLElement, "--land-y") - 0.6}vh`,
        ease: "power1.out",
        stagger: 0.007,
        duration: 0.04,
      }, 0.3)
      .to(objects, {
        "--fall-y": (_index: number, element: Element) => `${num(element as HTMLElement, "--land-y")}vh`,
        ease: "power1.in",
        stagger: 0.007,
