---
import { getOrderedSegments } from "../../data/segments";

const segmentWorlds = getOrderedSegments().map((segment) => {
  const details: Record<string, { cue: string; className: string }> = {
    "vendor-collaboration": { cue: "vendor / client", className: "menu-vendor" },
    streetwear: { cue: "streetwear", className: "menu-streetwear" },
    "evening-wear": { cue: "evening", className: "menu-evening" },
    contemporary: { cue: "contemporary", className: "menu-contemporary" },
    "indo-western": { cue: "ethnic / indo-western", className: "menu-ethnic" },
  };

  return {
    ...segment,
    ...(details[segment.id] ?? { cue: segment.name, className: "menu-contemporary" }),
  };
});

// Narrative beats laid over the photograph. The first three carry the story
// as the camera tilts from the maker's hands up to their face; the fourth is
// the lead-in to the portfolio menu that resolves the whole section.
const chapters = [
  {
    kicker: "Indigo — 01",
    line: "It begins in the hand.",
    sub: "Raw indigo, a needle, a maker's patience — long before anything earns a label.",
  },
  {
    kicker: "Construction — 02",
    line: "Every stitch is a decision.",
    sub: "Couture-level finishing, set by hand, then held across every piece that follows.",
  },
  {
    kicker: "Range — 03",
    line: "One discipline, many worlds.",
    sub: "From streetwear repetition to evening-wear restraint — the same standard, different rooms.",
  },
  {
    kicker: "Portfolio — 04",
    line: "Choose where to begin.",
    sub: "Five worlds, one maker.",
  },
];
---

<section
  class="indigo-scroll"
  data-indigo-scroll
  aria-label="A cinematic portrait of a maker hand-stitching indigo cloth, opening into Girisha Suri's portfolio menu"
>
  <!-- The photograph: full-bleed, scroll-driven cinematic tilt + scale. -->
  <div class="film" data-film aria-hidden="true">
    <img
      class="film-img"
      data-film-img
      src="/images/landing/karigar-mark.jpg"
      alt=""
      width="620"
      height="795"
      loading="eager"
      decoding="async"
    />
  </div>

  <!-- Colour grade: deepen + cool the shadows toward indigo, lift the existing
       warm key light, then a focus-pulling vignette. mix-blend keeps it
       photographic rather than a flat tint. -->
  <div class="grade grade-shadow" data-grade-shadow aria-hidden="true"></div>
  <div class="grade grade-warm" aria-hidden="true"></div>
  <div class="grade vignette" data-vignette aria-hidden="true"></div>

  <!-- Real film grain (SVG turbulence), boiling on its own loop so the frame
       is alive before the wheel even moves — the single biggest "shot on film"
       cue and what masks any softness from upscaling a portrait plate. -->
  <div class="grain" aria-hidden="true"></div>

  <!-- Cinematic letterboxing that breathes in as the shot opens. -->
  <div class="bar bar-top" data-bar aria-hidden="true"></div>
  <div class="bar bar-bottom" data-bar aria-hidden="true"></div>

  <nav class="story-rail" aria-hidden="true">
    <span class="rail-progress" data-rail-progress></span>
    {chapters.map(() => <span data-rail-dot></span>)}
  </nav>

  <div class="chapter-copy" data-chapter-copy>
    {chapters.map((chapter, index) => (
      <article class:list={["chapter", { "is-active": index === 0 }]} data-chapter>
        <p>{chapter.kicker}</p>
        <h2>{chapter.line}</h2>
        <span>{chapter.sub}</span>
      </article>
    ))}
  </div>

  <div class="goto-menu" data-goto-menu>
    <p>Go to</p>
    <nav aria-label="Portfolio sections">
      {segmentWorlds.map((segment) => (
        <a class:list={["menu-link", segment.className]} href={`/work/${segment.slug}`}>
          <span>{String(segment.order).padStart(2, "0")}</span>
          <strong>{segment.name}</strong>
          <em>{segment.cue}</em>
        </a>
      ))}
    </nav>
  </div>
</section>

<style>
  .indigo-scroll {
    position: relative;
    height: 100vh;
    overflow: hidden;
    background: #0b0e16;
    isolation: isolate;
  }

  /* ---- The photograph ---- */
  .film {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .film-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Start tilted down onto the hands + indigo cloth; the scroll timeline
       pans this up the figure to the maker's face. */
    object-position: 50% calc(var(--py, 50) * 1%);
    transform: scale(var(--s, 1.08));
    transform-origin: 50% 42%;
    filter: contrast(1.04) saturate(1.02);
    will-change: transform, object-position, filter;
  }

  /* ---- Colour grade ---- */
  .grade {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }

  .grade-shadow {
    background:
      linear-gradient(to top, rgba(8, 11, 20, 0.74) 0%, rgba(8, 11, 20, 0.3) 26%, transparent 52%),
      linear-gradient(to bottom, rgba(8, 11, 20, 0.48) 0%, transparent 30%),
      linear-gradient(to left, rgba(8, 11, 20, 0.62) 0%, rgba(8, 11, 20, 0.14) 36%, transparent 64%);
  }

  .grade-shadow::after {
    /* Indigo cast pushed into the shadows only. */
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 82% 82% at 42% 46%, transparent 42%, rgba(14, 24, 48, 0.44));
    mix-blend-mode: multiply;
  }

  .grade-warm {
    /* Strengthen the warm window key already in the frame (upper-right). */
    background: radial-gradient(ellipse 56% 50% at 70% 24%, rgba(255, 212, 150, 0.26), transparent 56%);
    mix-blend-mode: soft-light;
  }

  .vignette {
    background: radial-gradient(ellipse 74% 74% at 48% 40%, transparent 44%, rgba(4, 6, 12, 0.72) 100%);
  }

  /* ---- Film grain ---- */
  .grain {
    position: absolute;
    inset: -50%;
    z-index: 4;
    pointer-events: none;
    opacity: 0.16;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='180' height='180'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.82' numOctaves='2' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 180px 180px;
    animation: grain-boil 0.7s steps(4) infinite;
    will-change: transform;
  }

  @keyframes grain-boil {
    0% { transform: translate(0, 0); }
    25% { transform: translate(-3%, 2%); }
    50% { transform: translate(2%, -3%); }
    75% { transform: translate(-2%, -2%); }
    100% { transform: translate(3%, 2%); }
  }

  /* ---- Letterbox ---- */
  .bar {
    position: absolute;
    left: 0;
    right: 0;
    z-index: 5;
    height: 9vh;
    background: #05070c;
    transform: scaleY(0);
    pointer-events: none;
  }

  .bar-top {
    top: 0;
    transform-origin: top;
    box-shadow: 0 1px 0 rgba(247, 245, 240, 0.05);
  }

  .bar-bottom {
    bottom: 0;
    transform-origin: bottom;
    box-shadow: 0 -1px 0 rgba(247, 245, 240, 0.05);
  }

  /* ---- Progress rail ---- */
  .story-rail {
    position: absolute;
    left: var(--page-gutter);
    top: 50%;
    z-index: 12;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    transform: translateY(-50%);
  }

  .story-rail::before {
    content: "";
    position: absolute;
    top: 0.35rem;
    bottom: 0.35rem;
    left: 0.35rem;
    width: 1px;
    background: repeating-linear-gradient(to bottom, rgba(247, 245, 240, 0.28) 0 3px, transparent 3px 7px);
  }

  .rail-progress {
    position: absolute;
    top: 0.35rem;
    bottom: 0.35rem;
    left: 0.35rem;
    width: 1px;
    background: var(--color-thread);
    transform-origin: top;
    transform: scaleY(0);
    will-change: transform;
  }

  .story-rail span:not(.rail-progress) {
    position: relative;
    width: 0.62rem;
    height: 0.62rem;
    border: 1px solid rgba(247, 245, 240, 0.4);
    border-radius: 50%;
    background: rgba(8, 11, 20, 0.6);
    transition: background var(--duration-base) var(--ease-thread), border-color var(--duration-base) var(--ease-thread);
  }

  .story-rail span.is-active {
    background: var(--color-thread);
    border-color: var(--color-thread);
  }

  /* ---- Editorial chapter copy (right side, clear of the maker's face) ---- */
  .chapter-copy {
    position: absolute;
    right: max(var(--page-gutter), 5vw);
    top: 16vh;
    z-index: 10;
    width: min(31rem, 42vw);
    min-height: 18rem;
    text-align: right;
    pointer-events: none;
  }

  .chapter {
    position: absolute;
    inset: 0 0 auto auto;
    width: 100%;
    opacity: 0;
    transform: translateY(1.6rem);
    filter: blur(6px);
    color: var(--color-chalk);
    transition:
      opacity 0.8s var(--ease-thread),
      transform 0.8s var(--ease-thread),
      filter 0.8s var(--ease-thread);
  }

  .chapter.is-active {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  .chapter p {
    margin-bottom: var(--space-sm);
    color: color-mix(in srgb, var(--color-thread) 58%, var(--color-chalk));
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .chapter h2 {
    margin-bottom: var(--space-sm);
    font-family: var(--font-display);
    font-variation-settings: var(--fv-h2);
    font-size: clamp(2.1rem, 4.8vw, 4.6rem);
    line-height: 1.0;
    text-shadow: 0 0.4rem 2rem rgba(4, 6, 12, 0.55);
  }

  .chapter span {
    display: block;
    margin-left: auto;
    max-width: 24rem;
    color: rgba(247, 245, 240, 0.74);
    font-size: var(--fs-body-lg);
    line-height: 1.5;
    text-shadow: 0 0.2rem 1.4rem rgba(4, 6, 12, 0.6);
  }

  /* ---- Portfolio menu (markup + links preserved verbatim) ---- */
  .goto-menu {
    position: absolute;
    left: var(--page-gutter);
    right: var(--page-gutter);
    bottom: clamp(2rem, 6vh, 4rem);
    z-index: 11;
    opacity: 0;
    transform: translateY(2rem);
    pointer-events: none;
  }

  .goto-menu.is-live {
    pointer-events: auto;
  }

  .goto-menu p {
    margin-bottom: var(--space-sm);
    color: color-mix(in srgb, var(--color-thread) 72%, var(--color-chalk));
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .goto-menu nav {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: clamp(0.55rem, 1.2vw, 0.9rem);
  }

  .menu-link {
    position: relative;
    min-height: 8.5rem;
    padding: clamp(0.8rem, 1.35vw, 1.1rem);
    overflow: hidden;
    color: var(--color-ink);
    text-decoration: none;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.86), transparent 32%),
      linear-gradient(135deg, rgba(247, 245, 240, 0.96), rgba(216, 203, 174, 0.96)),
      #eadfc7;
    border: 1px solid rgba(30, 27, 23, 0.2);
    box-shadow:
      inset -0.4rem -0.4rem 0.7rem rgba(30, 27, 23, 0.09),
      inset 0.35rem 0.3rem 0.5rem rgba(255, 255, 255, 0.42),
      0 1.2rem 2.2rem rgba(0, 0, 0, 0.36);
    transition: transform var(--duration-base) var(--ease-thread), box-shadow var(--duration-base) var(--ease-thread);
  }

  .menu-link::before {
    content: "";
    display: block;
    height: 2rem;
    margin-bottom: var(--space-sm);
    background: var(--menu-texture);
    box-shadow:
      inset -0.25rem -0.25rem 0.45rem rgba(0, 0, 0, 0.16),
      inset 0.18rem 0.18rem 0.32rem rgba(255, 255, 255, 0.26);
  }

  .menu-link:hover,
  .menu-link:focus-visible {
    transform: translateY(-0.4rem);
    box-shadow:
      inset -0.4rem -0.4rem 0.7rem rgba(30, 27, 23, 0.09),
      inset 0.35rem 0.3rem 0.5rem rgba(255, 255, 255, 0.42),
      0 1.8rem 3rem rgba(0, 0, 0, 0.44);
  }

  .menu-link span,
  .menu-link em {
    display: block;
    color: rgba(30, 27, 23, 0.56);
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    font-style: normal;
  }

  .menu-link strong {
    display: block;
    margin: var(--space-2xs) 0;
    font-family: var(--font-display);
    font-variation-settings: var(--fv-h3);
    font-size: clamp(1rem, 1.6vw, 1.35rem);
    line-height: 1.05;
  }

  .menu-vendor {
    --menu-texture:
      linear-gradient(90deg, rgba(30, 27, 23, 0.13) 0 1px, transparent 1px 17px),
      linear-gradient(0deg, rgba(30, 27, 23, 0.12) 0 1px, transparent 1px 17px),
      #ddd0b6;
  }

  .menu-streetwear {
    --menu-texture:
      repeating-linear-gradient(90deg, rgba(247, 245, 240, 0.08) 0 1px, transparent 1px 8px),
      repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.12) 0 1px, transparent 1px 10px),
      #20344a;
  }

  .menu-evening {
    --menu-texture:
      radial-gradient(circle at 20% 35%, #f7f5f0 0 3px, transparent 4px),
      radial-gradient(circle at 70% 60%, #d5a44d 0 3px, transparent 4px),
      #32272c;
  }

  .menu-contemporary {
    --menu-texture:
      linear-gradient(120deg, rgba(247, 245, 240, 0.55), transparent 42%),
      linear-gradient(45deg, #ccd1c2, #e4dcc9);
  }

  .menu-ethnic {
    --menu-texture:
      repeating-linear-gradient(45deg, rgba(196, 154, 69, 0.45) 0 3px, transparent 3px 10px),
      repeating-linear-gradient(-45deg, rgba(140, 42, 53, 0.35) 0 2px, transparent 2px 12px),
      #253d58;
  }

  @media (max-width: 980px) {
    .chapter-copy {
      right: var(--page-gutter);
      left: var(--page-gutter);
      top: 11vh;
      width: auto;
    }

    .chapter h2 {
      font-size: clamp(1.9rem, 8vw, 3.4rem);
    }

    .goto-menu nav {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .menu-link {
      min-height: 7.2rem;
    }
  }

  @media (max-width: 640px) {
    .story-rail {
      display: none;
    }

    .bar {
      height: 6vh;
    }

    .chapter-copy {
      top: 8vh;
    }

    .chapter span {
      max-width: none;
    }

    .goto-menu {
      bottom: 1.2rem;
    }

    .goto-menu nav {
      grid-template-columns: 1fr;
      gap: 0.45rem;
    }

    .menu-link {
      min-height: 4.6rem;
      padding: 0.65rem;
    }

    .menu-link::before {
      float: left;
      width: 4rem;
      height: 3rem;
      margin: 0 0.7rem 0 0;
    }

    .menu-link em {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .grain {
      animation: none;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function setChapter(index: number, chapters: HTMLElement[], dots: HTMLElement[]) {
    chapters.forEach((chapter, chapterIndex) => {
      chapter.classList.toggle("is-active", chapterIndex === index);
    });
    dots.forEach((dot, dotIndex) => {
      dot.classList.toggle("is-active", dotIndex === index);
    });
  }

  function setUp() {
    const root = document.querySelector<HTMLElement>("[data-indigo-scroll]");
    const film = document.querySelector<HTMLElement>("[data-film]");
    const img = document.querySelector<HTMLElement>("[data-film-img]");
    const vignette = document.querySelector<HTMLElement>("[data-vignette]");
    const bars = Array.from(document.querySelectorAll<HTMLElement>("[data-bar]"));
    const chapterCopy = document.querySelector<HTMLElement>("[data-chapter-copy]");
    const chapters = Array.from(document.querySelectorAll<HTMLElement>("[data-chapter]"));
    const dots = Array.from(document.querySelectorAll<HTMLElement>("[data-rail-dot]"));
    const menu = document.querySelector<HTMLElement>("[data-goto-menu]");
    const railProgress = document.querySelector<HTMLElement>("[data-rail-progress]");

    if (!root || !film || !img) return;

    // Resolved frame for reduced motion / no-scrub: a settled, graded still
    // with the menu available — never a half-open shutter.
    if (window.__prefersReducedMotion) {
      gsap.set(img, { "--py": 38, "--s": 1.04 });
      gsap.set(bars, { scaleY: 1 });
      if (menu) {
        gsap.set(menu, { autoAlpha: 1, y: 0 });
        menu.classList.add("is-live");
      }
      if (railProgress) railProgress.style.transform = "scaleY(1)";
      setChapter(2, chapters, dots);
      return;
    }

    // Start frame: the photograph is already open (so the section rises into
    // view showing the graded hands on the indigo cloth, never a black panel),
    // lens framing the lit hands, letterbox retracted, menu hidden.
    gsap.set(img, { "--py": 74, "--s": 1.16 });
    gsap.set(bars, { scaleY: 0 });
    if (menu) gsap.set(menu, { autoAlpha: 0, y: 40 });
    setChapter(0, chapters, dots);

    ScrollTrigger.create({
      trigger: root,
      start: "top top",
      end: "+=220%",
      pin: true,
      scrub: true,
      onUpdate: (self) => {
        const p = self.progress;
        const chapterIndex = p < 0.22 ? 0 : p < 0.46 ? 1 : p < 0.7 ? 2 : 3;
        setChapter(chapterIndex, chapters, dots);
        menu?.classList.toggle("is-live", p > 0.82);
        if (railProgress) railProgress.style.transform = `scaleY(${p})`;
      },
    });

    const timeline = gsap.timeline({
      defaults: { ease: "none" },
      scrollTrigger: {
        trigger: root,
        start: "top top",
        end: "+=220%",
        scrub: true,
      },
    });

    timeline
      // Letterbox breathes in as the section locks — the "now it's a film" beat.
      .to(bars, { scaleY: 1, duration: 0.07, ease: "power2.out" }, 0)
      // Slow camera move: tilt up the figure (hands -> face) and ease the
      // zoom out. This is the heart of the shot — long and unhurried.
      .to(img, { "--py": 22, "--s": 1.04, duration: 0.62, ease: "power1.inOut" }, 0.03)
      .to(vignette, { opacity: 1.18, duration: 0.62, ease: "power1.inOut" }, 0.03)
      // Resolve: the portrait recedes into a dim, graded, softly-blurred
      // backdrop; the chapter statement clears and the portfolio menu rises.
      .to(bars, { scaleY: 0, duration: 0.18, ease: "power2.inOut" }, 0.78)
      .to(img, { "--s": 1.22, filter: "contrast(1.04) saturate(0.82) brightness(0.46) blur(7px)", duration: 0.22, ease: "power2.inOut" }, 0.78)
      .to(vignette, { opacity: 1.4, duration: 0.22, ease: "power1.in" }, 0.78)
      .to(chapterCopy, { autoAlpha: 0, y: -24, duration: 0.12, ease: "power2.in" }, 0.84)
      .to(menu, { autoAlpha: 1, y: 0, duration: 0.16, ease: "power2.out" }, 0.86);
  }

  setUp();
</script>
