  .hoop-ring {
    border: 0;
    background:
      radial-gradient(circle, transparent 0 50%, #d8a35f 51% 60%, #86572e 61% 68%, transparent 69%),
      radial-gradient(circle at 34% 28%, rgba(255, 255, 255, 0.45), transparent 28%);
    box-shadow:
      inset -0.7rem -0.7rem 1rem rgba(0, 0, 0, 0.22),
      inset 0.55rem 0.45rem 0.7rem rgba(255, 255, 255, 0.24),
      0 0.8rem 1.1rem rgba(0, 0, 0, 0.24);
  }

  .hoop-cloth {
    background:
      repeating-linear-gradient(90deg, rgba(30, 27, 23, 0.055) 0 1px, transparent 1px 9px),
      repeating-linear-gradient(0deg, rgba(30, 27, 23, 0.045) 0 1px, transparent 1px 9px),
      rgba(239, 231, 212, 0.9);
    box-shadow: inset 0 -0.8rem 1rem rgba(0, 0, 0, 0.1), inset 0 0.5rem 0.8rem rgba(255, 255, 255, 0.45);
  }

  .hoop-screw {
    box-shadow: inset 0 -0.25rem 0.2rem rgba(0, 0, 0, 0.28), 0 0.25rem 0.25rem rgba(0, 0, 0, 0.2);
  }

  .tablet {
    border: 1px solid rgba(255, 255, 255, 0.13);
