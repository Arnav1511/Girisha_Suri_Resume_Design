---
import type { ProcessSection as ProcessSectionData } from "../../data/projects";
import ThreadEmbroidery from "../thread/ThreadEmbroidery.astro";

interface Props {
  section: ProcessSectionData;
  index: number;
}

const { section, index } = Astro.props;
const stage = String(index + 1).padStart(2, "0");
---

<section class="process-section" data-reveal>
  <p class="stage">{stage} — {section.heading.toUpperCase()}</p>
  <div class="layout">
    <div class="copy">
      <h2>{section.heading}</h2>
      <p>{section.body}</p>
    </div>
    <div class="imagery">
      {
        section.interactive === "thread-embroidery" ? (
          <ThreadEmbroidery image={section.images[0]} imageAlt={section.alt[0]} />
        ) : (
          section.images.map((src, i) => <img src={src} alt={section.alt[i]} loading="lazy" width="1200" height="1500" />)
        )
      }
    </div>
  </div>
</section>

<style>
  .process-section {
    max-width: var(--max-width-content);
    margin: 0 auto;
    padding: var(--space-3xl) var(--page-gutter);
  }

  .stage {
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    gap: var(--space-xl);
    align-items: start;
  }

  .copy h2 {
    font-family: var(--font-display);
    font-variation-settings: var(--fv-h2);
    font-size: var(--fs-h2);
    margin-bottom: var(--space-sm);
  }

  .copy p {
    max-width: var(--measure-prose);
    color: var(--color-text);
  }

  .imagery img {
    width: 100%;
    border-radius: var(--radius-md);
  }

  @media (max-width: 820px) {
    .layout {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }
</style>
