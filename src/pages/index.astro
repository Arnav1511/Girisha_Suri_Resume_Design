---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getOrderedSegments } from "../data/segments";

const segments = getOrderedSegments();
---

<BaseLayout title="Girisha Suri -- Fashion Design Portfolio">
  <Fragment slot="head">
    <link rel="preload" as="image" href="/images/landing/crystal/button-marble.png" />
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  </Fragment>

  <div id="nl-root">
    <div id="nl-watercolor" aria-hidden="true"></div>
    <div id="nl-spotlight" aria-hidden="true"></div>
    <div id="nl-canvas-host" aria-hidden="true"></div>
    <div id="nl-grab" aria-hidden="true"></div>

    <main id="nl-content">
      <div id="nl-spacer" aria-hidden="true" style="height: 100vh; height: 100dvh; pointer-events: none;"></div>

      <header class="nl-hero">
        <p id="nl-kicker" class="nl-kicker">Commercial discipline &middot; Couture finishing</p>
        <h1 id="nl-heading" data-catch="bead">Girisha Suri</h1>
        <p class="nl-tagline">
          Built across streetwear, evening wear, and the spaces between &mdash; where the surface carries the idea and
          the construction stays honest.
        </p>
      </header>

      <section class="nl-segments" aria-label="Work by segment">
        <p class="nl-section-label" data-catch="bead">The work</p>
        <ul class="nl-segment-list">
          {segments.map((segment, index) => (
            <li>
              <a href={`/work/${segment.slug}`}>
                <span class="nl-segment-num">{String(index + 1).padStart(2, "0")}</span>
                <span class="nl-segment-name" data-catch="bead">{segment.name}</span>
                <span class="nl-segment-tag">{segment.slug === "vendor-collaboration" ? "B2B" : "View →"}</span>
                <span class="nl-segment-blurb">{segment.blurb}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <footer class="nl-page-footer">
        <p data-catch="bead">"Let the surface carry the idea."</p>
        <span>Girisha Suri &middot; Portfolio</span>
      </footer>
    </main>
  </div>
</BaseLayout>

<script>
  (() => {
    // ---- tweakable knobs (defaults tuned to the requested refinements) ----
    const NT = 2.5; // needle thickness (thicker per request)
    const TT = 0.0038; // thin, delicate thread like the sketch
    const BREEZE = 1.15; // pendulum sway amount (1.15 ≈ ±20°)
    // The two holes of the button, in disc-local coords — measured directly
    // from the two white holes in the reference photo (button-marble.png): a
    // near-vertical pair centred on the disc. BOTH are punched clean through
    // the geometry so they are always see-through (the page background shows
    // through them). The needle threads the TOP hole only.
    const HOLE_TOP = { x: 0.025, y: 0.215 };
    const HOLE_BOT = { x: 0.017, y: -0.206 };
    const SHADOW = 0.3; // front/top sun shadow strength

    // Always begin at the drag stage so the intro (and its scroll roll) plays
    // on every load/refresh, instead of the browser restoring the previous
    // scroll position and skipping straight past it.
    if ("scrollRestoration" in history) history.scrollRestoration = "manual";
    window.scrollTo(0, 0);

    const rootEl = document.getElementById("nl-root");
    if (!rootEl) return;

    const html = document.documentElement;
    const grab = document.getElementById("nl-grab");
    const canvasHost = document.getElementById("nl-canvas-host");
    const contentEl = document.getElementById("nl-content");

    const reduceMotion =
      (window as any).__prefersReducedMotion || window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function revealImmediately() {
      html.classList.add("nl-revealed");
      if (grab) grab.hidden = true;
      if (canvasHost) canvasHost.hidden = true;
      const spacer = document.getElementById("nl-spacer");
      if (spacer) spacer.style.display = "none";
    }

    if (reduceMotion || !grab || !canvasHost || !contentEl) {
      revealImmediately();
      return;
    }

    let revealed = false;
    function reveal() {
      if (revealed) return;
      revealed = true;
      html.classList.add("nl-revealed");
      contentEl!.style.pointerEvents = "auto";
      grab!.style.display = "none";
    }

    const S: any = {
      phase: "idle",
      p: 0,
      dragging: false,
      dragStart: null as null | { x: number; y: number; p: number },
      released: false,
      relT: 0,
      btnVy: 0,
      beadColorHex: 0x3a0703,
      threadColorHex: 0x6b2222,
      interacted: false, // becomes true on first pointer-down; kills the hint
      idleT: 0, // seconds sat idle without interacting (drives the hint)
    };

    // ---------------- drag ----------------
    function wireDrag() {
      // Drag out along the needle's axis (~136°, up and to the right) to draw
      // it from the button. Screen-space: rightward and up.
      const dir = { x: 0.719, y: -0.695 };
      const PULL_PX = 300;

      const down = (e: PointerEvent) => {
        if (S.phase && S.phase !== "idle") return;
        S.interacted = true; // first touch — the pull hint has done its job
        S.dragging = true;
        S.dragStart = { x: e.clientX, y: e.clientY, p: S.p };
        S.phase = "dragging";
        grab!.style.cursor = "grabbing";
        // Keep receiving move/up even if the pointer leaves the surface —
        // reliable dragging on touch as well as mouse/trackpad.
        try {
          grab!.setPointerCapture(e.pointerId);
        } catch {}
        e.preventDefault();
      };
      const move = (e: PointerEvent) => {
        if (!S.dragging || !S.dragStart) return;
        const dx = e.clientX - S.dragStart.x;
        const dy = e.clientY - S.dragStart.y;
        const along = (dx * dir.x + dy * dir.y) / PULL_PX;
        S.p = Math.max(0, Math.min(1, S.dragStart.p + along));
      };
      const up = () => {
        if (!S.dragging) return;
        S.dragging = false;
        grab!.style.cursor = "grab";
        S.phase = S.p >= 0.5 ? "completing" : "returning";
      };
      grab!.addEventListener("pointerdown", down);
      window.addEventListener("pointermove", move, { passive: false });
      window.addEventListener("pointerup", up);
    }

    function waitForThree(cb: () => void) {
      let tries = 0;
      const tick = () => {
        if ((window as any).THREE) return cb();
        if (tries++ > 200) {
          console.error("[needle] THREE failed to load");
          reveal();
          return;
        }
        setTimeout(tick, 25);
      };
      tick();
    }

    // ---------------- scene ----------------
    function updateBounds() {
      const cam = S.camera;
      const dist = cam.position.z;
      const vH = 2 * Math.tan(((cam.fov * Math.PI) / 180) / 2) * dist;
      const vW = vH * cam.aspect;
      S.bounds = { halfH: vH / 2, halfW: vW / 2, floorY: -vH / 2 + 0.06 };
    }

    // Size the key light's shadow frustum to cover the WHOLE visible viewport
    // in world units, so shadows look identical at every resolution / aspect
    // ratio. halfH is fixed (it depends only on the camera FOV + distance), but
    // halfW grows with the viewport's aspect ratio — on a wide monitor the
    // world is much wider than on a laptop. The frustum used to be a fixed
    // ±5.6 wide, so on wider screens any object that fell/landed past that
    // edge dropped out of the shadow map and its shadow clipped — which is why
    // the shadows looked broken at some resolutions and fine at others. Tying
    // the frustum to the live bounds (plus padding for the light's offset)
    // makes every screen cover its own content, so the result is consistent.
    function fitShadowFrustum() {
      const key = S.keyLight;
      if (!key || !S.bounds) return;
      const pad = 1.3;
      const hw = S.bounds.halfW + pad;
      const hh = S.bounds.halfH + pad;
      const cam = key.shadow.camera;
      cam.left = -hw;
      cam.right = hw;
      cam.top = hh;
      cam.bottom = -hh;
      cam.updateProjectionMatrix();
    }

    function makeEnvTexture(THREE: any) {
      const c = document.createElement("canvas");
      c.width = 512;
      c.height = 256;
      const g = c.getContext("2d")!;
      const grad = g.createLinearGradient(0, 0, 0, 256);
      grad.addColorStop(0, "#fffdf7");
      grad.addColorStop(0.32, "#efe3cf");
      grad.addColorStop(0.56, "#c9bda8");
      grad.addColorStop(0.8, "#6f6655");
      grad.addColorStop(1, "#34302a");
      g.fillStyle = grad;
      g.fillRect(0, 0, 512, 256);
      const blobs: Array<[string, number, number, number]> = [
        ["#ffe7c2", 120, 70, 90],
        ["#d8c2e6", 360, 90, 110],
        ["#c2e6d8", 250, 150, 120],
        ["#ffd6e0", 430, 180, 80],
      ];
      blobs.forEach(([col, x, y, r]) => {
        const rg = g.createRadialGradient(x, y, 0, x, y, r);
        rg.addColorStop(0, col);
        rg.addColorStop(1, "rgba(255,255,255,0)");
        g.globalAlpha = 0.55;
        g.fillStyle = rg;
        g.beginPath();
        g.arc(x, y, r, 0, 7);
        g.fill();
      });
      g.globalAlpha = 1;
      const kg = g.createRadialGradient(150, 30, 0, 150, 30, 140);
      kg.addColorStop(0, "rgba(255,255,255,0.95)");
      kg.addColorStop(1, "rgba(255,255,255,0)");
      g.fillStyle = kg;
      g.beginPath();
      g.arc(150, 30, 140, 0, 7);
      g.fill();
      const tex = new THREE.CanvasTexture(c);
      tex.mapping = THREE.EquirectangularReflectionMapping;
      tex.encoding = THREE.sRGBEncoding;
      return tex;
    }

    function buildButton(THREE: any, group: any) {
      const R = 0.95;
      // Disc outline with two real holes punched through — the page
      // background shows straight through them (canvas is transparent).
      const shape = new THREE.Shape();
      shape.absarc(0, 0, R, 0, Math.PI * 2, false);
      // Punch BOTH holes clean through the geometry, exactly over the photo's
      // two painted white holes (radius matched to them). Both are genuinely
      // see-through, so the page background always shows through them. The
      // needle threads the TOP hole only.
      const holeR = 0.125;
      const h1 = new THREE.Path();
      h1.absarc(HOLE_TOP.x, HOLE_TOP.y, holeR, 0, Math.PI * 2, true);
      const h2 = new THREE.Path();
      h2.absarc(HOLE_BOT.x, HOLE_BOT.y, holeR, 0, Math.PI * 2, true);
      shape.holes.push(h1, h2);

      const geo = new THREE.ExtrudeGeometry(shape, {
        // Thin disc: the 3D read comes from the domed face + crater relief +
        // the offset drop shadow, NOT from a thick extruded side — a thick side
        // shows as a grey band/ring around the circumference, which we don't
        // want. Keep just enough depth for a crisp edge.
        depth: 0.05,
        curveSegments: 100,
        bevelEnabled: true,
        bevelThickness: 0.012,
        bevelSize: 0.02,
        bevelSegments: 5,
      });
      geo.center();

      // Gentle shell dome + marble waviness on the front/back caps only.
      const pos = geo.attributes.position;
      const nor = geo.attributes.normal;
      const v = new THREE.Vector3();
      for (let i = 0; i < pos.count; i++) {
        v.fromBufferAttribute(pos, i);
        const nz = nor.getZ(i);
        if (Math.abs(nz) > 0.5) {
          const rad = Math.hypot(v.x, v.y);
          const ang = Math.atan2(v.y, v.x);
          // Strong dome: the face bulges in the middle and curves away toward
          // the thin rim (like a real shirt button), so the shading gradient
          // reads clearly 3D — without needing a thick, ring-forming side.
          const dome = 0.11 * Math.cos((Math.min(1, rad / R) * Math.PI) / 2);
          const wave = 0.04 * Math.sin(3 * ang + 0.6) + 0.022 * Math.sin(5 * ang + 1.7);
          pos.setZ(i, v.z + (dome + wave) * (nz > 0 ? 1 : -1));
        }
      }
      geo.computeVertexNormals();

      // Normalize the cap UVs to 0..1 across the disc for the marble map.
      const uv = geo.attributes.uv;
      for (let i = 0; i < pos.count; i++) {
        uv.setXY(i, (pos.getX(i) + R) / (2 * R), (pos.getY(i) + R) / (2 * R));
      }
      uv.needsUpdate = true;

      const mat = new THREE.MeshPhysicalMaterial({
        color: 0xbcb3a4,
        metalness: 0.0,
        // Satin, not glossy: the photo already has its highlights/shadows
        // painted in, so we keep real-time specular low — otherwise the lights
        // add a SECOND set of highlights and blow the marble out to pale white.
        roughness: 0.9,
        // A soft clearcoat sheen gives the dome a bright specular spot where
        // the key light hits it (reads very 3D) — but envMapIntensity stays 0
        // so it never picks up the environment as a grey rim/ring.
        clearcoat: 0.2,
        clearcoatRoughness: 0.35,
        envMapIntensity: 0.0,
        reflectivity: 0.02,
      });
      // Dark, fully matte edge with NO environment reflection — otherwise the
      // rim catches the sky/env as a grey fresnel ring around the circumference.
      const rimMat = new THREE.MeshStandardMaterial({
        color: 0x3a322a,
        metalness: 0.0,
        roughness: 1.0,
        envMapIntensity: 0.0,
      });
      const btn = new THREE.Mesh(geo, [mat, rimMat]);
      btn.castShadow = true;
      btn.receiveShadow = true;
      const wrap = new THREE.Group();
      wrap.add(btn);
      group.add(wrap);
      S.button = wrap;
      S.buttonFace = btn;

      const marbleImg = new Image();
      marbleImg.onload = () => {
        const cv = document.createElement("canvas");
        cv.width = marbleImg.width;
        cv.height = marbleImg.height;
        const cg = cv.getContext("2d");
        if (!cg) return;
        // Push a little contrast + saturation into the photo so its true taupe
        // tones survive the lighting (instead of washing out to pale) and the
        // dark swirls read deeper — the raw material for the crater relief.
        cg.filter = "contrast(118%) saturate(114%)";
        cg.drawImage(marbleImg, 0, 0);
        cg.filter = "none";
        // Darken the outer ring of the photo so the disc edge + bevel always
        // sample deep marble — kills the pale/white ring around the rim and
        // gives the button a defined dark edge like the reference.
        {
          const W = cv.width;
          const H = cv.height;
          const g2 = cg.createRadialGradient(W / 2, H / 2, W * 0.42, W / 2, H / 2, W * 0.5);
          g2.addColorStop(0, "rgba(38,30,22,0)");
          g2.addColorStop(1, "rgba(38,30,22,0.8)");
          cg.fillStyle = g2;
          cg.fillRect(0, 0, W, H);
        }
        const tex: any = new THREE.CanvasTexture(cv);
        tex.encoding = THREE.sRGBEncoding;
        tex.anisotropy = Math.min(8, S.renderer.capabilities.getMaxAnisotropy());
        tex.center.set(0.5, 0.5);
        tex.rotation = 0;
        // Zoom in past the photo's pale outer margin so the disc edge samples
        // solid marble — no white ring leaking around the circumference.
        tex.wrapS = tex.wrapT = THREE.ClampToEdgeWrapping;
        tex.repeat.set(0.88, 0.88);
        mat.map = tex;
        // Drive real surface relief from the photo's own light/dark tones: dark
        // swirls sit LOWER (recessed craters/dents), bright ridges sit higher —
        // so light and shadow move across real bumps as the button turns.
        mat.bumpMap = tex;
        mat.bumpScale = 0.04;
        // Multiply the map DOWN a touch so the strong lights don't overexpose
        // the marble to pale white — keeps it at the photo's own richer tone.
        mat.color.set(0xd6ccbc);
        mat.emissive = new THREE.Color(0x000000);
        mat.emissiveIntensity = 0;
        mat.needsUpdate = true;
      };
      marbleImg.src = "/images/landing/crystal/button-marble.png";
    }

    function buildNeedle(THREE: any, group: any) {
      const needle = new THREE.Group();
      // Deep red, the same family as the thread (#6B2222) — a clean solid
      // material (high segment counts below keep the thin geometry crisp, not
      // pixelated). Slight sheen so it still reads as a needle, not flat paper.
      const metal = new THREE.MeshStandardMaterial({
        color: new THREE.Color(0x6b2222).convertSRGBToLinear(),
        metalness: 0.25,
        roughness: 0.42,
        envMapIntensity: 0.6,
      });
      // Shaft tapers slightly toward the tip; radii scaled by NT (thickness).
      // The needle is LONG on the tip side (below the hole crossing at local
      // y = 0): it enters the top hole, passes behind the disc, and the point
      // emerges out the BACK, protruding past the far edge — a real threaded
      // needle. Because the pull slides it along its own axis, the whole shaft
      // retracts back through the hole seamlessly, no clipping. Eye keeps its
      // length up top.
      const shaft = new THREE.Mesh(new THREE.CylinderGeometry(0.0065 * NT, 0.0105 * NT, 2.5, 32), metal);
      shaft.position.y = 0.05; // spans local y −1.2 (bottom) … +1.3 (up to the eye)
      shaft.castShadow = true;
      needle.add(shaft);
      // A genuinely sharp point: base flush with the shaft bottom (−1.2),
      // tapering to a fine apex at −1.8, well past the disc so it reads as
      // coming out the back.
      const tip = new THREE.Mesh(new THREE.ConeGeometry(0.0105 * NT, 0.6, 32), metal);
      tip.rotation.x = Math.PI; // apex points DOWN
      tip.position.y = -1.5;
      tip.castShadow = true;
      needle.add(tip);
      const eye = new THREE.Mesh(new THREE.TorusGeometry(0.034 * NT, 0.0085 * NT, 18, 36), metal);
      eye.position.y = 1.31;
      eye.scale.set(0.6, 1, 1);
      eye.castShadow = true;
      needle.add(eye);
      const eyeCap = new THREE.Mesh(new THREE.SphereGeometry(0.016 * NT, 20, 14), metal);
      eyeCap.position.y = 1.38;
      eyeCap.castShadow = true;
      needle.add(eyeCap);

      // Threads the TOP hole only. The shaft crosses the disc plane (z = 0)
      // exactly at the top hole's centre — that crossing IS the insertion
      // point, so the needle enters right at the hole, never before or after
      // it. Above the crossing (toward the eye) the shaft is in front of the
      // disc (+z); below it (toward the tip) it dips behind the disc (−z), so
      // it genuinely reads as pushed INTO that one hole. Insertion angle 67°
      // in the protractor convention the user gave — 0° at the top, measured
      // CLOCKWISE — so the shaft points up-and-right, ~23° above horizontal
      // (eye + thread out to the upper-right, tip out to the lower-left). The
      // +z tilt lifts the eye toward the viewer so the tip dives behind the
      // face right at the hole rather than skimming across it.
      const INSERT_DEG = 73;
      const insA = (INSERT_DEG * Math.PI) / 180;
      const dir = new THREE.Vector3(Math.sin(insA), Math.cos(insA), 1.25).normalize();
      needle.quaternion.setFromUnitVectors(new THREE.Vector3(0, 1, 0), dir);
      // Origin sits AT the hole on the disc mid-plane (z = 0), so the shaft
      // crosses the face exactly at the hole centre — not shifted off to the
      // side into solid marble. (A non-zero z here would slide the crossing
      // along the needle's own diagonal, off the hole, which is what made it
      // stab through the marble.)
      needle.position.set(HOLE_TOP.x, HOLE_TOP.y, 0.0);
      needle.scale.set(1, 1.4, 1);
      group.add(needle);
      S.needle = needle;
      S.eyeLocal = new THREE.Vector3(0.034 * 0.6 * NT, 1.31, 0);
      // Pull draws the needle up and out along its own axis, pulling the
      // beaded thread through the holes.
      S.pullVec = dir.clone().multiplyScalar(4.8);
    }

    function eyeWorld() {
      return S.needle.localToWorld(S.eyeLocal.clone());
    }

    function biconeGeo(THREE: any, r: number, h: number) {
      const lathe = new THREE.LatheGeometry(
        [new THREE.Vector2(0.0001, -h / 2), new THREE.Vector2(r, 0), new THREE.Vector2(0.0001, h / 2)],
        10
      );
      return lathe.toNonIndexed ? lathe.toNonIndexed() : lathe;
    }

    function teardropGeo(THREE: any, s: number) {
      const pts: Array<[number, number]> = [
        [0.0, -1.05],
        [0.46, -0.86],
        [0.78, -0.55],
        [0.94, -0.18],
        [0.96, 0.1],
        [0.82, 0.42],
        [0.55, 0.7],
        [0.28, 0.9],
        [0.0, 1.08],
      ];
      const prof = pts.map(([r, y]) => new THREE.Vector2(Math.max(0.0015, r * s), y * s * 1.25));
      const geo = new THREE.LatheGeometry(prof, 24);
      geo.computeVertexNormals();
      return geo;
    }

    // A single clean thread strand. Beads sit directly on it.
    function rebuildThread(THREE: any) {
      if (S.threadMesh) {
        S.scene.remove(S.threadMesh);
        S.threadMesh.geometry.dispose();
      }
      const curve = new THREE.CatmullRomCurve3(S.nodes.map((n: any) => n.pos));
      const geo = new THREE.TubeGeometry(curve, S.threadN * 3, TT, 8, false);
      const mesh = new THREE.Mesh(geo, S.threadMat);
      // Cast/receive a shadow at all times — idle, falling, and landed — so the
      // needle + thread keep a grounded shadow the whole way down and at rest.
      mesh.castShadow = true;
      mesh.receiveShadow = true;
      S.scene.add(mesh);
      S.threadMesh = mesh;
    }

    // Rest shape of the thread, traced from the reference sketch: a long, thin
    // hanging LOOP (elongated ellipse) that pinches at the needle eye. Both
    // ends meet at the eye (t=0 and t=1); it bellies out to ±LOOP_W and drops
    // to LOOP_L at the bottom (t=0.5), where the beads and teardrop hang.
    const LOOP_W = 0.075; // half-width of the loop
    const LOOP_L = 2.7; // total drop to the bottom of the loop (longer thread)
    function sketchOffset(t: number) {
      const a = t * Math.PI * 2;
      // Base loop.
      let x = LOOP_W * Math.sin(a);
      let y = -(LOOP_L / 2) * (1 - Math.cos(a));
      // Hand-drawn, free-thread irregularity — the two strands wander and the
      // whole loop leans right toward the belly, rather than reading as a rigid
      // geometric ellipse. Every term is zero at a=0 and a=2π, so the loop
      // still pinches cleanly at the needle eye.
      x += 0.055 * Math.sin(2 * a) + 0.028 * Math.sin(3 * a) + 0.1 * Math.sin(a / 2);
      y += -0.05 * (1 - Math.cos(2 * a)) + 0.03 * Math.sin(3 * a);
      const z = 0.06 * Math.sin(a) + 0.035 * Math.sin(2 * a) + 0.02 * Math.sin(3 * a);
      return { x, y, z };
    }

    function buildThreadAndBeads(THREE: any) {
      const N = 60;
      S.threadN = N;
      S.segLen = LOOP_L / (N / 2);
      const anchor = eyeWorld();
      S.nodes = [];
      for (let i = 0; i < N; i++) {
        const t = i / (N - 1);
        const off = sketchOffset(t);
        const p = new THREE.Vector3(anchor.x + off.x, anchor.y + off.y, anchor.z + off.z + 0.05);
        S.nodes.push({ pos: p.clone(), prev: p.clone() });
      }
      S.threadMat = new THREE.MeshStandardMaterial({
        color: new THREE.Color(S.threadColorHex).convertSRGBToLinear(),
        roughness: 0.95,
        metalness: 0.0,
        envMapIntensity: 0.1,
        transparent: true,
        opacity: 1,
      });
      S.threadMesh = null;
      rebuildThread(THREE);

      // Uncut ruby stones: deep translucent red, chunky irregular facets.
      //   biggest stone  → #270402
      //   all others     → #3A0703 / #4E0904, randomised
      const RUBY_BIG = 0x270402;
      const RUBY_SMALL = [0x3a0703, 0x4e0904];
      const pickSmall = () => RUBY_SMALL[Math.floor(Math.random() * RUBY_SMALL.length)];
      const rubyMat = (hex: number) => {
        const col = new THREE.Color(hex).convertSRGBToLinear();
        return new THREE.MeshPhysicalMaterial({
          color: col,
          metalness: 0.0,
          roughness: 0.34 + Math.random() * 0.12,
          clearcoat: 0.5,
          clearcoatRoughness: 0.3,
          transmission: 0.14,
          ior: 1.76, // ruby
          thickness: 0.25,
          attenuationColor: col,
          attenuationDistance: 0.35,
          envMapIntensity: 0.55,
          reflectivity: 0.4,
          flatShading: true, // hard facets → uncut look
        });
      };
      // Push each vertex in/out along its radius so the stone reads as a rough,
      // hand-knapped uncut crystal rather than a clean geometric solid.
      const roughen = (geo: any, amt: number) => {
        const p = geo.attributes.position;
        const v = new THREE.Vector3();
        // Icosahedron geometry is non-indexed, so shared corners appear as
        // multiple vertices — displace by a factor keyed to the rounded
        // position so every copy of a corner moves identically (no cracks).
        const cache = new Map<string, number>();
        for (let i = 0; i < p.count; i++) {
          v.fromBufferAttribute(p, i);
          const key = `${v.x.toFixed(4)},${v.y.toFixed(4)},${v.z.toFixed(4)}`;
          let f = cache.get(key);
          if (f === undefined) {
            f = 1 + (Math.random() - 0.5) * amt;
            cache.set(key, f);
          }
          v.multiplyScalar(f);
          p.setXYZ(i, v.x, v.y, v.z);
        }
        p.needsUpdate = true;
        geo.computeVertexNormals();
        return geo;
      };
      const mk = (geo: any, hex: number) => {
        const m = new THREE.Mesh(geo, rubyMat(hex));
        m.castShadow = true;
        m.receiveShadow = true;
        return m;
      };
      // Chunky low-poly icosahedra (detail 0 = 20 faces), roughened.
      const stone = (r: number) => roughen(new THREE.IcosahedronGeometry(r, 0), 0.45);
      // biconeGeo is non-indexed, so roughening would crack it — its low-poly
      // lathe + flatShading already gives clean faceted facets.
      const bicone = (r: number) => biconeGeo(THREE, r, r * 1.9);
      // Stones sit on the lower part of the loop, strung down to the big
      // teardrop drop at the very bottom (node 30 ≈ t 0.5), like the
      // "multiple beads" sketch. N = 60 → the bottom of the loop is at node 30.
      // The longer thread carries a few extra stones (same knapped-ruby look
      // and physics as the rest — they're all pushed through the same pipeline
      // below and into S.beads).
      const specs: Array<{ node: number; geo: () => any; r: number }> = [
        { node: 14, geo: () => stone(0.025), r: 0.025 },
        { node: 15, geo: () => bicone(0.024), r: 0.028 },
        { node: 16, geo: () => stone(0.027), r: 0.027 },
        { node: 17, geo: () => bicone(0.025), r: 0.029 },
        { node: 18, geo: () => stone(0.026), r: 0.026 },
        { node: 19, geo: () => bicone(0.026), r: 0.03 },
        { node: 20, geo: () => stone(0.031), r: 0.031 },
        { node: 21, geo: () => stone(0.028), r: 0.028 },
        { node: 22, geo: () => stone(0.024), r: 0.024 },
        { node: 23, geo: () => bicone(0.03), r: 0.038 },
        { node: 24, geo: () => stone(0.033), r: 0.033 },
        { node: 25, geo: () => bicone(0.028), r: 0.034 },
        { node: 26, geo: () => stone(0.03), r: 0.03 },
        { node: 27, geo: () => bicone(0.026), r: 0.03 },
        { node: 28, geo: () => stone(0.029), r: 0.029 },
        { node: 29, geo: () => bicone(0.03), r: 0.038 },
        { node: 30, geo: () => teardropGeo(THREE, 0.055), r: 0.064 },
        { node: 32, geo: () => stone(0.029), r: 0.029 },
        { node: 33, geo: () => bicone(0.026), r: 0.03 },
        { node: 34, geo: () => stone(0.026), r: 0.026 },
        { node: 35, geo: () => stone(0.028), r: 0.028 },
        { node: 36, geo: () => bicone(0.027), r: 0.032 },
        { node: 37, geo: () => stone(0.026), r: 0.026 },
        { node: 38, geo: () => teardropGeo(THREE, 0.05), r: 0.058 },
      ];
      const radii = specs.map((s) => s.r);
      // Largest stone (the teardrop) gets the deepest red; the rest randomised.
      const maxR = Math.max(...radii);
      S.beads = [];
      specs.forEach((sp, idx) => {
        const r = sp.r ?? radii[idx];
        const hex = r >= maxR - 1e-6 ? RUBY_BIG : pickSmall();
        const mesh = mk(sp.geo(), hex);
        mesh.rotation.set(Math.random() * 6, Math.random() * 6, Math.random() * 6);
        mesh.userData = {
          node: sp.node,
          radius: (sp.r ?? radii[idx]) * 1.1,
          free: false,
          vel: new THREE.Vector3(),
          settled: false,
          delay: 0,
          spin: new THREE.Vector3((Math.random() - 0.5) * 3, (Math.random() - 0.5) * 3, (Math.random() - 0.5) * 3),
        };
        S.scene.add(mesh);
        S.beads.push(mesh);
      });
    }

    function applyPull(p: number) {
      // Once the needle has broken away (S.needleFall), it falls under its own
      // physics — don't keep yanking it back along the pull axis.
      if (!S.needleFall) S.needle.position.copy(S.needleBase).addScaledVector(S.pullVec, p);
      // Do NOT rotate the button while pulling: the hole is off-centre, so any
      // rotation swings it away from the needle's fixed axis and the last bit
      // (the tip) would exit through solid marble instead of the hole — that's
      // the tip "clipping". Held still, the needle slides straight out through
      // the hole. (The button still tumbles later, during its fall.)
      // Normal depth testing does the right thing on its own: the part of the
      // needle still behind the disc stays hidden, and only the part that has
      // emerged in front of the face draws on top of the button as it comes out
      // of the hole.
    }

    // Idle thread: the whole drape swings like a pendulum about the needle
    // eye. BREEZE 1.15 ≈ ±20° swing (0.3035 rad per unit).
    function shapeThread(THREE: any, time: number) {
      const anchor = eyeWorld();
      const nodes = S.nodes;
      const maxRad = BREEZE * 0.3035;
      const sway = maxRad * (0.85 * Math.sin(time * 0.62) + 0.15 * Math.sin(time * 1.4 + 0.5));
      const cs = Math.cos(sway),
        sn = Math.sin(sway);
      for (let i = 0; i < nodes.length; i++) {
        const t = i / (nodes.length - 1);
        const a = t * Math.PI * 2;
        const off = sketchOffset(t);
        // A travelling undulation that grows toward the belly of the loop and
        // vanishes at the eye — makes the thread flutter/flow like a real
        // hanging thread rather than swinging as one rigid shape.
        const belly = Math.sin(a / 2);
        const flowX = 0.05 * Math.sin(a * 1.6 - time * 1.4) * belly;
        const flowZ = 0.04 * Math.sin(a * 2.1 + time * 1.0) * belly;
        const dx = off.x + flowX,
          dy = off.y;
        // rotate the offset-from-eye about Z (screen plane) — anchor (the eye)
        // stays put, the bottom of the loop swings the most.
        const rx = dx * cs - dy * sn;
        const ry = dx * sn + dy * cs;
        nodes[i].pos.set(anchor.x + rx, anchor.y + ry, anchor.z + off.z + flowZ + 0.05);
        nodes[i].prev.copy(nodes[i].pos);
      }
      rebuildThread(THREE);
    }

    function placeBeadsOnThread() {
      S.beads.forEach((m: any) => {
        if (m.userData.free) return;
        const n = S.nodes[m.userData.node];
        m.position.copy(n.pos);
        m.rotation.x += 0.003;
        m.rotation.y += 0.005;
      });
    }

    function screenToWorld(sx: number, sy: number, zWorld: number) {
      const THREE = (window as any).THREE;
      const W = window.innerWidth,
        H = window.innerHeight;
      const v = new THREE.Vector3((sx / W) * 2 - 1, -(sy / H) * 2 + 1, 0.5);
      v.unproject(S.camera);
      const dir = v.sub(S.camera.position).normalize();
      const dist = (zWorld - S.camera.position.z) / dir.z;
      return S.camera.position.clone().add(dir.multiplyScalar(dist));
    }

    function worldToScreen(pos: any) {
      const W = window.innerWidth,
        H = window.innerHeight;
      const v = pos.clone().project(S.camera);
      return { x: (v.x * 0.5 + 0.5) * W, y: (-v.y * 0.5 + 0.5) * H };
    }

    // The thread "breaks": beads fall down the page and snap onto text; the
    // button drops all the way to the footer name. Positions are tracked in
    // document space (px) so a stuck object rides with its text as the page
    // scrolls — each frame we project doc-space back into the 3D scene.
    // Tight bounds of an element's actual TEXT (not its full block box). A
    // centred <p>/<h1> has a full-width box with empty margins on either side;
    // a bead aimed at that box could land in the blank margin. Measuring the
    // text run with a Range keeps beads on the real letters only.
    function textRect(el: HTMLElement) {
      try {
        const range = document.createRange();
        range.selectNodeContents(el);
        const r = range.getBoundingClientRect();
        if (r && r.width > 0 && r.height > 0) return r;
      } catch (e) {
        /* fall through */
      }
      return el.getBoundingClientRect();
    }

    function startFall() {
      const sc = window.scrollY;
      // Every catchable letter/word on the page.
      const beadEls = Array.from(document.querySelectorAll('[data-catch="bead"]')) as HTMLElement[];
      S.beads.forEach((m: any) => {
        const u = m.userData;
        u.free = true;
        u.stuck = false;
        m.castShadow = false; // no stray far-cast shadow once it leaves the thread
        const s = worldToScreen(m.position);
        u.docX = s.x;
        u.docY = s.y + sc;
        u.beadZ = m.position.z;
        u.vy = 10 + Math.random() * 70;
        u.bounces = 3 + Math.floor(Math.random() * 3); // several bounces
        u.age = 0;
        u.minLive = 1.2 + Math.random() * 0.6; // stay lively ~1.2–1.8s before it can settle
        u.frac = 0.15 + Math.random() * 0.7; // landing spot along its target word
        u.atBottom = false; // true once it has come to rest at the page bottom
        // Land only on a hard object — a letter BELOW where it starts — and
        // rest on TOP of it. If there is no letter beneath (it would pass
        // through them all), it drops to the bottom of the last page instead.
        const below = beadEls.filter((el) => {
          const r = textRect(el);
          return r.width > 0 && r.height > 0 && r.top + sc > u.docY + 8;
        });
        u.targetEl = below.length ? below[Math.floor(Math.random() * below.length)] : null;
      });
      // Always send at least 4 beads all the way to the bottom of the last
      // page (the rest stay random). Which beads is shuffled each run, but each
      // gets a fixed, evenly-spread landing column across the page so they
      // bounce down their own clean path and settle at distinct spots — never
      // piling up or teleporting.
      const order = S.beads.map((_: any, i: number) => i).sort(() => Math.random() - 0.5);
      const nBottom = Math.min(S.beads.length, 4 + Math.floor(Math.random() * 3)); // 4–6
      const vw = window.innerWidth;
      order.slice(0, nBottom).forEach((i: number, k: number) => {
        const u = S.beads[i].userData;
        u.targetEl = null;
        u.bottomX = vw * (0.16 + 0.68 * ((k + 0.5) / nBottom)); // spread 16%–84% across
      });

      // The button drops all the way down to the dark site footer and settles
      // in the negative space just above the "Girisha Suri" wordmark, turning
      // slowly.
      S.scene.attach(S.button); // reparent to scene, keep world transform
      S.btnScaleRest = S.button.scale.clone().multiplyScalar(0.62); // shrink to a medallion when it lands
      const bs = worldToScreen(S.button.getWorldPosition(new (window as any).THREE.Vector3()));
      const nameEl = document.querySelector(".site-footer .name") as HTMLElement | null;
      S.btnFall = {
        el: nameEl,
        stuck: false,
        docX: bs.x,
        docY: bs.y + sc,
        vy: 30,
        vx: 0,
        bounces: 3, // bounce a few times before resting on the name
      };

      // The needle + thread BREAK AWAY from the button and fall together to the
      // very bottom of the page. The beads have just been released (above), so
      // the loop is now a bare string trailing from the needle eye — that is
      // the "thread breaking". Physics for both are tracked in document space
      // (px) so they fall the full length of the page and ride scrolls.
      const THREE2 = (window as any).THREE;
      S.scene.attach(S.needle); // keep world transform, detach from the hero group
      const nWorld = S.needle.getWorldPosition(new THREE2.Vector3());
      const nsp = worldToScreen(nWorld);
      // Deterministic landing: no random velocity/spin/bounce. Wherever the
      // needle breaks away from, it always drifts to the SAME column and comes
      // to rest in the SAME place with the SAME orientation — so the final
      // needle+thread pose is identical on every platform and resolution. The
      // target column is a fraction of the viewport width, so it scales.
      S.needleFall = {
        docX: nsp.x,
        docY: nsp.y + sc,
        z: nWorld.z,
        vy: 12,
        targetX: vw * 0.5, // fixed landing column (centre), scales with width
        stuck: false,
        spin: 2.0, // fixed gentle tumble, eases back to eye-up at rest
      };
      // The needle + thread come to rest a comfortable margin ABOVE the very
      // bottom of the page instead of jammed against the last pixel (where the
      // tip and half the thread were being clipped off the bottom edge, which
      // made the whole thing read as broken/detached). This leaves the eye,
      // shaft and the little pool of thread fully on-screen. Scaled to the
      // viewport so it looks the same on any screen.
      S.restMargin = Math.min(190, Math.round(window.innerHeight * 0.17));
      S.threadRest = false; // becomes true once the thread stops moving
      S.threadCalm = 0; // seconds the needle has been landed, gating the freeze
      // Seed the thread nodes into document space for a simple rope simulation
      // (verlet + distance constraints) that trails from the falling needle.
      let segSum = 0;
      for (let i = 0; i < S.nodes.length; i++) {
        const s = worldToScreen(S.nodes[i].pos);
        const n = S.nodes[i];
        n.docX = s.x;
        n.docY = s.y + sc;
        n.docPX = s.x;
        n.docPY = s.y + sc;
        if (i > 0) {
          const p = worldToScreen(S.nodes[i - 1].pos);
          segSum += Math.hypot(s.x - p.x, s.y - p.y);
        }
      }
      S.threadSegPx = Math.max(4, segSum / Math.max(1, S.nodes.length - 1));
      S.threadFalling = true;
      S.threadMat.opacity = 1; // it no longer fades; it falls instead

      // Roll the page down to the hero, like turning to the next page. We
      // drive the scroll ourselves with plain window.scrollTo — supported on
      // every browser and device — so it stays one smooth, unbroken roll.
      // Lenis is paused for the duration so it can't fight us, then handed
      // back in finishBreak once the drag stage has been removed.
      (window as any).__lenis?.stop();
      // Land with the kicker a short, comfortable distance below the fixed
      // header — a little breathing room, not a screenful of empty space.
      // (finishBreak's spacer removal is pixel-seamless, so wherever the roll
      // ends is exactly where we stay.)
      const headerEl = document.querySelector(".site-header") as HTMLElement | null;
      const headerH = headerEl ? headerEl.getBoundingClientRect().height : 0;
      const kickerEl = document.getElementById("nl-kicker");
      const spacerEl = document.getElementById("nl-spacer");
      const spacerH = spacerEl ? spacerEl.offsetHeight : window.innerHeight;
      const landGap = headerH + 26; // small negative space above the kicker
      const kickerDoc = kickerEl ? kickerEl.getBoundingClientRect().top + window.scrollY : spacerH;
      const target = Math.max(spacerH * 0.5, kickerDoc - landGap);
      S.roll = { from: window.scrollY, to: target, t: 0, dur: 1.6, done: false };
    }

    // Remove the 100vh drag stage so the hero header becomes the top of the
    // page — the blank first screen can never be scrolled back into view.
    function finishBreak() {
      const spacer = document.getElementById("nl-spacer");
      if (!spacer || (spacer as any).dataset.removed) return;
      const h = spacer.offsetHeight;
      const cur = window.scrollY;
      spacer.style.display = "none";
      (spacer as any).dataset.removed = "1";
      // Shift anything still in flight up by the removed height so it keeps
      // falling toward the same on-screen spot.
      S.beads.forEach((m: any) => {
        const u = m.userData;
        if (u.free && !u.stuck) u.docY -= h;
      });
      if (S.btnFall && !S.btnFall.stuck) S.btnFall.docY -= h;
      if (S.needleFall && !S.needleFall.stuck) S.needleFall.docY -= h;
      if (S.threadFalling) {
        S.nodes.forEach((n: any) => {
          n.docY -= h;
          n.docPY -= h;
        });
      }
      // Re-anchor to the hero top. Removing the spacer + shifting scroll by
      // the same amount keeps every pixel in place (beads included), so this
      // is invisible — but it must NOT read as an upward scroll. Route it
      // through Lenis with `immediate` so it snaps in one paint and Lenis's
      // own position stays synced (no drift back toward a stale target).
      const newTop = Math.max(0, cur - h);
      const lenis = (window as any).__lenis;
      lenis?.resize?.();
      lenis?.start?.(); // hand scrolling back to the user
      if (lenis?.scrollTo) {
        lenis.scrollTo(newTop, { immediate: true, force: true });
      } else {
        window.scrollTo(0, newTop);
      }
      window.dispatchEvent(new Event("resize"));
    }

    // The DETERMINISTIC resting shape of the thread, in document-space pixels,
    // anchored at the needle eye. Given the eye position and the floor, it
    // returns where node `t` (0 = eye … 1 = free end) should lie: the strand
    // hangs from the eye straight down to the floor, then the remaining length
    // lies in a compact serpentine pool trailing to one side. Because it is a
    // pure function of the eye + floor (no physics, no randomness), the settled
    // needle+thread looks pixel-identical on every platform and resolution, and
    // node 0 is exactly on the eye so it can never read as detached.
    function threadRestPoint(t: number, eyeX: number, eyeY: number, floorDoc: number) {
      const N = S.threadN;
      const totalLen = S.threadSegPx * (N - 1);
      const H = Math.max(30, floorDoc - eyeY); // drop from the eye to the floor
      // Fraction of the strand spent hanging down to the floor (a touch more
      // than H so it isn't bowstring-taut), clamped to sensible bounds.
      let tDrop = (H * 1.15) / Math.max(1, totalLen);
      tDrop = Math.min(0.62, Math.max(0.24, tDrop));
      if (t <= tDrop) {
        const f = t / tDrop; // 0 at eye … 1 at floor
        const ease = 1 - (1 - f) * (1 - f); // steeper near the eye, easing onto the floor
        // Bow out to the side as it descends so the hanging strand separates
        // cleanly from the needle shaft rather than running parallel to it.
        return { x: eyeX - 48 * Math.sin(f * Math.PI * 0.5), y: eyeY + H * ease };
      }
      const g = (t - tDrop) / (1 - tDrop); // 0 … 1 along the floor pool
      // Trail the pool to the left, but never past the left edge — cap the reach
      // to the room actually available, so on a narrow phone it stays fully on
      // screen just like on a wide monitor.
      const room = Math.max(30, eyeX - 80);
      const reach = Math.min(170, totalLen * (1 - tDrop) * 0.55, room);
      const x = eyeX - 48 - reach * g + Math.sin(g * Math.PI * 3) * 20 * (1 - 0.35 * g);
      const y = floorDoc - Math.abs(Math.sin(g * Math.PI * 3)) * 6; // hug the floor with soft bumps
      return { x, y };
    }

    // Rope simulation for the broken thread as it falls with the needle. Node 0
    // is pinned to the needle eye; the rest integrate under gravity (verlet) in
    // document-space pixels, with a few distance-constraint passes to hold the
    // strand together. Nodes are then projected back into the 3D scene.
    function simThreadFall(THREE: any, dt: number, sc: number, floorDoc: number) {
      const nodes = S.nodes;
      // Refresh the needle's world matrix FIRST so the eye position we pin the
      // head to is this frame's, not last frame's (localToWorld reads a cached
      // matrix, which lags a frame and can open a hairline gap at the eye while
      // things are still moving). The head is glued to the eye every frame.
      S.needle.updateMatrixWorld(true);
      const es = worldToScreen(eyeWorld());
      const headX = es.x;
      const headY = es.y + sc;

      // Once the needle has landed, ease the whole strand into the DESIGNED
      // resting drape (a pure function of the eye + floor) and hold it there,
      // instead of leaving the physics to settle into a different — and often
      // detached-looking — shape each time. Node 0 stays exactly on the eye, so
      // the thread is always connected, and the pose is identical everywhere.
      if (S.threadRest) {
        nodes[0].docX = headX;
        nodes[0].docY = headY;
        const k = Math.min(1, dt * 6); // smooth glide into the designed shape
        for (let i = 1; i < nodes.length; i++) {
          const t = i / (nodes.length - 1);
          const tgt = threadRestPoint(t, headX, headY, floorDoc);
          nodes[i].docX += (tgt.x - nodes[i].docX) * k;
          nodes[i].docY += (tgt.y - nodes[i].docY) * k;
        }
        for (let i = 0; i < nodes.length; i++) {
          nodes[i].pos.copy(screenToWorld(nodes[i].docX, nodes[i].docY - sc, 0));
        }
        rebuildThread(THREE);
        return;
      }

      const g = 2600; // px/s^2 in document space
      const rest = S.threadSegPx;
      // Pin the head to the needle eye.
      nodes[0].docX = headX;
      nodes[0].docY = headY;
      nodes[0].docPX = headX;
      nodes[0].docPY = headY;
      // Verlet integrate the rest, tracking how fast the strand is still moving
      // so we know when it has come to rest.
      let maxSpeed = 0;
      for (let i = 1; i < nodes.length; i++) {
        const n = nodes[i];
        const vx = (n.docX - n.docPX) * 0.98;
        const vy = (n.docY - n.docPY) * 0.98;
        if (Math.abs(vx) > maxSpeed) maxSpeed = Math.abs(vx);
        if (Math.abs(vy) > maxSpeed) maxSpeed = Math.abs(vy);
        n.docPX = n.docX;
        n.docPY = n.docY;
        n.docX += vx;
        n.docY += vy + g * dt * dt;
      }
      // Iterate distance + floor as balanced constraints. Each pass: (1) hold
      // each segment at its rest length so the strand stays intact and its head
      // stays glued to the pinned eye — NO gap between needle and thread; then
      // (2) push any node that sank below the floor back up onto it. Node 0
      // (the eye) is never moved, so the whole thread hangs from the needle and
      // comes to rest, still attached.
      for (let it = 0; it < 16; it++) {
        for (let i = 1; i < nodes.length; i++) {
          const a = nodes[i - 1];
          const b = nodes[i];
          const dx = b.docX - a.docX;
          const dy = b.docY - a.docY;
          const d = Math.hypot(dx, dy) || 1e-4;
          const diff = (d - rest) / d;
          if (i - 1 === 0) {
            b.docX -= dx * diff;
            b.docY -= dy * diff;
          } else {
            a.docX += dx * 0.5 * diff;
            a.docY += dy * 0.5 * diff;
            b.docX -= dx * 0.5 * diff;
            b.docY -= dy * 0.5 * diff;
          }
        }
        // Floor collision as a constraint (not a hard pre-clamp that fought the
        // distance pass and tore the strand off the eye).
        for (let i = 1; i < nodes.length; i++) {
          if (nodes[i].docY > floorDoc) nodes[i].docY = floorDoc;
        }
      }
      // Keep the eye pinned as the final word (distance passes never move it,
      // but be explicit) so the head is exactly on the needle eye.
      nodes[0].docX = headX;
      nodes[0].docY = headY;
      // Project back into the scene for the tube geometry.
      for (let i = 0; i < nodes.length; i++) {
        nodes[i].pos.copy(screenToWorld(nodes[i].docX, nodes[i].docY - sc, 0));
      }
      rebuildThread(THREE);

      // Latch to rest once the needle has landed: either as soon as the strand
      // goes calm, or after a short grace period regardless. The rope solver
      // leaves a permanent ~1px per-frame jitter as it redistributes the slack
      // pooled on the floor, so a pure "is it calm" test never fully fires and
      // the tail creeps forever — the time cap guarantees it always comes to
      // rest and stays put.
      if (S.needleFall && S.needleFall.stuck) {
        S.threadCalm += dt;
        if (maxSpeed < 1.2 || S.threadCalm > 2.5) S.threadRest = true;
      }
    }

    function updateFall(dt: number) {
      // Smooth roll to the next page — self-driven, no dependency on Lenis.
      if (S.roll && !S.roll.done) {
        S.roll.t += dt;
        const k = Math.min(1, S.roll.t / S.roll.dur);
        const e = 1 - Math.pow(1 - k, 3);
        window.scrollTo(0, S.roll.from + (S.roll.to - S.roll.from) * e);
        if (k >= 1) {
          S.roll.done = true;
          finishBreak();
        }
      }
      const sc = window.scrollY;
      const G = 1000;
      const maxDoc = document.body.scrollHeight - 24;

      // The needle falls and comes to rest a margin above the very bottom so
      // it (and the thread hanging from its eye) stay fully visible.
      const needleFloor = maxDoc - (S.restMargin || 0);
      const nf = S.needleFall;
      if (nf) {
        // Always steer horizontally to the fixed landing column so the needle
        // ends up in the same spot every time (no random drift).
        if (nf.targetX != null) {
          const ease = nf.stuck ? Math.min(1, dt * 4) : Math.min(1, dt * 2.2);
          nf.docX += (nf.targetX - nf.docX) * ease;
        }
        if (!nf.stuck) {
          nf.vy += G * dt;
          nf.docY += nf.vy * dt;
          S.needle.rotation.z += nf.spin * dt; // one clean tumble on the way down
          if (nf.docY >= needleFloor) {
            nf.docY = needleFloor; // lands once, cleanly — no bounce
            nf.stuck = true;
            nf.vy = 0;
          }
        } else {
          // Landed: ease back to the threaded orientation (rotation.z → 0) so
          // the EYE points up and the thread drapes visibly down from it onto
          // the floor. Deterministic end orientation, identical every run.
          S.needle.rotation.z += (0 - S.needle.rotation.z) * Math.min(1, dt * 3);
        }
        S.needle.position.copy(screenToWorld(nf.docX, nf.docY - sc, nf.z));
      }

      // The thread trails behind the falling needle like a broken string
      // (simple rope sim in document space, then projected back into 3D). Its
      // floor sits just below where the needle rests, so it pools in a small
      // visible heap under the eye rather than smearing along the very bottom
      // edge of the page.
      if (S.threadFalling) {
        const threadFloor = maxDoc - Math.max(0, (S.restMargin || 0) - 26);
        simThreadFall((window as any).THREE, dt, sc, threadFloor);
      }

      S.beads.forEach((m: any) => {
        const u = m.userData;
        if (!u.free) return;
        if (!u.stuck) {
          u.age += dt;
          u.vy += G * dt;
          u.docY += u.vy * dt;
          let tY: number | null = null;
          let tX: number | null = null;
          if (u.targetEl) {
            const r = textRect(u.targetEl);
            tY = r.top + sc; // land ON TOP of the letters, not in their middle
            tX = r.left + r.width * u.frac;
          } else {
            // A guaranteed-bottom bead: drift toward its own fixed spread column
            // the whole way down, so it bounces along a clean path and settles
            // at a distinct spot at the bottom of the last page.
            if (u.bottomX != null) tX = u.bottomX;
            if (u.docY >= maxDoc) tY = maxDoc;
          }
          // Drift horizontally onto the target word as it falls, so it lands on
          // the text naturally instead of piling up where the thread hung.
          if (tX != null) u.docX += (tX - u.docX) * Math.min(1, dt * 2.5);
          if (tY != null && u.docY >= tY) {
            u.docY = tY;
            // Stay lively for ~1.5s: keep bouncing (with a floor on the bounce
            // while it's still young) until it has both aged out and run out of
            // bounces. Then settle — never teleport.
            const canSettle = u.age >= u.minLive && u.bounces <= 0;
            if (!canSettle) {
              let bv = Math.abs(u.vy) * 0.5;
              if (u.age < u.minLive) bv = Math.max(bv, 150 + Math.random() * 130);
              u.vy = -bv;
              if (u.bounces > 0) u.bounces--;
            } else {
              u.stuck = true;
              u.vy = 0;
              if (!u.targetEl) u.atBottom = true; // came to rest at the page bottom
            }
          }
          m.rotation.x += u.spin.x * dt;
          m.rotation.y += u.spin.y * dt;
        } else if (u.targetEl) {
          // Locked onto its word — ride the TOP of it as the page scrolls, and
          // keep a slow idle turn so the facets keep catching light (shine).
          const r = textRect(u.targetEl);
          u.docY = r.top + sc;
          const tX = r.left + r.width * u.frac;
          u.docX += (tX - u.docX) * Math.min(1, dt * 5);
          m.rotation.x += 0.25 * dt;
          m.rotation.y += 0.32 * dt;
        } else if (u.atBottom) {
          // Resting at the very bottom of the last page — pinned at its own
          // spread column so the guaranteed-bottom beads stay evenly placed.
          u.docY = maxDoc;
          if (u.bottomX != null) u.docX += (u.bottomX - u.docX) * Math.min(1, dt * 5);
          m.rotation.x += 0.25 * dt;
          m.rotation.y += 0.32 * dt;
        }
        m.position.copy(screenToWorld(u.docX, u.docY - sc, u.beadZ));
      });

      const b = S.btnFall;
      if (b) {
        // Rest point: horizontally over the wordmark, vertically centred in
        // the empty space between the footer's top edge and the wordmark.
        let restY: number | null = null;
        let restX = b.docX;
        if (b.el) {
          const nr = b.el.getBoundingClientRect();
          const foot = (b.el as HTMLElement).closest(".site-footer");
          const fr = foot ? foot.getBoundingClientRect() : nr;
          restY = (fr.top + nr.top) / 2 + sc;
          restX = nr.left + nr.width * 0.5;
        }
        if (!b.stuck) {
          b.vy += G * 0.9 * dt;
          b.docY += b.vy * dt;
          // Roll gradually toward the resting column as it drops, so it
          // arrives there naturally rather than snapping at the end.
          if (restX != null) b.docX += (restX - b.docX) * Math.min(1, dt * 2.0);
          S.button.rotation.z += dt * 1.6; // tumble/roll on the way down
          const tY = restY != null ? restY : b.docY >= maxDoc ? maxDoc : null;
          if (tY != null && b.docY >= tY) {
            b.docY = tY;
            if (Math.abs(b.vy) > 60 && b.bounces > 0) {
              b.vy = -Math.abs(b.vy) * 0.5; // bounce before it settles
              b.bounces--;
            } else {
              b.stuck = true;
              b.vy = 0;
            }
          }
        } else {
          // Settled above the footer wordmark — ease into place (never
          // teleport), shrink to a medallion that clears the name, turn slowly.
          if (restY != null) {
            b.docY += (restY - b.docY) * Math.min(1, dt * 4);
            b.docX += (restX - b.docX) * Math.min(1, dt * 4);
          }
          if (S.btnScaleRest) S.button.scale.lerp(S.btnScaleRest, Math.min(1, dt * 3));
          S.button.rotation.z += dt * 0.25;
        }
        S.button.position.copy(screenToWorld(b.docX, b.docY - sc, 0));
      }
    }

    function frame() {
      const THREE = (window as any).THREE;
      if (!THREE || !S.renderer) return;
      const dt = Math.min(S.clock.getDelta(), 0.033);
      const time = S.clock.elapsedTime;

      if (S.phase === "idle") {
        // Pull hint (auto-peek): after a short idle, the needle gently eases out
        // of the button and settles back on a loop — a live preview of the pull
        // — until the user first interacts.
        if (!S.interacted) {
          S.idleT += dt;
          const t2 = S.idleT - 2.5;
          let peek = 0;
          if (t2 > 0) {
            const local = t2 % 3.4; // out-and-back, then a short rest, repeat
            if (local < 1.6) peek = Math.sin((local / 1.6) * Math.PI) * 0.13;
          }
          S.p = peek;
        }
        applyPull(S.p);
        shapeThread(THREE, time);
        placeBeadsOnThread();
        S.heroGroup.position.y = Math.sin(time * 0.6) * 0.008;
      } else if (S.phase === "dragging") {
        applyPull(S.p);
        shapeThread(THREE, time);
        placeBeadsOnThread();
      } else if (S.phase === "returning") {
        S.p += (0 - S.p) * Math.min(1, dt * 8);
        applyPull(S.p);
        shapeThread(THREE, time);
        placeBeadsOnThread();
        if (S.p < 0.005) {
          S.p = 0;
          S.phase = "idle";
        }
      } else if (S.phase === "completing") {
        S.p = Math.min(1, S.p + dt * 1.7);
        applyPull(S.p);
        if (S.p > 0.45 && !S.released) {
          S.released = true;
          startFall();
          reveal();
        }
        if (S.released) updateFall(dt);
        else {
          shapeThread(THREE, time);
          placeBeadsOnThread();
        }
        if (S.p >= 1) S.phase = "released";
      } else {
        updateFall(dt);
      }

      // Pulsing eye halo (pull hint): visible only until the first interaction,
      // riding the needle's eye and pulsing to draw the eye there.
      if (S.eyeGlow) {
        const hint = !S.interacted && S.phase === "idle";
        const pulse = 0.5 + 0.5 * Math.sin(time * 2.0);
        const target = hint ? 0.3 + 0.45 * pulse : 0;
        const m = S.eyeGlow.material;
        m.opacity += (target - m.opacity) * Math.min(1, dt * 4);
        if (m.opacity > 0.01) {
          S.eyeGlow.visible = true;
          S.eyeGlow.position.copy(S.heroGroup.worldToLocal(eyeWorld()));
          const s = 0.72 + 0.2 * pulse;
          S.eyeGlow.scale.set(s, s, 1);
        } else {
          S.eyeGlow.visible = false;
        }
      }

      S.renderer.render(S.scene, S.camera);
    }

    function init() {
      const THREE = (window as any).THREE;
      const host = canvasHost!;
      const W = window.innerWidth,
        H = window.innerHeight;

      const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
      renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
      renderer.setSize(W, H);
      renderer.shadowMap.enabled = true;
      renderer.shadowMap.type = THREE.PCFSoftShadowMap;
      renderer.outputEncoding = THREE.sRGBEncoding;
      renderer.toneMapping = THREE.ACESFilmicToneMapping;
      renderer.toneMappingExposure = 0.82;
      host.appendChild(renderer.domElement);
      S.renderer = renderer;

      // Release the WebGL context on navigate-away/refresh. Without this,
      // rapid reloads exhaust the browser's context pool, `init()` then fails
      // to get a context, and the intro silently falls back to a plain
      // fade-in with no scroll. Freeing it here keeps every reload fresh.
      const releaseGL = () => {
        try {
          renderer.forceContextLoss();
          renderer.dispose();
        } catch (e) {
          /* nothing to do */
        }
      };
      window.addEventListener("pagehide", releaseGL);

      const scene = new THREE.Scene();
      S.scene = scene;
      const camera = new THREE.PerspectiveCamera(40, W / H, 0.1, 100);
      camera.position.set(0, 0, 9.6);
      S.camera = camera;

      const envTex = makeEnvTexture(THREE);
      const pmrem = new THREE.PMREMGenerator(renderer);
      const envRT = pmrem.fromEquirectangular(envTex);
      scene.environment = envRT.texture;
      envTex.dispose();
      pmrem.dispose();

      scene.add(new THREE.HemisphereLight(0xfffaf0, 0xb9b09c, 0.42));
      // Light from the front, a touch upper-left of camera — each object
      // throws a soft shadow straight back onto the plane behind it (offset
      // just slightly down-right), exactly as in the sketch.
      const key = new THREE.DirectionalLight(0xfff4e2, 1.02);
      // Kept fairly frontal (only slightly upper-left) so each object throws a
      // TIGHT soft shadow just behind it, instead of a far-offset ghost copy.
      key.position.set(-0.9, 1.3, 8.5);
      key.castShadow = true;
      // High-res shadow map over a frustum wide enough to cover the WHOLE page
      // in world units (the viewport is wider than tall, and objects fall/land
      // right to the edges + bottom) — otherwise a fallen needle/thread/bead at
      // the rim would fall outside the frustum and its shadow would clip/mask.
      key.shadow.mapSize.set(4096, 4096);
      key.shadow.camera.near = 0.5;
      key.shadow.camera.far = 26;
      // The left/right/top/bottom extents are set responsively by
      // fitShadowFrustum() (called after updateBounds, and again on resize) so
      // the shadow map always covers the full viewport at any aspect ratio.
      key.shadow.bias = -0.0003;
      key.shadow.radius = 14;
      scene.add(key);
      S.keyLight = key;
      const fill = new THREE.DirectionalLight(0xeae6f0, 0.4);
      fill.position.set(3, 1.5, 4);
      scene.add(fill);
      const rim = new THREE.DirectionalLight(0xffffff, 0.2);
      rim.position.set(2.5, -1, -4);
      scene.add(rim);

      // Invisible catcher plane directly BEHIND the objects — the cast
      // shadow lands right behind the button and thread, not on a floor.
      const shadowMat = new THREE.ShadowMaterial({ opacity: SHADOW });
      const backPlane = new THREE.Mesh(new THREE.PlaneGeometry(60, 60), shadowMat);
      // Set well back from the objects so the (slightly upper-left) key light
      // throws a soft shadow that OFFSETS down-right with real distance — a
      // believable drop shadow with depth, not a flat grey ring hugging the
      // silhouette on every side.
      backPlane.position.set(0, 0, -1.3);
      backPlane.receiveShadow = true;
      scene.add(backPlane);
      S.shadowFloor = backPlane;

      const heroGroup = new THREE.Group();
      scene.add(heroGroup);
      S.heroGroup = heroGroup;
      heroGroup.rotation.x = -0.02;
      heroGroup.rotation.y = 0.0;
      heroGroup.scale.setScalar(0.5);

      buildButton(THREE, heroGroup);
      buildNeedle(THREE, heroGroup);
      scene.updateMatrixWorld(true);
      buildThreadAndBeads(THREE);

      S.phase = "idle";
      S.clock = new THREE.Clock();
      S.needleBase = S.needle.position.clone();
      updateBounds();
      fitShadowFrustum();

      // Pull hint: a soft pulsing halo that marks the needle's eye as the grab
      // point. A radial-gradient sprite in the thread's warm red; it rides the
      // eye and fades away the moment the user first interacts.
      {
        const gc = document.createElement("canvas");
        gc.width = gc.height = 128;
        const g2 = gc.getContext("2d")!;
        // A soft red RING (transparent centre) so it frames the eye and reads
        // clearly on the pale background instead of washing out.
        const grd = g2.createRadialGradient(64, 64, 0, 64, 64, 64);
        grd.addColorStop(0.0, "rgba(190,63,58,0.0)");
        grd.addColorStop(0.5, "rgba(190,63,58,0.06)");
        grd.addColorStop(0.72, "rgba(178,55,50,0.62)");
        grd.addColorStop(0.86, "rgba(178,55,50,0.28)");
        grd.addColorStop(1.0, "rgba(178,55,50,0.0)");
        g2.fillStyle = grd;
        g2.fillRect(0, 0, 128, 128);
        const gtex = new THREE.CanvasTexture(gc);
        gtex.encoding = THREE.sRGBEncoding;
        const glow = new THREE.Sprite(
          new THREE.SpriteMaterial({ map: gtex, transparent: true, opacity: 0, depthTest: false, depthWrite: false })
        );
        glow.scale.set(0.85, 0.85, 1);
        glow.renderOrder = 30;
        heroGroup.add(glow);
        S.eyeGlow = glow;
      }

      const onResize = () => {
        const w = window.innerWidth,
          h = window.innerHeight;
        renderer.setSize(w, h);
        camera.aspect = w / h;
        camera.updateProjectionMatrix();
        updateBounds();
        fitShadowFrustum();
      };
      window.addEventListener("resize", onResize);

      const animate = () => {
        requestAnimationFrame(animate);
        frame();
      };
      animate();

      if (location.search.includes("debugfall")) {
        setTimeout(() => {
          reveal();
          S.p = 0.6;
          S.phase = "completing";
        }, 500);
        if (location.search.includes("tobottom")) {
          setTimeout(() => {
            const b = document.body.scrollHeight;
            (window as any).__lenis?.scrollTo?.(b, { immediate: true, force: true });
            window.scrollTo(0, b);
          }, 7000);
        }
      }
    }

    wireDrag();
    waitForThree(() => {
      try {
        init();
      } catch (e) {
        console.error("[needle] init failed", e);
        reveal();
      }
    });
  })();
</script>

<script>
  // Flowing-watercolor background for the opening landing view. A fullscreen
  // shader takes the watercolor photo and makes its darker pigment swirl/bloom
  // like ink in water — perpetually, seamlessly (the noise field evolves with
  // time, so there is never a reset). White paper stays calm (flow is masked by
  // darkness); a faint luminance-based light term gives the moving pigment a
  // subtle 3D shimmer. Sits behind everything, kept soft so the hero leads.
  (() => {
    const host = document.getElementById("nl-watercolor");
    if (!host) return;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const vertexShader = `
      varying vec2 vUv;
      void main(){ vUv = uv; gl_Position = vec4(position.xy, 0.0, 1.0); }
    `;
    const fragmentShader = `
      precision highp float;
      varying vec2 vUv;
      uniform float uTime, uStrength, uSpeed, uIntensity;
      uniform sampler2D uTex;
      uniform vec2 uCover;
      float hash(vec2 p){ p = fract(p*vec2(123.34,456.21)); p += dot(p,p+45.32); return fract(p.x*p.y); }
      float vnoise(vec2 p){
        vec2 i = floor(p), f = fract(p);
        vec2 u = f*f*(3.0-2.0*f);
        float a=hash(i), b=hash(i+vec2(1.0,0.0)), c=hash(i+vec2(0.0,1.0)), d=hash(i+vec2(1.0,1.0));
        return mix(mix(a,b,u.x), mix(c,d,u.x), u.y);
      }
      float fbm(vec2 p){ float s=0.0,a=0.5; for(int i=0;i<4;i++){ s+=a*vnoise(p); p*=2.02; a*=0.5; } return s; }
      float lum(vec3 c){ return dot(c, vec3(0.299,0.587,0.114)); }
      vec2 coverUv(vec2 uv){ return (uv-0.5)*uCover + 0.5; }
      // Sample the texture advected along a molten flow field, at a given phase
      // of the drift cycle.
      vec3 sampleFlow(vec2 uv, vec2 dir, float amt){
        return texture2D(uTex, clamp(coverUv(uv - dir * amt), 0.0, 1.0)).rgb;
      }
      void main(){
        float t = uTime * uSpeed;
        vec2 p = vUv * 2.4;
        // A slow, curling flow field: mostly creeping downward-right, warped by
        // evolving noise so the red channels wander like molten lava.
        float n1 = fbm(p + vec2(0.0, -t * 0.6));
        float n2 = fbm(p + vec2(4.3, 1.9) - t * 0.5);
        vec2 dir = normalize(vec2(0.35, 1.0) + (vec2(n1, n2) - 0.5) * 1.6);

        vec3 base = texture2D(uTex, clamp(coverUv(vUv), 0.0, 1.0)).rgb;
        float darkMask = smoothstep(0.98, 0.45, lum(base)); // red pigment=1, paper=0
        float amp = uStrength * darkMask; // only the pigment flows; paper stays

        // Dual-phase advection: two drift cycles a half-period apart, cross-faded
        // so the flow is continuous and seamless — never a visible reset/jump.
        float ph1 = fract(t);
        float ph2 = fract(t + 0.5);
        float w = abs(1.0 - 2.0 * ph1);
        vec3 col = mix(sampleFlow(vUv, dir, ph1 * amp), sampleFlow(vUv, dir, ph2 * amp), w);

        // Molten shimmer: light the flowing pigment by its own luminance slope so
        // ridges catch light and creep like lava, giving a 3D sense.
        vec2 off = dir * mix(ph1, ph2, w) * amp;
        float e = 0.0016;
        float lx = lum(texture2D(uTex, clamp(coverUv(vUv+off+vec2(e,0.0)),0.,1.)).rgb)
                 - lum(texture2D(uTex, clamp(coverUv(vUv+off-vec2(e,0.0)),0.,1.)).rgb);
        float ly = lum(texture2D(uTex, clamp(coverUv(vUv+off+vec2(0.0,e)),0.,1.)).rgb)
                 - lum(texture2D(uTex, clamp(coverUv(vUv+off-vec2(0.0,e)),0.,1.)).rgb);
        vec3 nrm = normalize(vec3(-lx*7.0, -ly*7.0, 1.0));
        float light = 0.5 + 0.5*dot(nrm, normalize(vec3(0.3,0.4,0.85)));
        col *= mix(1.0, 0.72 + 0.5*light, 0.45*darkMask);

        float pigment = smoothstep(0.99, 0.5, lum(col)); // white paper -> transparent
        gl_FragColor = vec4(col, pigment * uIntensity);
      }
    `;

    let tries = 0;
    const boot = () => {
      const THREE = (window as any).THREE;
      if (!THREE) { if (tries++ < 200) setTimeout(boot, 25); return; }
      const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
      host.appendChild(renderer.domElement);
      const scene = new THREE.Scene();
      const cam = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);
      const uniforms: any = {
        uTime: { value: 0 },
        uTex: { value: null },
        uCover: { value: new THREE.Vector2(1, 1) },
        uStrength: { value: 0.15 }, // molten creep distance — visibly flowing
        uSpeed: { value: 0.26 }, // flow speed (slow, viscous like lava)
        uIntensity: { value: 0.72 }, // pigment opacity
      };
      const mat = new THREE.ShaderMaterial({
        uniforms,
        vertexShader,
        fragmentShader,
        transparent: true,
        depthTest: false,
        depthWrite: false,
      });
      scene.add(new THREE.Mesh(new THREE.PlaneGeometry(2, 2), mat));
      let imgAspect = 1080 / 1620;
      const resize = () => {
        // Match the fixed inset:0 host (the true laid-out viewport), NOT
        // window.innerHeight. On mobile the browser UI makes innerHeight smaller
        // than the viewport the fixed host actually fills, so sizing to
        // innerHeight left the canvas short and a strip of the flat page
        // background (#ece8dc) showed through at the bottom — the grey band you
        // saw when scrolling the landing page. The <canvas> is kept at
        // 100%×100% by CSS; here we only size the drawing buffer to match it.
        const w = host.clientWidth || window.innerWidth;
        const h = host.clientHeight || window.innerHeight;
        renderer.setSize(w, h, false);
        const ca = w / h;
        uniforms.uCover.value.set(ca < imgAspect ? ca / imgAspect : 1, ca > imgAspect ? imgAspect / ca : 1);
      };
      new THREE.TextureLoader().load("/images/landing/watercolor-bg.png", (tex: any) => {
        tex.minFilter = THREE.LinearFilter;
        tex.magFilter = THREE.LinearFilter;
        tex.wrapS = tex.wrapT = THREE.ClampToEdgeWrapping;
        if (tex.image && tex.image.width) imgAspect = tex.image.width / tex.image.height;
        uniforms.uTex.value = tex;
        resize();
        renderer.render(scene, cam);
      });
      window.addEventListener("resize", resize);
      resize();
      const t0 = performance.now();
      let running = !reduce;
      const loop = () => {
        if (!running) return;
        // Intro only: stop once the site is revealed (CSS fades it out).
        if (document.documentElement.classList.contains("nl-revealed")) { running = false; return; }
        requestAnimationFrame(loop);
        uniforms.uTime.value = (performance.now() - t0) / 1000;
        if (uniforms.uTex.value) renderer.render(scene, cam);
      };
      if (!reduce) loop();
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) running = false;
        else if (!reduce) { running = true; loop(); }
      });
    };
