---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/cards/ProjectCard.astro";
import { getOrderedSegments } from "../data/segments";
import { getProjectsBySegment } from "../data/projects";

const segments = getOrderedSegments();
const streetwearProjects = getProjectsBySegment("streetwear");
const beadAssets = [
  "b13.png",
  "b7.png",
  "b6.png",
  "b11.png",
  "b10.png",
  "b8.png",
  "b4.png",
  "b11.png",
  "b5.png",
  "b7.png",
  "b12.png",
  "b6.png",
  "b3.png",
  "b13.png",
  "b5.png",
];
---

<BaseLayout title="Girisha Suri -- Fashion Design Portfolio">
  <script is:inline>
    document.documentElement.classList.add("ct-intro-active");
  </script>

  <div id="ct-root">
    <div class="ct-paper" aria-hidden="true"></div>
    <div class="ct-vignette" aria-hidden="true"></div>

    <div class="ct-stage" aria-hidden="true">
      <svg class="ct-thread-svg" aria-hidden="true">
        <path class="ct-thread-path" d="" fill="none" />
      </svg>

      <div class="ct-needle">
        <svg width="360" height="34" viewBox="0 0 360 34" aria-hidden="true">
          <defs>
            <linearGradient id="ct-steel" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="#fbfbfc" />
              <stop offset=".28" stop-color="#cfd0d4" />
              <stop offset=".5" stop-color="#8d8e95" />
              <stop offset=".62" stop-color="#6c6d74" />
              <stop offset=".8" stop-color="#a9aab0" />
              <stop offset="1" stop-color="#e7e8ea" />
            </linearGradient>
          </defs>
          <path d="M2,17 L300,9.5 Q322,9 332,10.5 Q352,13 352,17 Q352,21 332,23.5 Q322,25 300,24.5 Z" fill="url(#ct-steel)" />
          <ellipse cx="326" cy="17" rx="5.4" ry="8.6" fill="#efeae0" stroke="#5e5f66" stroke-width="1.1" />
          <path d="M2,17 L300,9.5 L300,24.5 Z" fill="url(#ct-steel)" />
        </svg>
      </div>

      <img class="ct-button" src="/images/landing/crystal/button.png" alt="" />
    </div>

    <div class="ct-beads" aria-hidden="true">
      {beadAssets.map((asset) => (
        <img class="ct-bead" src={`/images/landing/crystal/${asset}`} alt="" />
      ))}
    </div>

    <main id="ct-content">
      <header class="ct-hero">
        <p class="ct-kicker">Commercial discipline / Couture finishing</p>
        <h1>Girisha Suri</h1>
        <p class="ct-tagline">
          A fashion-design portfolio where the surface carries the idea and the construction stays honest,
          built across streetwear, ethnic, and the spaces between.
        </p>
        <p class="ct-scroll-cue">Scroll to explore</p>
      </header>

      <section class="ct-segments" aria-label="Work by segment">
        <p class="ct-section-label">The work -- by segment</p>
        <ul class="ct-segment-list">
          {segments.map((segment, index) => (
            <li>
              <a href={`/work/${segment.slug}`}>
                <span class="ct-segment-num">{String(index + 1).padStart(2, "0")}</span>
                <span class="ct-segment-copy">
                  <span class="ct-segment-name">{segment.name}</span>
                  <span class="ct-segment-blurb">{segment.blurb}</span>
                </span>
                <span class="ct-segment-arrow" aria-hidden="true">-&gt;</span>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <section class="ct-projects" aria-label="Streetwear projects">
        <div class="ct-projects-header">
          <h2>Streetwear</h2>
          <span>{String(streetwearProjects.length).padStart(2, "0")} -- Selected</span>
        </div>
        <ul class="ct-project-grid">
          {streetwearProjects.map((project) => (
            <ProjectCard project={project} />
          ))}
        </ul>
      </section>

      <footer class="ct-page-footer">
        <p>"Let the surface carry the idea."</p>
        <span>Girisha Suri / Portfolio</span>
      </footer>
    </main>
  </div>
</BaseLayout>

<script>
  (() => {
    const root = document.getElementById("ct-root");
    if (!root) return;

    const html = document.documentElement;
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const stage = root.querySelector(".ct-stage") as HTMLElement | null;
    const beadLayer = root.querySelector(".ct-beads") as HTMLElement | null;
    const button = root.querySelector(".ct-button") as HTMLImageElement | null;
    const needle = root.querySelector(".ct-needle") as HTMLElement | null;
    const thread = root.querySelector(".ct-thread-path") as SVGPathElement | null;
    const content = root.querySelector("#ct-content") as HTMLElement | null;
    const beadEls = Array.from(root.querySelectorAll(".ct-bead")) as HTMLImageElement[];

    if (reduceMotion || !stage || !beadLayer || !button || !needle || !thread || !content || !beadEls.length) {
      html.classList.remove("ct-intro-active");
      html.classList.add("ct-revealed");
      if (stage) stage.hidden = true;
      if (beadLayer) beadLayer.hidden = true;
      return;
    }

    const stageEl = stage;
    const buttonEl = button;
    const needleEl = needle;
    const threadEl = thread;
    const contentEl = content;

    const cfg = [
      { w: 22, ax: 135, ay: -46, rot: 0, strand: true },
      { w: 46, ax: 150, ay: -16, rot: 38, strand: true },
      { w: 31, ax: 162, ay: 16, rot: 0, strand: true },
      { w: 21, ax: 170, ay: 44, rot: 0, strand: true },
      { w: 44, ax: 176, ay: 74, rot: 18, strand: true },
      { w: 27, ax: 181, ay: 102, rot: 0, strand: true },
      { w: 40, ax: 184, ay: 132, rot: 82, strand: true },
      { w: 19, ax: 186, ay: 158, rot: 0, strand: true },
      { w: 33, ax: 187, ay: 186, rot: 0, strand: true },
      { w: 31, ax: 188, ay: 212, rot: 68, strand: true },
      { w: 36, ax: 189, ay: 244, rot: 0, strand: true },
      { w: 27, ax: 118, ay: 58, rot: 0, strand: false },
      { w: 48, ax: 92, ay: 30, rot: 12, strand: false },
      { w: 20, ax: 150, ay: 116, rot: 0, strand: false },
      { w: 29, ax: 206, ay: 150, rot: 30, strand: false },
    ];

    const state = {
      vw: window.innerWidth,
      vh: window.innerHeight,
      scale: 1,
      origin: { x: 0, y: 0 },
      eye: { x: 0, y: 0 },
      start: performance.now(),
      last: performance.now(),
      phase: "idle",
      pullAt: 1500,
      revealAt: 0,
      revealing: false,
      done: false,
      scrollVel: 0,
      lastScroll: window.scrollY || window.pageYOffset || 0,
      targets: {} as Record<number, number>,
    };

    const beads = beadEls.map((el, index) => {
      const beadCfg = cfg[index] || cfg[0];
      return {
        el,
        cfg: beadCfg,
        x: 0,
        y: 0,
        vx: 0,
        vy: 0,
        rot: beadCfg.rot,
        vrot: 0,
        released: false,
        settled: false,
        delay: 0,
        w: 0,
        h: 0,
        natW: el.naturalWidth || 40,
        natH: el.naturalHeight || 40,
      };
    });

    beads.forEach((bead) => {
      if (!bead.el.complete) {
        bead.el.addEventListener("load", () => {
          bead.natW = bead.el.naturalWidth || bead.natW;
          bead.natH = bead.el.naturalHeight || bead.natH;
          measure();
        }, { once: true });
      }
    });

    function measure() {
      state.vw = window.innerWidth;
      state.vh = window.innerHeight;
      state.scale = Math.min(1.18, Math.max(0.58, state.vw / 1080));
      state.origin = { x: state.vw * 0.47, y: state.vh * 0.43 };
      state.eye = {
        x: state.origin.x + 150 * state.scale,
        y: state.origin.y - 58 * state.scale,
      };

      buttonEl.style.width = `${250 * state.scale}px`;
      beads.forEach((bead) => {
        bead.w = bead.cfg.w * state.scale * 1.06;
        bead.h = bead.w * (bead.natH / bead.natW);
        bead.el.style.width = `${bead.w}px`;
      });
    }

    function beadAnchor(bead: typeof beads[number], sway: number) {
      const ox = state.origin.x + bead.cfg.ax * state.scale - state.eye.x;
      const oy = state.origin.y + bead.cfg.ay * state.scale - state.eye.y;
      const c = Math.cos(sway);
      const s = Math.sin(sway);
      return {
        x: state.eye.x + ox * c - oy * s,
        y: state.eye.y + ox * s + oy * c,
      };
    }

    function easeInOut(t: number) {
      return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
    }

    function startPull(elapsed: number) {
      state.phase = "pulling";
      const strand = beads.filter((bead) => bead.cfg.strand);
      const loose = beads.filter((bead) => !bead.cfg.strand);
      strand.forEach((bead, index) => {
        bead.delay = 380 + (strand.length - 1 - index) * 95;
      });
      loose.forEach((bead, index) => {
        bead.delay = 520 + index * 120;
      });

      const order = beads.map((_, index) => index).sort(() => Math.random() - 0.5);
      order.forEach((id, rank) => {
        state.targets[id] = state.vw * (0.1 + 0.8 * (rank / Math.max(1, beads.length - 1)));
      });
      state.revealAt = elapsed + 1650;
    }

    function release(bead: typeof beads[number]) {
      bead.released = true;
      const index = beads.indexOf(bead);
      const targetX = state.targets[index] ?? state.vw * Math.random();
      bead.vx = (targetX - bead.x) * (0.7 + Math.random() * 0.6) + (Math.random() - 0.5) * 60;
      bead.vy = -30 - Math.random() * 80;
      bead.vrot = (Math.random() - 0.5) * 320;
    }

    function integrate(bead: typeof beads[number], dt: number, time: number) {
      const gravity = 1850;
      bead.vy += gravity * dt;
      bead.x += bead.vx * dt;
      bead.y += bead.vy * dt;
      bead.rot += bead.vrot * dt;

      const floor = state.vh - 14 * state.scale - bead.h * 0.42;
      if (bead.y > floor) {
        bead.y = floor;
        if (bead.vy > 0) bead.vy = -bead.vy * 0.26;
        bead.vx *= 0.72;
        bead.vrot *= 0.4;
        if (Math.abs(bead.vy) < 80) {
          bead.vy = 0;
          bead.settled = true;
        }
        bead.rot -= (bead.vx / Math.max(bead.w, 16)) * dt * 40;
      } else {
        bead.settled = false;
      }

      const margin = bead.w * 0.42;
      if (bead.x < margin) {
        bead.x = margin;
        bead.vx = Math.abs(bead.vx) * 0.4;
      }
      if (bead.x > state.vw - margin) {
        bead.x = state.vw - margin;
        bead.vx = -Math.abs(bead.vx) * 0.4;
      }
      if (bead.settled) {
        bead.vx *= 0.9;
        bead.vx += Math.sin(time * 0.8 + bead.x * 0.01) * 1.4 * dt * 60 * 0.02;
        bead.x += bead.vx * dt;
        if (bead.x < margin) bead.x = margin;
        if (bead.x > state.vw - margin) bead.x = state.vw - margin;
      }
    }

    function separate() {
      for (let i = 0; i < beads.length; i++) {
        const a = beads[i];
        if (!a.released) continue;
        for (let j = i + 1; j < beads.length; j++) {
          const b = beads[j];
          if (!b.released) continue;
          const dx = b.x - a.x;
          const dy = b.y - a.y;
          const distance = Math.hypot(dx, dy) || 0.001;
          const min = (a.w + b.w) * 0.42;
          if (distance < min) {
            const overlap = (min - distance) / 2;
            const nx = dx / distance;
            const ny = dy / distance;
            a.x -= nx * overlap;
            a.y -= ny * overlap;
            b.x += nx * overlap;
            b.y += ny * overlap;
          }
        }
      }
    }

    function beginReveal(elapsed: number) {
      if (!state.revealing) {
        state.revealing = true;
        html.classList.remove("ct-intro-active");
        html.classList.add("ct-revealing");
        contentEl.style.opacity = "0";
        contentEl.style.pointerEvents = "none";
        stageEl.style.opacity = "1";
      }

      const progress = Math.min(1, (elapsed - state.revealAt) / 1200);
      contentEl.style.opacity = String(progress);
      stageEl.style.opacity = String(1 - progress);

      if (progress >= 1 && !state.done) {
        state.done = true;
        html.classList.remove("ct-revealing");
        html.classList.add("ct-revealed");
        stageEl.hidden = true;
        contentEl.style.opacity = "";
        contentEl.style.pointerEvents = "";
        const lenis = (window as any).__lenis;
        lenis?.resize?.();
        window.dispatchEvent(new Event("resize"));
      }
    }

    function frame(now: number) {
      const elapsed = now - state.start;
      const dt = Math.min(0.034, (now - state.last) / 1000);
      state.last = now;
      const time = elapsed / 1000;

      if (state.phase === "idle" && elapsed > state.pullAt) startPull(elapsed);

      const sway = Math.sin(time * 0.55) * 0.05 + Math.sin(time * 0.93) * 0.018;
      const bx = state.origin.x;
      const by = state.origin.y + Math.sin(time * 0.6) * 3 * state.scale;
      let buttonRot = Math.sin(time * 0.4) * 1.3;
      if (state.phase !== "idle") {
        buttonRot += easeInOut(Math.min(1, (elapsed - state.pullAt) / 2400)) * 26;
      }
      buttonEl.style.transform = `translate(${bx}px,${by}px) translate(-50%,-50%) rotate(${buttonRot}deg)`;

      let needlePull = 0;
      let needleFade = 1;
      if (state.phase !== "idle") {
        const pullEase = easeInOut(Math.min(1, (elapsed - state.pullAt) / 1700));
        needlePull = pullEase * 540 * state.scale;
        if (elapsed - state.pullAt > 1300) {
          needleFade = Math.max(0, 1 - (elapsed - state.pullAt - 1300) / 600);
        }
      }
      const angle = -18 * Math.PI / 180;
      const dx = Math.cos(angle) * needlePull;
      const dy = Math.sin(angle) * needlePull;
      const needleScale = state.scale * 0.74;
      needleEl.style.opacity = String(needleFade);
      needleEl.style.transform = `translate(${state.eye.x + dx}px,${state.eye.y + dy}px) rotate(-18deg) translate(${-326 * needleScale}px, ${-17 * needleScale}px) scale(${needleScale})`;

      const strandPoints: Array<[number, number]> = [];
      const releasing = state.phase !== "idle";
      for (const bead of beads) {
        if (!bead.released) {
          const anchor = beadAnchor(bead, sway);
          bead.x = anchor.x;
          bead.y = anchor.y;
          if (bead.cfg.strand) strandPoints.push([anchor.x, anchor.y]);
          if (releasing && elapsed - state.pullAt > bead.delay) release(bead);
        } else {
          integrate(bead, dt, time);
        }
        bead.el.style.transform = `translate(${bead.x}px,${bead.y}px) translate(-50%,-50%) rotate(${bead.rot}deg)`;
      }

      if (releasing) separate();

      if (state.phase === "idle" || (releasing && elapsed - state.pullAt < 500)) {
        let d = `M ${state.eye.x} ${state.eye.y}`;
        strandPoints.forEach((point) => {
          d += ` L ${point[0]} ${point[1]}`;
        });
        threadEl.setAttribute("d", d);
        if (releasing) {
          threadEl.setAttribute("opacity", String(Math.max(0, 0.82 * (1 - (elapsed - state.pullAt) / 500))));
        }
      } else if (releasing) {
        threadEl.setAttribute("opacity", "0");
      }

      if (state.revealAt && elapsed > state.revealAt) beginReveal(elapsed);

      if (Math.abs(state.scrollVel) > 0.1) {
        const push = -state.scrollVel * 0.06;
        beads.forEach((bead) => {
          if (bead.settled) bead.vx += push * (0.6 + Math.random() * 0.5);
        });
        state.scrollVel *= 0.82;
        if (Math.abs(state.scrollVel) < 0.4) state.scrollVel = 0;
      }

      requestAnimationFrame(frame);
    }

    window.addEventListener("resize", measure);
    window.addEventListener("scroll", () => {
      const current = window.scrollY || window.pageYOffset || 0;
      state.scrollVel += current - state.lastScroll;
      state.lastScroll = current;
    }, { passive: true });

    measure();
    requestAnimationFrame(frame);
  })();
</script>

<style is:global>
  html.ct-intro-active,
  html.ct-intro-active body {
    overflow: hidden;
  }

  html.ct-intro-active .site-header,
  html.ct-intro-active .site-footer {
    opacity: 0;
    pointer-events: none;
  }

  html.ct-revealed .site-header,
  html.ct-revealed .site-footer {
    opacity: 1;
    pointer-events: auto;
    transition: opacity 0.8s ease 0.3s;
  }

  html.ct-intro-active #ct-content {
    opacity: 0;
    pointer-events: none;
  }

  @keyframes ct-cue {
    0%,
    100% {
      opacity: 0.32;
      transform: translateY(0);
    }
    50% {
      opacity: 0.85;
      transform: translateY(5px);
    }
  }

  #ct-root {
    position: relative;
    min-height: 100vh;
    overflow-x: hidden;
    background: #f0ece2;
    color: #221f1a;
  }

  .ct-paper,
  .ct-vignette {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .ct-paper {
    background: radial-gradient(120% 100% at 50% 18%, #f7f4ec 0%, #efeae0 46%, #e6e0d3 100%);
  }

  .ct-vignette {
    opacity: 0.5;
    background:
      radial-gradient(70% 55% at 50% 42%, rgba(255, 255, 255, 0.5) 0%, rgba(255, 255, 255, 0) 60%),
      radial-gradient(130% 120% at 50% 60%, rgba(0, 0, 0, 0) 52%, rgba(74, 64, 48, 0.13) 100%);
  }

  .ct-stage {
    position: fixed;
    inset: 0;
    z-index: 30;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition: opacity 1.2s var(--ease-thread), visibility 0s linear 1.2s;
  }

  html.ct-intro-active .ct-stage,
  html.ct-revealing .ct-stage {
    opacity: 1;
    visibility: visible;
    transition-delay: 0s;
  }

  .ct-thread-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .ct-thread-path {
    stroke: #7c1f28;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
    opacity: 0.82;
  }

  .ct-needle {
    position: absolute;
    left: 0;
    top: 0;
    transform-origin: center;
    will-change: transform;
    filter: drop-shadow(0 5px 7px rgba(60, 50, 35, 0.28));
  }

  .ct-button {
    position: absolute;
    left: 0;
    top: 0;
    width: 250px;
    height: auto;
    max-width: none;
    transform-origin: center;
    will-change: transform;
    filter:
      drop-shadow(0 18px 26px rgba(70, 58, 40, 0.34))
      drop-shadow(0 4px 8px rgba(70, 58, 40, 0.2));
  }

  .ct-beads {
    position: fixed;
    inset: 0;
    z-index: 36;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
  }

  html.ct-intro-active .ct-beads,
  html.ct-revealing .ct-beads,
  html.ct-revealed .ct-beads {
    opacity: 1;
    visibility: visible;
  }

  .ct-beads[hidden],
  .ct-stage[hidden] {
    display: none;
  }

  .ct-bead {
    position: absolute;
    left: 0;
    top: 0;
    max-width: none;
    height: auto;
    will-change: transform;
    filter: drop-shadow(0 4px 5px rgba(80, 20, 28, 0.32));
  }

  #ct-content {
    position: relative;
    z-index: 20;
    opacity: 1;
    transition: opacity 1.1s var(--ease-thread);
  }

  .ct-hero {
    min-height: 92svh;
    max-width: var(--max-width-content);
    margin: 0 auto;
    padding: 12vh var(--page-gutter) 8vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .ct-kicker,
  .ct-section-label,
  .ct-page-footer span {
    font-size: 12px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #9a9286;
  }

  .ct-kicker {
    margin-bottom: 22px;
  }

  .ct-hero h1 {
    margin: 0;
    font-family: var(--font-display);
    font-variation-settings: var(--fv-hero);
    font-size: clamp(3.2rem, 10vw, 8rem);
    line-height: 0.98;
    color: #221f1a;
  }

  .ct-tagline {
    margin-top: 26px;
    max-width: 31rem;
    font-size: 1.08rem;
    line-height: 1.65;
    color: #6c655a;
  }

  .ct-scroll-cue {
    margin-top: 52px;
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #b3aa9c;
    animation: ct-cue 2.8s ease-in-out infinite;
  }

  .ct-segments,
  .ct-projects,
  .ct-page-footer {
    max-width: 70rem;
    margin: 0 auto;
    padding-inline: var(--page-gutter);
  }

  .ct-segments {
    padding-top: 6vh;
    padding-bottom: 12vh;
  }

  .ct-section-label {
    margin-bottom: 36px;
  }

  .ct-segment-list {
    border-top: 1px solid rgba(124, 31, 40, 0.18);
  }

  .ct-segment-list li {
    border-bottom: 1px solid rgba(124, 31, 40, 0.18);
  }

  .ct-segment-list a {
    display: grid;
    grid-template-columns: 3rem minmax(0, 1fr) auto;
    align-items: baseline;
    gap: 16px 20px;
    padding: 30px 6px;
    text-decoration: none;
    color: inherit;
  }

  .ct-segment-num {
    font-family: var(--font-display);
    font-size: 0.82rem;
    color: #b1a899;
  }

  .ct-segment-copy {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
  }

  .ct-segment-name {
    width: fit-content;
    font-family: var(--font-display);
    font-variation-settings: var(--fv-h2);
    font-size: clamp(1.55rem, 3.6vw, 2.55rem);
    line-height: 1.08;
    color: #221f1a;
    position: relative;
  }

  .ct-segment-name::after {
    content: "";
    position: absolute;
    left: 0;
    right: 100%;
