---
import BaseLayout from "../layouts/BaseLayout.astro";
import SegmentCard from "../components/cards/SegmentCard.astro";
import ProjectCard from "../components/cards/ProjectCard.astro";
import { getOrderedSegments } from "../data/segments";
import { getProjectsBySegment } from "../data/projects";

const segments = getOrderedSegments();
const streetwearProjects = getProjectsBySegment("streetwear");
---

<BaseLayout title="Girisha Suri — Fashion Design Portfolio">
  <script slot="head" is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

  <div id="nl-root">

    <div id="nl-spotlight"></div>
    <div id="nl-canvas-host"></div>

    <div id="nl-gate">
      <div id="nl-gate-inner">
        <p class="nl-gate-label">Girisha Suri — Fashion Design</p>
        <form id="nl-form" autocomplete="off" class="nl-form">
          <span class="nl-prompt-arrow" aria-hidden="true">›</span>
          <input
            id="nl-input"
            type="text"
            spellcheck="false"
            placeholder="type a command to begin"
            aria-label="Enter a command to begin"
          />
        </form>
        <p id="nl-hint" class="nl-hint">
          try: <span class="nl-hint-phrase">pull the needle out</span>
        </p>
      </div>
    </div>

    <main id="nl-content">

      <header class="nl-hero-header">
        <p class="nl-kicker">Commercial discipline · Couture finishing</p>
        <h1 class="nl-hero-title">Girisha Suri</h1>
        <p class="nl-hero-tagline">
          Built across streetwear, evening wear, and the spaces between —
          where the surface carries the idea and the construction stays honest.
        </p>
        <p class="nl-scroll-cue">Scroll to explore</p>
      </header>

      <section class="nl-segments-section" aria-label="Work by segment">
        <p class="nl-section-eyebrow">The work</p>
        <ul class="nl-segment-list">
          {segments.map((segment, index) => (
            <SegmentCard segment={segment} index={index} />
          ))}
        </ul>
      </section>

      <section class="nl-projects-section" aria-label="Streetwear projects">
        <div class="nl-projects-header">
          <h2 class="nl-projects-title">Streetwear</h2>
          <span class="nl-projects-count">02 — Selected</span>
        </div>
        <ul class="nl-project-grid">
          {streetwearProjects.map((project) => (
            <ProjectCard project={project} />
          ))}
        </ul>
      </section>

      <footer class="nl-page-footer">
        <p class="nl-footer-quote">"Let the surface carry the idea."</p>
        <p class="nl-footer-byline">Girisha Suri · Portfolio</p>
      </footer>

    </main>
  </div>
</BaseLayout>

<script>
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  // ─── helpers ───────────────────────────────────────────────────────────────

  function easeInOut(t: number) { return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2; }
  function easeOut(t: number) { return 1 - Math.pow(1 - t, 3); }

  function waitForThree(cb: () => void) {
    let tries = 0;
    const tick = () => {
      if ((window as any).THREE) return cb();
      if (tries++ > 200) { console.error("[needle] THREE.js failed to load from CDN"); return; }
      setTimeout(tick, 25);
    };
    tick();
  }

  // ─── state ─────────────────────────────────────────────────────────────────

  let renderer: any = null;
  let scene: any = null;
  let camera: any = null;
  let heroGroup: any = null;
  let needle: any = null;
  let button: any = null;
  let eyeLocal: any = null;
  let shadowFloor: any = null;
  let threadMesh: any = null;
  let threadMat: any = null;
  let nodes: Array<{ pos: any; prev: any }> = [];
  let beads: any[] = [];
  let phase = "idle";
  let pullT = 0;
  let released = false;
  let clock: any = null;
  let rafId = 0;
  let bounds = { halfH: 0, halfW: 0, floorY: 0 };
  let scrollVel = 0;
  let lastScroll = 0;
  const threadN = 26;
  const segLen = 0.062;

  // ─── env texture ───────────────────────────────────────────────────────────

  function makeEnvTexture(THREE: any) {
    const c = document.createElement("canvas"); c.width = 512; c.height = 256;
    const g = c.getContext("2d")!;
    const grad = g.createLinearGradient(0, 0, 0, 256);
    grad.addColorStop(0, "#fffdf7");
    grad.addColorStop(0.3, "#efe3cf");
    grad.addColorStop(0.55, "#c9bda8");
    grad.addColorStop(0.8, "#6f6655");
    grad.addColorStop(1, "#34302a");
    g.fillStyle = grad; g.fillRect(0, 0, 512, 256);
    const blobs: [string, number, number, number][] = [
      ["#ffe7c2", 120, 70, 90],
      ["#d8c2e6", 360, 90, 110],
      ["#c2e6d8", 250, 150, 120],
      ["#ffd6e0", 430, 180, 80],
    ];
    blobs.forEach(([col, x, y, r]) => {
      const rg = g.createRadialGradient(x, y, 0, x, y, r);
      rg.addColorStop(0, col); rg.addColorStop(1, "rgba(255,255,255,0)");
      g.globalAlpha = 0.55; g.fillStyle = rg; g.beginPath(); g.arc(x, y, r, 0, 7); g.fill();
    });
    g.globalAlpha = 1;
    const kg = g.createRadialGradient(150, 30, 0, 150, 30, 140);
    kg.addColorStop(0, "rgba(255,255,255,0.95)"); kg.addColorStop(1, "rgba(255,255,255,0)");
    g.fillStyle = kg; g.beginPath(); g.arc(150, 30, 140, 0, 7); g.fill();
    const tex = new THREE.CanvasTexture(c);
    tex.mapping = THREE.EquirectangularReflectionMapping;
    tex.encoding = THREE.sRGBEncoding;
    return tex;
  }

  // ─── pearl texture ─────────────────────────────────────────────────────────

  function makePearlTexture(THREE: any) {
    const c = document.createElement("canvas"); c.width = 512; c.height = 512;
    const g = c.getContext("2d")!;
    g.fillStyle = "#c2b291"; g.fillRect(0, 0, 512, 512);
    const dark = ["#7a6c50", "#5f5640", "#6d5d52", "#534a3c"];
    const light = ["#fff6e6", "#f3e8d2", "#e9eef6", "#efe0ee", "#d8ecdd", "#fbeccf"];
    for (let i = 0; i < 22; i++) {
      const x = Math.random() * 512, y = Math.random() * 512, r = 70 + Math.random() * 160;
      const rg = g.createRadialGradient(x, y, 0, x, y, r);
      rg.addColorStop(0, dark[i % dark.length]); rg.addColorStop(1, "rgba(0,0,0,0)");
      g.globalAlpha = 0.5; g.fillStyle = rg; g.beginPath(); g.arc(x, y, r, 0, 7); g.fill();
    }
    for (let i = 0; i < 30; i++) {
      const x = Math.random() * 512, y = Math.random() * 512, r = 50 + Math.random() * 150;
      const rg = g.createRadialGradient(x, y, 0, x, y, r);
      rg.addColorStop(0, light[i % light.length]); rg.addColorStop(1, "rgba(255,255,255,0)");
      g.globalAlpha = 0.55; g.fillStyle = rg; g.beginPath(); g.arc(x, y, r, 0, 7); g.fill();
    }
    g.globalAlpha = 1;
    const tex = new THREE.CanvasTexture(c);
    tex.encoding = THREE.sRGBEncoding;
    return tex;
  }

  // ─── geometry helpers ──────────────────────────────────────────────────────

  function biconeGeo(THREE: any, r: number, h: number) {
    return new THREE.ConeGeometry(r, h, 14, 1, false);
  }

  function teardropGeo(THREE: any, s: number) {
    const prof: any[] = [];
    const steps = 16;
    for (let i = 0; i <= steps; i++) {
      const t = i / steps;
      const y = (0.5 - t) * 2.2 * s;
      let r: number;
      if (t < 0.4) {
        r = Math.pow(t / 0.4, 1.5) * 0.85 * s;
      } else {
        const u = (t - 0.4) / 0.6;
        r = Math.sqrt(Math.max(0, 1 - (u - 1) * (u - 1))) * 0.9 * s;
      }
      prof.push(new THREE.Vector2(Math.max(0.002, r), y));
    }
    return new THREE.LatheGeometry(prof, 20);
  }

  function approxRadius(nodeIdx: number): number {
    const map: Record<number, number> = { 8: 0.085, 10: 0.05, 12: 0.075, 13: 0.06, 15: 0.04, 16: 0.075, 18: 0.055, 19: 0.034, 21: 0.058, 23: 0.06, 25: 0.1 };
    return map[nodeIdx] ?? 0.06;
  }

  // ─── build button ──────────────────────────────────────────────────────────

  function buildButton(THREE: any, group: any) {
    const R = 0.92, TH = 0.17;
    const geo = new THREE.CylinderGeometry(R, R, TH, 200, 6, false);
    const pos = geo.attributes.position;
    const v = new THREE.Vector3();
    for (let i = 0; i < pos.count; i++) {
      v.fromBufferAttribute(pos, i);
      const ang = Math.atan2(v.z, v.x);
      const rad = Math.hypot(v.x, v.z);
      const wave = 0.032 * Math.sin(3 * ang + 0.6) + 0.022 * Math.sin(5 * ang + 1.7) + 0.013 * Math.sin(8 * ang);
      const radial = 0.018 * Math.cos(rad * 6.2 + ang * 2.0);
      const k = Math.min(1, rad / (R * 0.4));
      if (Math.abs(v.y) > TH * 0.35) {
        v.y += (wave + radial) * (v.y > 0 ? 1 : 0.7) * k;
      }
      if (rad > R * 0.6) {
        const rr = 1 + 0.022 * Math.sin(4 * ang + 0.4) + 0.012 * Math.sin(7 * ang);
        v.x *= rr; v.z *= rr;
      }
      pos.setXYZ(i, v.x, v.y, v.z);
    }
    geo.computeVertexNormals();

    const colorTex = makePearlTexture(THREE);
    const mat = new THREE.MeshPhysicalMaterial({
      map: colorTex,
      color: 0xc4b291,
      metalness: 0.35, roughness: 0.48,
      clearcoat: 0.85, clearcoatRoughness: 0.26,
      envMapIntensity: 0.5, reflectivity: 0.7,
    });
    const btn = new THREE.Mesh(geo, mat);
    btn.rotation.x = Math.PI / 2;
    btn.castShadow = true; btn.receiveShadow = true;
    const wrap = new THREE.Group();
    wrap.add(btn);

    const holeMat = new THREE.MeshStandardMaterial({ color: 0x46402f, metalness: 0.2, roughness: 0.6 });
    [[0.06, 0.12], [0.06, -0.06]].forEach(([x, y]) => {
      const hole = new THREE.Mesh(new THREE.CylinderGeometry(0.045, 0.05, 0.09, 24), holeMat);
      hole.rotation.x = Math.PI / 2;
      hole.position.set(x, y, 0.05);
      wrap.add(hole);
    });
    group.add(wrap);
    button = wrap;
  }

  // ─── build needle ──────────────────────────────────────────────────────────

  function buildNeedle(THREE: any, group: any) {
    const ndl = new THREE.Group();
    const metal = new THREE.MeshStandardMaterial({ color: 0xcac4b4, metalness: 1.0, roughness: 0.32, envMapIntensity: 0.9 });
    const shaft = new THREE.Mesh(new THREE.CylinderGeometry(0.018, 0.026, 1.5, 20), metal);
    shaft.position.y = 0.05; shaft.castShadow = true; ndl.add(shaft);
    const tip = new THREE.Mesh(new THREE.ConeGeometry(0.026, 0.18, 20), metal);
    tip.position.y = -0.79; tip.castShadow = true; ndl.add(tip);
    const eye = new THREE.Mesh(new THREE.TorusGeometry(0.05, 0.016, 12, 28), metal);
    eye.position.y = 0.84; eye.scale.set(0.7, 1, 1); eye.castShadow = true; ndl.add(eye);
    const eyeCap = new THREE.Mesh(new THREE.SphereGeometry(0.03, 16, 12), metal);
    eyeCap.position.y = 0.92; ndl.add(eyeCap);

    ndl.position.set(0.6, 0.32, 0.12);
    ndl.rotation.z = -0.55;
    group.add(ndl);
    needle = ndl;
    eyeLocal = new THREE.Vector3(0.05 * 0.7, 0.84, 0);
  }

  function eyeWorld(THREE: any) {
    return needle.localToWorld(eyeLocal.clone());
  }

  // ─── build thread + beads ──────────────────────────────────────────────────

  function buildThreadAndBeads(THREE: any) {
    const anchor = eyeWorld(THREE);
    nodes = [];
    for (let i = 0; i < threadN; i++) {
      const p = new THREE.Vector3(anchor.x, anchor.y - segLen * i, anchor.z);
      nodes.push({ pos: p.clone(), prev: p.clone() });
    }

    threadMat = new THREE.MeshStandardMaterial({ color: 0x6e1620, roughness: 0.65, metalness: 0.0, transparent: true, opacity: 1 });
    rebuildThread(THREE);

    const crystalMat = () => new THREE.MeshPhysicalMaterial({
      color: 0x720811, emissive: 0x44040a, emissiveIntensity: 0.14,
      metalness: 0.0, roughness: 0.22, clearcoat: 0.35, clearcoatRoughness: 0.16,
      envMapIntensity: 0.15, reflectivity: 0.6, transparent: true, opacity: 0.97,
    });
    const mk = (geo: any, s: number) => {
      const m = new THREE.Mesh(geo, crystalMat()); m.castShadow = true; m.scale.setScalar(s * 1.6); return m;
    };
    const specs = [
      { node: 8,  geo: () => new THREE.IcosahedronGeometry(0.07, 0) },
      { node: 10, geo: () => new THREE.SphereGeometry(0.045, 20, 16) },
      { node: 12, geo: () => new THREE.CylinderGeometry(0.028, 0.028, 0.13, 14) },
      { node: 13, geo: () => new THREE.OctahedronGeometry(0.055, 0) },
      { node: 15, geo: () => new THREE.SphereGeometry(0.035, 18, 14) },
      { node: 16, geo: () => biconeGeo(THREE, 0.06, 0.12) },
      { node: 18, geo: () => new THREE.IcosahedronGeometry(0.05, 0) },
      { node: 19, geo: () => new THREE.SphereGeometry(0.03, 16, 12) },
      { node: 21, geo: () => new THREE.DodecahedronGeometry(0.05, 0) },
      { node: 23, geo: () => new THREE.CylinderGeometry(0.022, 0.022, 0.1, 12) },
      { node: 25, geo: () => teardropGeo(THREE, 0.085) },
    ];
    beads = [];
    specs.forEach((sp) => {
      const mesh = mk(sp.geo(), 1);
      mesh.userData = {
        node: sp.node,
        radius: approxRadius(sp.node) * 1.6,
        free: false,
        vel: new THREE.Vector3(),
        spin: new THREE.Vector3(
          (Math.random() - 0.5) * 3,
          (Math.random() - 0.5) * 3,
          (Math.random() - 0.5) * 3,
        ),
        settled: false,
        delay: 0,
      };
      scene.add(mesh);
      beads.push(mesh);
    });
  }

  function rebuildThread(THREE: any) {
    if (threadMesh) { scene.remove(threadMesh); threadMesh.geometry.dispose(); }
    const curve = new THREE.CatmullRomCurve3(nodes.map((n: any) => n.pos));
    const geo = new THREE.TubeGeometry(curve, threadN * 2, 0.014, 6, false);
    const mesh = new THREE.Mesh(geo, threadMat);
    mesh.castShadow = true;
    scene.add(mesh);
    threadMesh = mesh;
  }

  // ─── physics: thread (pinned) ──────────────────────────────────────────────

  function stepThread(THREE: any, dt: number, time: number) {
    const g = -9.8;
    const wind = Math.sin(time * 0.7) * 0.4 + Math.sin(time * 1.3) * 0.18;
    const anchor = eyeWorld(THREE);
    nodes[0].pos.copy(anchor); nodes[0].prev.copy(anchor);
    for (let i = 1; i < nodes.length; i++) {
      const n = nodes[i];
      const vx = (n.pos.x - n.prev.x) * 0.98;
      const vy = (n.pos.y - n.prev.y) * 0.98;
      const vz = (n.pos.z - n.prev.z) * 0.98;
      n.prev.copy(n.pos);
      n.pos.x += vx + wind * 0.00012 * i;
      n.pos.y += vy + g * dt * dt;
      n.pos.z += vz + Math.sin(time * 1.3 + i * 0.3) * 0.0002;
    }
    for (let k = 0; k < 18; k++) {
      for (let i = 0; i < nodes.length - 1; i++) {
        const a = nodes[i].pos, b = nodes[i + 1].pos;
        const dx = b.x - a.x, dy = b.y - a.y, dz = b.z - a.z;
        const d = Math.hypot(dx, dy, dz) || 0.0001;
        const diff = (d - segLen) / d;
        const mxa = i === 0 ? 0 : 0.5, mxb = 0.5 + (i === 0 ? 0.5 : 0);
        a.x += dx * diff * mxa; a.y += dy * diff * mxa; a.z += dz * diff * mxa;
        b.x -= dx * diff * mxb; b.y -= dy * diff * mxb; b.z -= dz * diff * mxb;
      }
      nodes[0].pos.copy(anchor);
    }
    rebuildThread(THREE);
  }

  // ─── physics: thread (free, after release) ─────────────────────────────────

  function stepFreeThread(THREE: any, dt: number) {
    const g = -2.6;
    const fy = bounds.floorY + 0.02;
    for (let i = 0; i < nodes.length; i++) {
      const n = nodes[i];
      const vx = (n.pos.x - n.prev.x) * 0.97;
      const vy = (n.pos.y - n.prev.y) * 0.97;
      n.prev.copy(n.pos);
      n.pos.x += vx; n.pos.y += vy + g * dt * dt;
      if (n.pos.y < fy) { n.pos.y = fy; n.prev.y = fy; }
    }
    for (let k = 0; k < 10; k++) {
      for (let i = 0; i < nodes.length - 1; i++) {
        const a = nodes[i].pos, b = nodes[i + 1].pos;
        const dx = b.x - a.x, dy = b.y - a.y, dz = b.z - a.z;
        const d = Math.hypot(dx, dy, dz) || 0.0001;
        const diff = (d - segLen) / d;
        a.x += dx * diff * 0.5; a.y += dy * diff * 0.5; a.z += dz * diff * 0.5;
        b.x -= dx * diff * 0.5; b.y -= dy * diff * 0.5; b.z -= dz * diff * 0.5;
      }
    }
    rebuildThread(THREE);
    if (threadMat.opacity > 0.32) threadMat.opacity -= dt * 0.35;
  }

  // ─── beads: place on thread (idle) ────────────────────────────────────────

  function placeBeadsOnThread() {
    beads.forEach((m) => {
      if (m.userData.free) return;
      const n = nodes[m.userData.node];
      m.position.copy(n.pos);
      m.rotation.x += 0.004; m.rotation.y += 0.006;
    });
  }

  // ─── beads: release (scatter) ─────────────────────────────────────────────

  function releaseBeads(THREE: any) {
    const halfW = bounds.halfW;
    const n = beads.length;
    const order = beads.map((_: any, i: number) => i).sort(() => Math.random() - 0.5);
    beads.forEach((m, i) => {
      const u = m.userData;
      u.free = true;
      const frac = (order[i] + 0.5) / n;
      const targetX = (frac * 2 - 1) * halfW * 0.82 + (Math.random() - 0.5) * 0.6;
      u.vel.set(
        (targetX - m.position.x) * (0.6 + Math.random() * 0.5),
        -0.2 - Math.random() * 0.7,
        (Math.random() - 0.5) * 0.4,
      );
      u.delay = Math.random() * 0.5;
    });
  }

  // ─── beads: physics step ──────────────────────────────────────────────────

  function stepBeads(THREE: any, dt: number) {
    if (!beads.length) return;
    const b = bounds;
    const g = -7.5;
    const floorY = b.floorY;
    let push = 0;
    if (scrollVel) { push = -scrollVel * 0.0009; scrollVel *= 0.8; if (Math.abs(scrollVel) < 0.5) scrollVel = 0; }

    for (const m of beads) {
      const u = m.userData;
      if (!u.free) continue;
      if (u.delay > 0) { u.delay -= dt; continue; }
      u.vel.y += g * dt;
      if (m.position.y < floorY + 0.4 && push) u.vel.x += push;
      if (u.settled) u.vel.x += Math.sin((clock.elapsedTime + u.node) * 0.7) * 0.0006;
      m.position.x += u.vel.x * dt;
      m.position.y += u.vel.y * dt;
      m.position.z += u.vel.z * dt;
      const rad = u.radius;
      if (m.position.y - rad < floorY) {
        m.position.y = floorY + rad;
        if (u.vel.y < 0) u.vel.y = -u.vel.y * 0.32;
        u.vel.x *= 0.86; u.vel.z *= 0.86;
        if (Math.abs(u.vel.y) < 0.25) { u.vel.y = 0; u.settled = true; }
        m.rotation.z -= u.vel.x / Math.max(rad, 0.03) * dt;
      } else { u.settled = false; }
      if (m.position.x - rad < -b.halfW) { m.position.x = -b.halfW + rad; u.vel.x = Math.abs(u.vel.x) * 0.4; }
      if (m.position.x + rad > b.halfW)  { m.position.x = b.halfW - rad;  u.vel.x = -Math.abs(u.vel.x) * 0.4; }
      if (m.position.z > 0.3)  { m.position.z = 0.3;  u.vel.z *= -0.4; }
      if (m.position.z < -0.3) { m.position.z = -0.3; u.vel.z *= -0.4; }
      if (!u.settled) { m.rotation.x += u.spin.x * dt; m.rotation.y += u.spin.y * dt; }
    }

    // bead–bead separation
    for (let i = 0; i < beads.length; i++) {
      const a = beads[i]; if (!a.userData.free || a.userData.delay > 0) continue;
      for (let j = i + 1; j < beads.length; j++) {
        const c = beads[j]; if (!c.userData.free || c.userData.delay > 0) continue;
        const dx = c.position.x - a.position.x, dy = c.position.y - a.position.y;
        const d = Math.hypot(dx, dy) || 0.0001;
        const min = a.userData.radius + c.userData.radius;
        if (d < min) {
          const overlap = (min - d) / 2;
          const nx = dx / d, ny = dy / d;
          a.position.x -= nx * overlap; a.position.y -= ny * overlap;
          c.position.x += nx * overlap; c.position.y += ny * overlap;
          const dvx = (c.userData.vel.x - a.userData.vel.x) * 0.5;
          a.userData.vel.x += dvx * 0.5; c.userData.vel.x -= dvx * 0.5;
        }
      }
    }
  }

  // ─── bounds ────────────────────────────────────────────────────────────────

  function updateBounds() {
    const dist = camera.position.z;
    const vH = 2 * Math.tan((camera.fov * Math.PI / 180) / 2) * dist;
    const vW = vH * camera.aspect;
    bounds = { halfH: vH / 2, halfW: vW / 2, floorY: -vH / 2 + 0.06 };
    if (shadowFloor) shadowFloor.position.y = bounds.floorY - 0.02;
  }

  // ─── reveal ────────────────────────────────────────────────────────────────

  function revealSite() {
    document.documentElement.classList.add("nl-revealed");
    document.documentElement.style.scrollBehavior = "smooth";
    setTimeout(() => {
      const lenis = (window as any).__lenis;
      if (lenis) {
        lenis.scrollTo(0, { immediate: true });
        lenis.resize?.();
      }
      ScrollTrigger.refresh();
    }, 200);
  }

  // ─── trigger pull ─────────────────────────────────────────────────────────

  function triggerPull() {
    if (phase !== "idle") return;
    phase = "pulling";
    pullT = 0;
    released = false;
    const gate = document.getElementById("nl-gate-inner");
    if (gate) { gate.style.opacity = "0"; gate.style.transform = "translateY(16px)"; }
    setTimeout(() => { const g = document.getElementById("nl-gate"); if (g) g.style.display = "none"; }, 950);
  }

  // ─── frame loop ───────────────────────────────────────────────────────────

  function frame() {
    const THREE = (window as any).THREE;
    if (!THREE || !renderer) { rafId = requestAnimationFrame(frame); return; }
    const dt = Math.min(clock.getDelta(), 0.033);
    const time = clock.elapsedTime;

    if (phase === "idle") {
      stepThread(THREE, dt, time);
      placeBeadsOnThread();
      heroGroup.position.y = Math.sin(time * 0.6) * 0.012;
    } else if (phase === "pulling") {
      pullT += dt;
      const T = pullT;

      const ne = easeInOut(Math.min(T / 1.5, 1));
      needle.position.y = 0.03 + ne * 2.6;
      needle.position.x = 0.06 + ne * 0.5;
      if (T > 1.4) {
        needle.children.forEach((c: any) => {
          if (c.material) { c.material.transparent = true; c.material.opacity = Math.max(0, 1 - (T - 1.4) / 0.6); }
        });
      }

      const be = easeInOut(Math.min(T / 2.2, 1));
      const targetX = -bounds.halfW + 0.55, targetY = bounds.halfH - 0.55;
      button.rotation.z = be * 2.7;
      button.position.x = be * targetX;
      button.position.y = be * targetY;
      button.scale.setScalar(1 - be * 0.72);

      if (T > 0.55 && !released) {
        released = true;
        releaseBeads((window as any).THREE);
      }
      if (released) stepFreeThread(THREE, dt);
      stepBeads(THREE, dt);

      if (T > 2.3) {
        phase = "released";
        revealSite();
      }
    } else {
      button.rotation.z += dt * 0.08;
      stepFreeThread(THREE, dt);
      stepBeads(THREE, dt);
    }

    renderer.render(scene, camera);
    rafId = requestAnimationFrame(frame);
  }

  // ─── init Three.js ────────────────────────────────────────────────────────

  function init() {
    const THREE = (window as any).THREE;
    const host = document.getElementById("nl-canvas-host")!;
    const W = window.innerWidth, H = window.innerHeight;

    renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
    renderer.setSize(W, H);
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;
    renderer.outputEncoding = THREE.sRGBEncoding;
    renderer.toneMapping = THREE.LinearToneMapping;
    renderer.toneMappingExposure = 1.0;
    host.appendChild(renderer.domElement);

    scene = new THREE.Scene();
    camera = new THREE.PerspectiveCamera(42, W / H, 0.1, 100);
    camera.position.set(0, 0, 5.4);

    const envTex = makeEnvTexture(THREE);
    const pmrem = new THREE.PMREMGenerator(renderer);
    const envRT = pmrem.fromEquirectangular(envTex);
    scene.environment = envRT.texture;
    envTex.dispose(); pmrem.dispose();

    scene.add(new THREE.HemisphereLight(0xfffaf0, 0xb9b09c, 0.25));
    const key = new THREE.DirectionalLight(0xfff4e2, 2.2);
    key.position.set(-3.2, 5.5, 4.2);
    key.castShadow = true;
    key.shadow.mapSize.set(2048, 2048);
    key.shadow.camera.near = 0.5; key.shadow.camera.far = 20;
    key.shadow.camera.left = -5; key.shadow.camera.right = 5;
    key.shadow.camera.top = 5; key.shadow.camera.bottom = -5;
    key.shadow.bias = -0.0004; key.shadow.radius = 6;
    scene.add(key);
    const fill = new THREE.DirectionalLight(0xeae6f0, 0.5);
    fill.position.set(4, 2, 3); scene.add(fill);
    const rim = new THREE.DirectionalLight(0xffffff, 0.7);
    rim.position.set(2, -1, -4); scene.add(rim);

    const shadowMat = new THREE.ShadowMaterial({ opacity: 0.1 });
    const floor = new THREE.Mesh(new THREE.PlaneGeometry(40, 40), shadowMat);
    floor.rotation.x = -Math.PI / 2;
    floor.position.y = -2.8;
    floor.receiveShadow = true;
    scene.add(floor);
    shadowFloor = floor;

    heroGroup = new THREE.Group(); scene.add(heroGroup);
    heroGroup.rotation.x = -0.14; heroGroup.rotation.y = 0.05;

    buildButton(THREE, heroGroup);
    buildNeedle(THREE, heroGroup);
    scene.updateMatrixWorld(true);
    buildThreadAndBeads(THREE);

    clock = new THREE.Clock();
    updateBounds();

    const onResize = () => {
      const w = window.innerWidth, h = window.innerHeight;
      renderer.setSize(w, h); camera.aspect = w / h; camera.updateProjectionMatrix();
      updateBounds();
    };
    window.addEventListener("resize", onResize);

    frame();
  }

  // ─── DOM wiring ───────────────────────────────────────────────────────────

  function wireDom() {
    const form = document.getElementById("nl-form");
    const input = document.getElementById("nl-input") as HTMLInputElement | null;
    const hint = document.getElementById("nl-hint");

    if (form && input) {
      form.addEventListener("submit", (e) => {
        e.preventDefault();
        const v = (input.value || "").toLowerCase();
        if (/(pull|needle|out|thread|open|begin|enter|start)/.test(v)) {
          triggerPull();
        } else {
          const inner = document.getElementById("nl-gate-inner");
          if (inner) {
            inner.style.animation = "nl-shake .5s ease";
            setTimeout(() => { inner.style.animation = ""; }, 520);
          }
          if (hint) {
            (hint as HTMLElement).style.color = "var(--color-thread)";
            hint.textContent = "almost — try: pull the needle out";
          }
        }
      });
    }

    lastScroll = window.scrollY;
    window.addEventListener("scroll", () => {
      scrollVel += window.scrollY - lastScroll;
      lastScroll = window.scrollY;
    }, { passive: true });
  }

  // ─── boot ─────────────────────────────────────────────────────────────────

  wireDom();
  waitForThree(() => {
    try { init(); } catch (e) { console.error("[needle] init failed", e); }
  });
</script>

<style is:global>
  /* Gate phase: lock scroll so users can't bypass the intro */
  html:not(.nl-revealed) {
    overflow: hidden;
  }
  html:not(.nl-revealed) body {
    overflow: hidden;
  }

  /* Site header + site footer: invisible during gate, fade in after reveal */
  html:not(.nl-revealed) .site-header,
  html:not(.nl-revealed) .site-footer {
    opacity: 0;
    pointer-events: none;
  }
  html.nl-revealed .site-header,
  html.nl-revealed .site-footer {
    opacity: 1;
    pointer-events: auto;
    transition: opacity 0.8s ease 0.4s;
  }

  /* Reveal transitions */
  html.nl-revealed #nl-content {
    opacity: 1 !important;
    pointer-events: auto !important;
  }
  html.nl-revealed #nl-spotlight {
    opacity: 0.4 !important;
  }

  /* Needle landing animations */
  @keyframes nl-cuepulse {
    0%, 100% { opacity: 0.35; transform: translateY(0); }
    50% { opacity: 0.9; transform: translateY(4px); }
  }
  @keyframes nl-shake {
    0%, 100% { transform: translateX(0); }
    20% { transform: translateX(-7px); }
    40% { transform: translateX(6px); }
    60% { transform: translateX(-4px); }
    80% { transform: translateX(3px); }
  }
</style>

