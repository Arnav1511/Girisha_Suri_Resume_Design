---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getOrderedSegments } from "../data/segments";

const segments = getOrderedSegments();
---

<BaseLayout title="Girisha Suri -- Fashion Design Portfolio">
  <Fragment slot="head">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  </Fragment>

  <div id="nl-root">
    <div id="nl-spotlight" aria-hidden="true"></div>
    <div id="nl-canvas-host" aria-hidden="true"></div>
    <div id="nl-grab" aria-hidden="true"></div>

    <main id="nl-content">
      <div id="nl-spacer" aria-hidden="true" style="height: 100vh; pointer-events: none;"></div>

      <header class="nl-hero">
        <p id="nl-kicker" class="nl-kicker">Commercial discipline &middot; Couture finishing</p>
        <h1 id="nl-heading">Girisha Suri</h1>
        <p class="nl-tagline">
          Built across streetwear, evening wear, and the spaces between &mdash; where the surface carries the idea and
          the construction stays honest.
        </p>
      </header>

      <section class="nl-segments" aria-label="Work by segment">
        <p class="nl-section-label">The work</p>
        <ul class="nl-segment-list">
          {segments.map((segment, index) => (
            <li>
              <a href={`/work/${segment.slug}`}>
                <span class="nl-segment-num">{String(index + 1).padStart(2, "0")}</span>
                <span class="nl-segment-name">{segment.name}</span>
                <span class="nl-segment-tag">{segment.slug === "vendor-collaboration" ? "B2B" : "View →"}</span>
                <span class="nl-segment-blurb">{segment.blurb}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <footer class="nl-page-footer">
        <p>"Let the surface carry the idea."</p>
        <span>Girisha Suri &middot; Portfolio</span>
      </footer>
    </main>
  </div>
</BaseLayout>

<script>
  (() => {
    const rootEl = document.getElementById("nl-root");
    if (!rootEl) return;

    const html = document.documentElement;
    const grab = document.getElementById("nl-grab");
    const canvasHost = document.getElementById("nl-canvas-host");
    const contentEl = document.getElementById("nl-content");

    const reduceMotion =
      (window as any).__prefersReducedMotion || window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function revealImmediately() {
      html.classList.add("nl-revealed");
      if (grab) grab.hidden = true;
      if (canvasHost) canvasHost.hidden = true;
      const spacer = document.getElementById("nl-spacer");
      if (spacer) spacer.style.display = "none";
    }

    if (reduceMotion || !grab || !canvasHost || !contentEl) {
      revealImmediately();
      return;
    }

    const S: any = {
      phase: "idle",
      p: 0,
      dragStart: null as null | { x: number; y: number; p: number },
      scrollVel: 0,
      lastScroll: window.scrollY || 0,
      released: false,
      relT: 0,
      btnVy: 0,
      roll: null as null | { pos: number; vel: number; target: number; active: boolean; settleT: number },
      beadColorHex: 0x5e121b,
      threadColorHex: 0x561019,
      swayK: 1,
    };

    // ---------------- drag ----------------
    function wireDrag() {
      const dir = { x: 0.46, y: -0.89 };
      const PULL_PX = 300;

      const down = (e: PointerEvent) => {
        if (S.phase && S.phase !== "idle") return;
        S.dragging = true;
        S.dragStart = { x: e.clientX, y: e.clientY, p: S.p };
        S.phase = "dragging";
        grab!.style.cursor = "grabbing";
        e.preventDefault();
      };
      const move = (e: PointerEvent) => {
        if (!S.dragging || !S.dragStart) return;
        const dx = e.clientX - S.dragStart.x;
        const dy = e.clientY - S.dragStart.y;
        const along = (dx * dir.x + dy * dir.y) / PULL_PX;
        S.p = Math.max(0, Math.min(1, S.dragStart.p + along));
      };
      const up = () => {
        if (!S.dragging) return;
        S.dragging = false;
        grab!.style.cursor = "grab";
        S.phase = S.p >= 0.5 ? "completing" : "returning";
      };
      grab!.addEventListener("pointerdown", down);
      window.addEventListener("pointermove", move, { passive: false });
      window.addEventListener("pointerup", up);

      S.lastScroll = window.scrollY;
      window.addEventListener(
        "scroll",
        () => {
          const y = window.scrollY;
          S.scrollVel += y - S.lastScroll;
          S.lastScroll = y;
        },
        { passive: true }
      );
    }

    function waitForThree(cb: () => void) {
      let tries = 0;
      const tick = () => {
        if ((window as any).THREE) return cb();
        if (tries++ > 200) {
          console.error("[needle] THREE failed to load");
          revealImmediately();
          return;
        }
        setTimeout(tick, 25);
      };
      tick();
    }

    // ---------------- scene ----------------
    function updateBounds() {
      const cam = S.camera;
      const dist = cam.position.z;
      const vH = 2 * Math.tan(((cam.fov * Math.PI) / 180) / 2) * dist;
      const vW = vH * cam.aspect;
      S.bounds = { halfH: vH / 2, halfW: vW / 2, floorY: -vH / 2 + 0.06 };
      if (S.shadowFloor) S.shadowFloor.position.y = S.bounds.floorY - 0.02;
    }

    function makeEnvTexture(THREE: any) {
      const c = document.createElement("canvas");
      c.width = 512;
      c.height = 256;
      const g = c.getContext("2d")!;
      const grad = g.createLinearGradient(0, 0, 0, 256);
      grad.addColorStop(0, "#fffdf7");
      grad.addColorStop(0.32, "#efe3cf");
      grad.addColorStop(0.56, "#c9bda8");
      grad.addColorStop(0.8, "#6f6655");
      grad.addColorStop(1, "#34302a");
      g.fillStyle = grad;
      g.fillRect(0, 0, 512, 256);
      const blobs: Array<[string, number, number, number]> = [
        ["#ffe7c2", 120, 70, 90],
        ["#d8c2e6", 360, 90, 110],
        ["#c2e6d8", 250, 150, 120],
        ["#ffd6e0", 430, 180, 80],
      ];
      blobs.forEach(([col, x, y, r]) => {
        const rg = g.createRadialGradient(x, y, 0, x, y, r);
        rg.addColorStop(0, col);
        rg.addColorStop(1, "rgba(255,255,255,0)");
        g.globalAlpha = 0.55;
        g.fillStyle = rg;
        g.beginPath();
        g.arc(x, y, r, 0, 7);
        g.fill();
      });
      g.globalAlpha = 1;
      const kg = g.createRadialGradient(150, 30, 0, 150, 30, 140);
      kg.addColorStop(0, "rgba(255,255,255,0.95)");
      kg.addColorStop(1, "rgba(255,255,255,0)");
      g.fillStyle = kg;
      g.beginPath();
      g.arc(150, 30, 140, 0, 7);
      g.fill();
      const tex = new THREE.CanvasTexture(c);
      tex.mapping = THREE.EquirectangularReflectionMapping;
      tex.encoding = THREE.sRGBEncoding;
      return tex;
    }

    function buildButton(THREE: any, group: any) {
      const R = 0.95,
        TH = 0.8;
      const geo = new THREE.CylinderGeometry(R, R, TH, 220, 8, false);
      const pos = geo.attributes.position;
      const v = new THREE.Vector3();
      for (let i = 0; i < pos.count; i++) {
        v.fromBufferAttribute(pos, i);
        const ang = Math.atan2(v.z, v.x);
        const rad = Math.hypot(v.x, v.z);
        const wave = 0.026 * Math.sin(3 * ang + 0.6) + 0.016 * Math.sin(5 * ang + 1.7);
        const k = Math.min(1, rad / (R * 0.45));
        if (Math.abs(v.y) > TH * 0.35) v.y += wave * (v.y > 0 ? 1 : 0.6) * k;
        if (rad > R * 0.6) {
          const rr = 1 + 0.02 * Math.sin(4 * ang + 0.4) + 0.01 * Math.sin(7 * ang);
          v.x *= rr;
          v.z *= rr;
        }
        pos.setXYZ(i, v.x, v.y, v.z);
      }
      geo.computeVertexNormals();

      const mat = new THREE.MeshPhysicalMaterial({
        color: 0x6a6155,
        metalness: 0.0,
        roughness: 0.62,
        clearcoat: 0.6,
        clearcoatRoughness: 0.3,
        envMapIntensity: 0.35,
        reflectivity: 0.4,
      });
      const sideMat = new THREE.MeshStandardMaterial({
        color: 0x9d8e72,
        metalness: 0.3,
        roughness: 0.55,
        envMapIntensity: 0.5,
      });
      const btn = new THREE.Mesh(geo, [sideMat, mat, mat]);
      btn.rotation.x = Math.PI / 2;
      btn.rotation.y = 0;
      btn.castShadow = true;
      btn.receiveShadow = true;
      const wrap = new THREE.Group();
      wrap.add(btn);
      group.add(wrap);
      S.button = wrap;
      S.buttonFace = btn;

      new THREE.TextureLoader().load("/images/landing/crystal/button.png", (tex: any) => {
        tex.encoding = THREE.sRGBEncoding;
        tex.anisotropy = Math.min(8, S.renderer.capabilities.getMaxAnisotropy());
        tex.center.set(0.5, 0.5);
        tex.rotation = 0.28;
        mat.map = tex;
        mat.color.set(0xffffff);
        mat.emissiveMap = tex;
        mat.emissive = new THREE.Color(0xffffff);
        mat.emissiveIntensity = 0.45;
        mat.needsUpdate = true;
      });
    }

    function buildNeedle(THREE: any, group: any) {
      const needle = new THREE.Group();
      const metal = new THREE.MeshStandardMaterial({
        color: 0xb9bdc2,
        metalness: 1.0,
        roughness: 0.2,
        envMapIntensity: 1.2,
      });
      const shaft = new THREE.Mesh(new THREE.CylinderGeometry(0.007, 0.011, 2.3, 20), metal);
      shaft.position.y = 0.1;
      shaft.castShadow = true;
      needle.add(shaft);
      const tip = new THREE.Mesh(new THREE.ConeGeometry(0.011, 0.2, 20), metal);
      tip.position.y = -1.15;
      tip.castShadow = true;
      needle.add(tip);
      const eye = new THREE.Mesh(new THREE.TorusGeometry(0.034, 0.0085, 14, 28), metal);
      eye.position.y = 1.31;
      eye.scale.set(0.6, 1, 1);
      eye.castShadow = true;
      needle.add(eye);
      const eyeCap = new THREE.Mesh(new THREE.SphereGeometry(0.016, 14, 10), metal);
      eyeCap.position.y = 1.38;
      needle.add(eyeCap);

      const dir = new THREE.Vector3(0.42, 0.4, 0.82).normalize();
      needle.quaternion.setFromUnitVectors(new THREE.Vector3(0, 1, 0), dir);
      needle.position.set(-0.03, 0.0, -0.04);
      needle.scale.set(1, 1.7, 1);
      group.add(needle);
      S.needle = needle;
      S.eyeLocal = new THREE.Vector3(0.034 * 0.6, 1.31, 0);
      S.pullVec = dir.clone().multiplyScalar(4.8);
    }

    function eyeWorld() {
      return S.needle.localToWorld(S.eyeLocal.clone());
    }

    function biconeGeo(THREE: any, r: number, h: number) {
      const lathe = new THREE.LatheGeometry(
        [new THREE.Vector2(0.0001, -h / 2), new THREE.Vector2(r, 0), new THREE.Vector2(0.0001, h / 2)],
        10
      );
      return lathe.toNonIndexed ? lathe.toNonIndexed() : lathe;
    }

    function teardropGeo(THREE: any, s: number) {
      const pts: Array<[number, number]> = [
        [0.0, -1.05],
        [0.46, -0.86],
        [0.78, -0.55],
        [0.94, -0.18],
        [0.96, 0.1],
        [0.82, 0.42],
        [0.55, 0.7],
        [0.28, 0.9],
        [0.0, 1.08],
      ];
      const prof = pts.map(([r, y]) => new THREE.Vector2(Math.max(0.0015, r * s), y * s * 1.25));
      const geo = new THREE.LatheGeometry(prof, 24);
      geo.computeVertexNormals();
      return geo;
    }

    function rebuildThread(THREE: any) {
      if (S.threadMesh) {
        S.scene.remove(S.threadMesh);
        S.threadMesh.geometry.dispose();
      }
      const curve = new THREE.CatmullRomCurve3(S.nodes.map((n: any) => n.pos));
      const geo = new THREE.TubeGeometry(curve, S.threadN * 3, 0.0075, 8, false);
      const mesh = new THREE.Mesh(geo, S.threadMat);
      mesh.castShadow = true;
      S.scene.add(mesh);
      S.threadMesh = mesh;
    }

    function buildThreadAndBeads(THREE: any) {
      const N = 30;
      S.threadN = N;
      S.segLen = 0.072;
      const anchor = eyeWorld();
      S.nodes = [];
      for (let i = 0; i < N; i++) {
        const t = i / (N - 1);
        const p = new THREE.Vector3(anchor.x + Math.sin(t * Math.PI) * 0.18, anchor.y - S.segLen * i, anchor.z);
        S.nodes.push({ pos: p.clone(), prev: p.clone() });
      }
      S.threadMat = new THREE.MeshStandardMaterial({
        color: new THREE.Color(S.threadColorHex).convertSRGBToLinear(),
        roughness: 0.95,
        metalness: 0.0,
        envMapIntensity: 0.1,
        transparent: true,
        opacity: 1,
      });
      S.threadMesh = null;
      rebuildThread(THREE);

      const base = new THREE.Color(S.beadColorHex).convertSRGBToLinear();
      const beadMat = () => {
        const c = base
          .clone()
          .offsetHSL((Math.random() - 0.5) * 0.01, (Math.random() - 0.5) * 0.04, (Math.random() - 0.5) * 0.025);
        return new THREE.MeshPhysicalMaterial({
          color: c,
          metalness: 0.0,
          roughness: 0.16 + Math.random() * 0.1,
          clearcoat: 0.85,
          clearcoatRoughness: 0.12,
          envMapIntensity: 0.5,
          reflectivity: 0.5,
          flatShading: true,
        });
      };
      const mk = (geo: any) => {
        const m = new THREE.Mesh(geo, beadMat());
        m.castShadow = true;
        return m;
      };
      const round = (r: number) => new THREE.IcosahedronGeometry(r, 1);
      const bugle = (r: number, h: number) => new THREE.CylinderGeometry(r, r, h, 16).rotateX((Math.PI / 2) * Math.random());
      const rondelle = (r: number) => new THREE.CylinderGeometry(r, r, r * 0.5, 18).rotateX(Math.PI / 2);
      const bicone = (r: number) => biconeGeo(THREE, r, r * 1.9);
      const specs = [
        { node: 16, geo: () => round(0.026), r: 0.026 },
        { node: 18, geo: () => bicone(0.024), r: 0.03 },
        { node: 19, geo: () => round(0.03), r: 0.03 },
        { node: 20, geo: () => rondelle(0.03), r: 0.03 },
        { node: 21, geo: () => round(0.024), r: 0.024 },
        { node: 22, geo: () => bugle(0.018, 0.07), r: 0.045 },
        { node: 23, geo: () => round(0.032), r: 0.032 },
        { node: 24, geo: () => bicone(0.026), r: 0.032 },
        { node: 25, geo: () => round(0.028), r: 0.028 },
        { node: 26, geo: () => round(0.034), r: 0.034 },
        { node: 27, geo: () => round(0.026), r: 0.026 },
        { node: 29, geo: () => teardropGeo(THREE, 0.05), r: 0.058 },
      ];
      S.beads = [];
      const BS = 1.0;
      specs.forEach((sp) => {
        const mesh = mk(sp.geo());
        mesh.scale.setScalar(BS);
        mesh.rotation.set(Math.random() * 6, Math.random() * 6, Math.random() * 6);
        mesh.userData = {
          node: sp.node,
          radius: sp.r * 1.1 * BS,
          free: false,
          vel: new THREE.Vector3(),
          spin: new THREE.Vector3((Math.random() - 0.5) * 3, (Math.random() - 0.5) * 3, (Math.random() - 0.5) * 3),
          settled: false,
          delay: 0,
        };
        S.scene.add(mesh);
        S.beads.push(mesh);
      });
    }

    function easeOut(t: number) {
      return 1 - Math.pow(1 - t, 3);
    }

    function applyPull(p: number) {
      S.needle.position.copy(S.needleBase).addScaledVector(S.pullVec, p);
      S.button.rotation.z = p * 0.55;
      if (S.phase === "completing" && p > 0.75) {
        S.needle.children.forEach((c: any) => {
          if (c.material) {
            c.material.transparent = true;
            c.material.opacity = Math.max(0, 1 - (p - 0.75) / 0.25);
          }
        });
      } else {
        S.needle.children.forEach((c: any) => {
          if (c.material) c.material.opacity = 1;
        });
      }
    }

    function stepThread(THREE: any, dt: number, time: number) {
      const g = -9.8;
      const wind = (Math.sin(time * 0.8) * 0.5 + Math.sin(time * 1.5) * 0.25) * S.swayK;
      const anchor = eyeWorld();
      const nodes = S.nodes;
      nodes[0].pos.copy(anchor);
      nodes[0].prev.copy(anchor);
      for (let i = 1; i < nodes.length; i++) {
        const n = nodes[i];
        const vx = (n.pos.x - n.prev.x) * 0.985,
          vy = (n.pos.y - n.prev.y) * 0.985,
          vz = (n.pos.z - n.prev.z) * 0.985;
        n.prev.copy(n.pos);
        n.pos.x += vx + wind * 0.000055 * i;
        n.pos.y += vy + g * dt * dt;
        n.pos.z += vz + Math.sin(time * 1.3 + i * 0.3) * 0.00009 * S.swayK;
      }
      for (let k = 0; k < 20; k++) {
        for (let i = 0; i < nodes.length - 1; i++) {
          const a = nodes[i].pos,
            b = nodes[i + 1].pos;
          const dx = b.x - a.x,
            dy = b.y - a.y,
            dz = b.z - a.z;
          const d = Math.hypot(dx, dy, dz) || 0.0001;
          const diff = (d - S.segLen) / d;
          const mxa = i === 0 ? 0 : 0.5,
            mxb = 0.5 + (i === 0 ? 0.5 : 0);
          a.x += dx * diff * mxa;
          a.y += dy * diff * mxa;
          a.z += dz * diff * mxa;
          b.x -= dx * diff * mxb;
          b.y -= dy * diff * mxb;
          b.z -= dz * diff * mxb;
        }
        nodes[0].pos.copy(anchor);
      }
      rebuildThread(THREE);
    }

    function stepFreeThread(THREE: any, dt: number) {
      const g = -2.6;
      const nodes = S.nodes;
      const fy = S.bounds.floorY + 0.02;
      for (let i = 0; i < nodes.length; i++) {
        const n = nodes[i];
        const vx = (n.pos.x - n.prev.x) * 0.97,
          vy = (n.pos.y - n.prev.y) * 0.97;
        n.prev.copy(n.pos);
        n.pos.x += vx;
        n.pos.y += vy + g * dt * dt;
        if (n.pos.y < fy) {
          n.pos.y = fy;
          n.prev.y = fy;
        }
      }
      for (let k = 0; k < 10; k++) {
        for (let i = 0; i < nodes.length - 1; i++) {
          const a = nodes[i].pos,
            b = nodes[i + 1].pos;
          const dx = b.x - a.x,
            dy = b.y - a.y,
            dz = b.z - a.z;
          const d = Math.hypot(dx, dy, dz) || 0.0001;
          const diff = (d - S.segLen) / d;
          a.x += dx * diff * 0.5;
          a.y += dy * diff * 0.5;
          a.z += dz * diff * 0.5;
          b.x -= dx * diff * 0.5;
          b.y -= dy * diff * 0.5;
          b.z -= dz * diff * 0.5;
        }
      }
      rebuildThread(THREE);
      if (S.threadMat.opacity > 0) S.threadMat.opacity = Math.max(0, S.threadMat.opacity - dt * 0.5);
    }

    function placeBeadsOnThread() {
      S.beads.forEach((m: any) => {
        if (m.userData.free) return;
        const n = S.nodes[m.userData.node];
        m.position.copy(n.pos);
        m.rotation.x += 0.003;
        m.rotation.y += 0.005;
      });
    }

    function releaseBeads() {
      const halfW = S.bounds.halfW;
      const n = S.beads.length;
      const order = S.beads.map((_: any, i: number) => i).sort(() => Math.random() - 0.5);
      S.beads.forEach((m: any, i: number) => {
        const u = m.userData;
        u.free = true;
        const frac = (order[i] + 0.5) / n;
        const targetX = (frac * 2 - 1) * halfW * 0.86 + (Math.random() - 0.5) * 0.6;
        u.vel.set(
          (targetX - m.position.x) * (0.7 + Math.random() * 0.6),
          -0.2 - Math.random() * 0.8,
          (Math.random() - 0.5) * 0.4
        );
        u.delay = Math.random() * 0.4;
      });
    }

    function stepBeads(dt: number) {
      if (!S.beads) return;
      const b = S.bounds,
        g = -8.0,
        floorY = b.floorY;
      const arr = S.beads;
      let push = 0;
      if (S.scrollVel) {
        push = -S.scrollVel * 0.006;
        S.scrollVel *= 0.85;
        if (Math.abs(S.scrollVel) < 0.3) S.scrollVel = 0;
      }
      for (const m of arr) {
        const u = m.userData;
        if (!u.free) continue;
        if (u.delay > 0) {
          u.delay -= dt;
          continue;
        }
        u.vel.y += g * dt;
        m.position.x += u.vel.x * dt;
        m.position.y += u.vel.y * dt;
        m.position.z += u.vel.z * dt;
        const rad = u.radius;
        const rfloor = floorY;
        if (m.position.y - rad < rfloor) {
          m.position.y = rfloor + rad;
          if (u.vel.y < 0) u.vel.y = -u.vel.y * 0.34;
          u.vel.x *= 0.85;
          u.vel.z *= 0.85;
          if (push) u.vel.x += push;
          if (Math.abs(u.vel.y) < 0.25) {
            u.vel.y = 0;
            u.settled = true;
          }
          m.rotation.z -= (u.vel.x / Math.max(rad, 0.03)) * dt;
        } else u.settled = false;
        if (m.position.x - rad < -b.halfW) {
          m.position.x = -b.halfW + rad;
          u.vel.x = Math.abs(u.vel.x) * 0.4;
        }
        if (m.position.x + rad > b.halfW) {
          m.position.x = b.halfW - rad;
          u.vel.x = -Math.abs(u.vel.x) * 0.4;
        }
        if (m.position.z > 0.3) {
          m.position.z = 0.3;
          u.vel.z *= -0.4;
        }
        if (m.position.z < -0.3) {
          m.position.z = -0.3;
          u.vel.z *= -0.4;
        }
        if (!u.settled) {
          m.rotation.x += u.spin.x * dt;
          m.rotation.y += u.spin.y * dt;
        }
      }
      for (let i = 0; i < arr.length; i++) {
        const a = arr[i];
        if (!a.userData.free || a.userData.delay > 0) continue;
        for (let j = i + 1; j < arr.length; j++) {
          const c = arr[j];
          if (!c.userData.free || c.userData.delay > 0) continue;
          const dx = c.position.x - a.position.x,
            dy = c.position.y - a.position.y;
          const d = Math.hypot(dx, dy) || 0.0001;
          const min = a.userData.radius + c.userData.radius;
          if (d < min) {
            const overlap = (min - d) / 2,
              nx = dx / d,
              ny = dy / d;
            a.position.x -= nx * overlap;
            a.position.y -= ny * overlap;
            c.position.x += nx * overlap;
            c.position.y += ny * overlap;
            const dvx = (c.userData.vel.x - a.userData.vel.x) * 0.5;
            a.userData.vel.x += dvx * 0.5;
            c.userData.vel.x -= dvx * 0.5;
          }
        }
      }
    }

    function beginTransition() {
      html.classList.add("nl-revealed");
      contentEl!.style.pointerEvents = "auto";
      (window as any).__lenis?.stop();
      const heading = document.getElementById("nl-kicker") || document.getElementById("nl-heading");
      const startY = window.scrollY;
      const targetY = heading
        ? Math.max(0, heading.getBoundingClientRect().top + startY - window.innerHeight * 0.06)
        : window.innerHeight;
      S.roll = { pos: startY, vel: 0, target: targetY, active: true, settleT: 0 };
    }

    function scrollDocumentTo(pos: number) {
      window.scrollTo(0, pos);
    }

    function stepRoll(dt: number) {
      const r = S.roll;
      if (!r || !r.active) return;
      const dist = r.target - r.pos;
      let falling = 0;
      if (S.beads) for (const m of S.beads) if (m.userData.free && !m.userData.settled) falling++;
      const weight = 0.35 + 0.65 * (falling / Math.max(1, S.beads.length));
      r.vel += dist * 2.4 * weight * dt;
      r.vel += dist * 0.9 * dt;
      r.vel *= 1 - 3.2 * dt;
      r.pos += r.vel * dt;
      if (r.pos < 0) {
        r.pos = 0;
        r.vel = 0;
      }
      scrollDocumentTo(r.pos);
      if (Math.abs(dist) < 0.6 && Math.abs(r.vel) < 0.6) {
        r.settleT += dt;
        if (r.settleT > 0.25) {
          scrollDocumentTo(r.target);
          const spacer = document.getElementById("nl-spacer");
          if (spacer) {
            spacer.style.display = "none";
            const heading = document.getElementById("nl-kicker") || document.getElementById("nl-heading");
            const settledY = heading
              ? Math.max(0, heading.getBoundingClientRect().top + window.scrollY - window.innerHeight * 0.06)
              : 0;
            scrollDocumentTo(settledY);
          }
          r.active = false;
          const lenis = (window as any).__lenis;
          lenis?.resize?.();
          lenis?.start?.();
          window.dispatchEvent(new Event("resize"));
        }
      } else r.settleT = 0;
    }

    function frame() {
      const THREE = (window as any).THREE;
      if (!THREE || !S.renderer) return;
      const dt = Math.min(S.clock.getDelta(), 0.033);
      const time = S.clock.elapsedTime;

      if (S.phase === "idle") {
        stepThread(THREE, dt, time);
        placeBeadsOnThread();
        S.heroGroup.position.y = Math.sin(time * 0.6) * 0.01;
      } else if (S.phase === "dragging") {
        applyPull(S.p);
        stepThread(THREE, dt, time);
        placeBeadsOnThread();
      } else if (S.phase === "returning") {
        S.p += (0 - S.p) * Math.min(1, dt * 8);
        applyPull(S.p);
        stepThread(THREE, dt, time);
        placeBeadsOnThread();
        if (S.p < 0.005) {
          S.p = 0;
          S.phase = "idle";
        }
      } else if (S.phase === "completing") {
        S.p = Math.min(1, S.p + dt * 1.7);
        applyPull(S.p);
        S.button.rotation.z = easeOut(S.p) * Math.PI * 1.15;
        if (S.p > 0.45 && !S.released) {
          S.released = true;
          releaseBeads();
          beginTransition();
        }
        if (S.released) {
          stepFreeThread(THREE, dt);
          stepBeads(dt);
          stepRoll(dt);
        } else {
          stepThread(THREE, dt, time);
          placeBeadsOnThread();
        }
        if (S.p >= 1) S.phase = "released";
      } else {
        S.relT = (S.relT || 0) + dt;
        S.button.rotation.z += dt * 1.4;
        if (S.relT < 0.28) {
          S.button.position.x -= dt * 2.2;
        } else {
          S.btnVy = (S.btnVy || -1.5) - 16 * dt;
          S.button.position.y += S.btnVy * dt;
          S.button.position.x -= dt * 1.2;
        }
        if (S.needle) S.needle.scale.multiplyScalar(1 - dt * 3.0);
        stepFreeThread(THREE, dt);
        stepBeads(dt);
        stepRoll(dt);
      }

      S.renderer.render(S.scene, S.camera);
    }

    function init() {
      const THREE = (window as any).THREE;
      const host = canvasHost!;
      const W = window.innerWidth,
        H = window.innerHeight;

      const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
      renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
      renderer.setSize(W, H);
      renderer.shadowMap.enabled = true;
      renderer.shadowMap.type = THREE.PCFSoftShadowMap;
      renderer.outputEncoding = THREE.sRGBEncoding;
      renderer.toneMapping = THREE.ACESFilmicToneMapping;
      renderer.toneMappingExposure = 0.82;
      host.appendChild(renderer.domElement);
      S.renderer = renderer;

      const scene = new THREE.Scene();
      S.scene = scene;
      const camera = new THREE.PerspectiveCamera(40, W / H, 0.1, 100);
      camera.position.set(0, 0, 9.6);
      S.camera = camera;

      const envTex = makeEnvTexture(THREE);
      const pmrem = new THREE.PMREMGenerator(renderer);
      const envRT = pmrem.fromEquirectangular(envTex);
      scene.environment = envRT.texture;
      envTex.dispose();
      pmrem.dispose();

      scene.add(new THREE.HemisphereLight(0xfffaf0, 0xb9b09c, 0.35));
      const key = new THREE.DirectionalLight(0xfff4e2, 1.45);
      key.position.set(-3.2, 4.6, 5.0);
      key.castShadow = true;
      key.shadow.mapSize.set(2048, 2048);
      key.shadow.camera.near = 0.5;
      key.shadow.camera.far = 22;
      key.shadow.camera.left = -6;
      key.shadow.camera.right = 6;
      key.shadow.camera.top = 6;
      key.shadow.camera.bottom = -6;
      key.shadow.bias = -0.0004;
      key.shadow.radius = 7;
      scene.add(key);
      const fill = new THREE.DirectionalLight(0xeae6f0, 0.45);
      fill.position.set(4, 2, 3);
      scene.add(fill);
      const rim = new THREE.DirectionalLight(0xffffff, 0.65);
      rim.position.set(2.5, -1, -4);
      scene.add(rim);

      const shadowMat = new THREE.ShadowMaterial({ opacity: 0.06 });
      const floor = new THREE.Mesh(new THREE.PlaneGeometry(50, 50), shadowMat);
      floor.rotation.x = -Math.PI / 2;
      floor.position.y = -2.9;
      floor.receiveShadow = true;
      scene.add(floor);
      S.shadowFloor = floor;

      const heroGroup = new THREE.Group();
      scene.add(heroGroup);
      S.heroGroup = heroGroup;
      heroGroup.rotation.x = -0.12;
      heroGroup.rotation.y = 0.04;
      heroGroup.scale.setScalar(0.5);

      buildButton(THREE, heroGroup);
      buildNeedle(THREE, heroGroup);
      scene.updateMatrixWorld(true);
      buildThreadAndBeads(THREE);

      S.phase = "idle";
      S.clock = new THREE.Clock();
      S.needleBase = S.needle.position.clone();
      updateBounds();

      const onResize = () => {
        const w = window.innerWidth,
          h = window.innerHeight;
        renderer.setSize(w, h);
        camera.aspect = w / h;
        camera.updateProjectionMatrix();
        updateBounds();
      };
      window.addEventListener("resize", onResize);

      const animate = () => {
        requestAnimationFrame(animate);
        frame();
      };
      animate();
    }

    wireDrag();
    waitForThree(() => {
      try {
        init();
      } catch (e) {
        console.error("[needle] init failed", e);
        revealImmediately();
      }
    });
  })();
</script>

