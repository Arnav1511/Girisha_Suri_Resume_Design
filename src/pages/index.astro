---
import BaseLayout from "../layouts/BaseLayout.astro";
import ParticleAssemblyHero from "../components/thread/ParticleAssemblyHero.astro";
import SegmentCard from "../components/cards/SegmentCard.astro";
import { getOrderedSegments } from "../data/segments";

const segments = getOrderedSegments();
---

<BaseLayout title="Girisha Suri — Fashion Design Portfolio">
  <main>
    <section class="hero" data-hero>
      <div class="hero-veil" data-hero-veil></div>
      <div class="hero-content">
        <p class="kicker">Fashion design portfolio</p>
        <h1>Girisha Suri</h1>
        <p class="tagline">
          Commercial discipline, couture finishing — built across streetwear, evening wear,
          and the spaces between.
        </p>
        <p class="scroll-cue">Scroll to explore</p>
      </div>
    </section>

    <ParticleAssemblyHero
      image="/images/landing/karigar-mark.jpg"
      imageAlt="A karigar hand-stitching a running pattern into indigo cloth."
      imageWidth={620}
      imageHeight={795}
    />

    <div class="outro-fade" data-outro-fade></div>

    <section class="segments" aria-label="Work by segment">
      <ul>
        {segments.map((segment, index) => (
          <SegmentCard segment={segment} index={index} />
        ))}
      </ul>
    </section>
  </main>
</BaseLayout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function setUp() {
    const hero = document.querySelector<HTMLElement>("[data-hero]");
    const veil = document.querySelector<HTMLElement>("[data-hero-veil]");
    const outro = document.querySelector<HTMLElement>("[data-outro-fade]");
    if (!hero || !veil || !outro) return;

    if (window.__prefersReducedMotion) return;

    const kicker = hero.querySelector(".kicker");
    const h1 = hero.querySelector("h1");
    const tagline = hero.querySelector(".tagline");
    const cue = hero.querySelector(".scroll-cue");

    // A dark veil rises from the bottom of the hero as you scroll — not a
    // flat color swap on the whole section, an actual tide moving through
    // it — so it always matches the (already-dark) assembly section right
    // beneath it, with no hard seam at any scroll position. The text
    // recedes (shrinks + lifts) rather than growing, and .hero clips
    // anything that travels past its own edges so nothing ever
    // double-exposes against the fixed header.
    gsap.timeline({
      scrollTrigger: { trigger: hero, start: "top top", end: "bottom top", scrub: true },
    })
      .fromTo(veil, { scaleY: 0 }, { scaleY: 1, ease: "none", duration: 1 }, 0)
      .to([kicker, tagline, cue], { opacity: 0, y: -30, ease: "none", duration: 0.5 }, 0)
      .to(h1, { opacity: 0, scale: 0.82, y: -36, ease: "none", duration: 0.5 }, 0);

    // Mirror fade back to canvas in a dedicated buffer band, so the grid
    // section itself never has to deal with a transitioning background.
    gsap.to(outro, {
      backgroundColor: "#E4E1D6",
      ease: "none",
      scrollTrigger: { trigger: outro, start: "top bottom", end: "bottom center", scrub: true },
    });
  }

  setUp();
</script>

<style>
  .hero {
    position: relative;
    height: 100vh;
    overflow: hidden;
  }

  .hero-veil {
    position: absolute;
    inset: 0;
    background: var(--color-ink);
    transform: scaleY(0);
    transform-origin: bottom center;
    z-index: 0;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: var(--space-md);
    padding: var(--space-xl) var(--page-gutter);
  }

  .kicker {
    font-size: var(--fs-label);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-text-muted);
  }

  .hero h1 {
    font-family: var(--font-display);
    font-variation-settings: var(--fv-hero);
    font-size: var(--fs-hero);
    line-height: var(--lh-display);
    letter-spacing: var(--tracking-display);
    margin: 0;
    transform-origin: center center;
  }

  .tagline {
    max-width: 34rem;
    font-size: var(--fs-body-lg);
    color: var(--color-text-muted);
  }

  .scroll-cue {
    margin-top: var(--space-2xl);
    font-size: var(--fs-label);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-text-muted);
    opacity: 0.7;
  }

  .outro-fade {
    height: 30vh;
    background: var(--color-ink);
  }

  .segments {
    max-width: var(--max-width-content);
    margin: 0 auto;
    padding: var(--space-2xl) var(--page-gutter) var(--space-3xl);
  }

  .segments ul {
    border-bottom: 1px solid var(--color-border);
  }
</style>
