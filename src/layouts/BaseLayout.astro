---
import "../styles/global.css";
import SmoothScroll from "../components/scroll/SmoothScroll.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import PasswordGateModal from "../components/gate/PasswordGateModal.astro";
import RecruiterFilter from "../components/filter/RecruiterFilter.astro";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Girisha Suri — fashion design portfolio." } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <noscript><style>[data-reveal] { opacity: 1 !important; }</style></noscript>
    <slot name="head" />
  </head>
  <body>
    <SmoothScroll />
    <Header />
    <slot />
    <Footer />
    <PasswordGateModal />
    <RecruiterFilter />
  </body>
</html>
